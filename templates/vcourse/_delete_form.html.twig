<button type="button" class="btn btn-danger w-100" id="delete-course-btn">
    <i class="bi bi-trash"></i> Delete Course
</button>

<form id="delete-course-form"
      action="{{ path('app_vcourse_delete', {'id': vcourse.id}) }}"
      method="post"
      style="display: none;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vcourse.id) }}">
    <input type="hidden" name="_method" value="DELETE">
</form>

<script>
    document.getElementById('delete-course-btn').addEventListener('click', function () {
        Swal.fire({
            title: 'Are you sure?',
            text: 'Do you want to delete "{{ vcourse.title|e('js') }}"? This action cannot be undone!',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: '<i class="bi bi-trash"></i> Yes, delete it!',
            cancelButtonText: '<i class="bi bi-x-circle"></i> Cancel'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('delete-course-form').submit();
            }
        });
    });
</script>
