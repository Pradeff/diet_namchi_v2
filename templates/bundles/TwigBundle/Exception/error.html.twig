{% extends 'base.html.twig' %}

{% block title %}
    {{ status_code }} {{ status_text }}
{% endblock %}

{% block body %}

    <section class="d-flex align-items-center bg-light">
        <div class="container py-5">

            <div class="row justify-content-center">
                <div class="col-xl-9 col-lg-10">

                    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                        <div class="row g-0 align-items-center">

                            <!-- Content -->
                            <div class="col-lg-7 order-2 order-lg-1">
                                <div class="p-4 p-lg-5">

                                <span class="badge bg-danger-subtle text-danger fw-semibold mb-3">
                                    Error {{ status_code }}
                                </span>

                                    <h1 class="display-6 fw-bold mb-2">
                                        {{ status_text }}
                                    </h1>

                                    <p class="text-muted fs-6 mb-4">
                                        Something went wrong while processing your request.
                                        If the problem persists, please contact support.
                                    </p>

                                    <div class="d-flex flex-wrap gap-3">
                                        <a href="{{ path('app_main') }}"
                                           class="btn btn-primary px-4">
                                            <i class="bi bi-house-door me-1"></i>
                                            Go Home
                                        </a>

                                        <button onclick="history.back()"
                                                class="btn btn-outline-secondary px-4">
                                            <i class="bi bi-arrow-left me-1"></i>
                                            Go Back
                                        </button>
                                    </div>

                                    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                        <div class="mt-4 text-muted small">
                                            Logged in as {{ app.user.userIdentifier }}
                                        </div>
                                    {% endif %}

                                </div>
                            </div>

                            <!-- Illustration -->
                            <div class="col-lg-5 order-1 order-lg-2 bg-body-tertiary text-center">
                                <div class="p-4 p-lg-5">

                                    <svg xmlns="http://www.w3.org/2000/svg" width="14em" height="14em" viewBox="0 0 32 32"><path fill="#AC5151" d="M30.48 25.145H32v1.52h-1.52ZM32 14.475v-3.05h-1.52v1.53h-1.53v-3.05h-1.52v6.1H25.9v-1.53h-1.52v3.05h3.05v4.57h-7.62v1.53H32v-1.53h-3.05v-7.62zM28.95.765H32v1.52h-3.05Zm-3.05 24.38h1.53v1.52H25.9Zm-1.52-21.33h3.05v1.52h-3.05Zm-4.57 21.33h1.52v1.52h-1.52Zm0-15.24h-4.57v1.52h4.57v1.53h1.52v-7.62h-1.52zm-6.1 6.1h-3.04v1.52h3.04v1.52h-3.04v-1.52H9.14v6.1h4.57v1.52H9.14v1.52H4.57V28.2H6.1v3.04h3.04v-1.52H7.62V28.2h4.57v-1.53h1.52v1.53h3.05v-1.53h-1.52v-6.09h1.52v1.52h1.53v-3.05h-3.05v-4.57h4.57v-1.52h-6.1Zm0 6.09h-3.04v-1.52h3.04ZM10.67.765h3.04v1.52h-3.04Zm-1.53 6.09h1.53v3.05H9.14Z"/><path fill="#A41B1B" d="M7.62 3.815h12.19v1.52H7.62Zm0 19.81h1.52v1.52H7.62ZM6.1 5.335h1.52v10.67H6.1Zm-1.53 10.67H6.1v4.57H4.57Zm-1.52 9.14h1.52v1.52H3.05Zm0-4.57h1.52v1.52H3.05Zm-1.53 3.05h1.53v1.52H1.52ZM0 5.335h3.05v1.52H0Zm1.52 15.24h1.53v-1.53H1.52v-1.52H0v6.1h1.52z"/></svg>

                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </section>

{% endblock %}
