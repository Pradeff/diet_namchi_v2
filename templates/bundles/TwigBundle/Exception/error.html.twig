{# templates/bundles/TwigBundle/Exception/error.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}
    {{ status_code }} • {{ status_text }}
{% endblock %}

{% block body %}
    <style>
        .error-page-wrapper {
            min-height: 100vh;
            background:
                radial-gradient(circle at top left, rgba(255, 193, 7, 0.18), transparent 55%),
                radial-gradient(circle at bottom right, rgba(248, 113, 113, 0.24), transparent 55%),
                #020617;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            position: relative;
        }
        .error-glass-card {
            background: rgba(15, 23, 42, 0.9);
            border-radius: 1.5rem;
            border: 1px solid rgba(248, 249, 250, 0.12);
            box-shadow: 0 24px 70px rgba(15, 23, 42, 0.9);
            backdrop-filter: blur(18px);
        }
        .error-pill {
            border-radius: 999px;
            border: 1px solid rgba(255, 193, 7, 0.45);
            background: linear-gradient(135deg, rgba(255, 193, 7, 0.2), rgba(239, 68, 68, 0.18));
        }
        .error-code-display {
            border-radius: 1rem;
            border: 1px solid rgba(248, 250, 252, 0.2);
            background: rgba(15, 23, 42, 0.95);
        }
        .error-shadow-btn {
            box-shadow: 0 14px 35px rgba(248, 113, 113, 0.5);
        }
    </style>

    <div class="error-page-wrapper">
        <div class="container px-3">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xl-7">
                    <div class="error-glass-card p-4 p-md-5 text-white position-relative">
                        <div class="mb-4 d-flex justify-content-between align-items-center">
                            <div class="error-pill px-3 py-1 d-inline-flex align-items-center gap-2">
                            <span class="badge rounded-pill bg-warning text-dark small">
                                <i class="bi bi-exclamation-octagon-fill me-1"></i>
                                Error detected
                            </span>
                                <span class="text-light small text-opacity-75">
                                Code {{ status_code }} • {{ status_text }}
                            </span>
                            </div>
                            <span class="text-secondary small d-none d-md-inline">
                            DIET Namchi • System alert
                        </span>
                        </div>

                        <div class="row g-4 align-items-center">
                            <div class="col-md-4">
                                <div class="error-code-display px-3 py-3 text-center">
                                    <div class="text-uppercase small mb-1 text-warning">
                                        Status code
                                    </div>
                                    <div class="display-4 fw-semibold lh-1 text-danger">
                                        {{ status_code }}
                                    </div>
                                    <div class="text-secondary small mt-1">
                                        {{ status_text }}
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-8">
                                <h1 class="h3 h-lg-2 fw-semibold mb-3">
                                <span class="badge bg-danger-subtle text-danger fw-semibold me-2">
                                    <i class="bi bi-lightning-charge-fill me-1"></i>
                                    Something went wrong
                                </span>
                                </h1>
                                <p class="mb-2 text-secondary">
                                    We ran into a problem while processing your request.
                                </p>
                                <p class="mb-3 text-secondary">
                                    Please try again in a few moments. If this continues, contact support and
                                    include the error code
                                    <span class="fw-bold text-warning-emphasis">{{ status_code }}</span>
                                    and message
                                    <span class="fw-bold text-warning-emphasis">{{ status_text }}</span>.
                                </p>

                                {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                                    <p class="mb-3 text-secondary small d-flex align-items-center gap-2">
                                    <span class="badge rounded-circle bg-success-subtle p-1">
                                        <span class="visually-hidden">Online</span>
                                    </span>
                                        Logged in as
                                        <span class="fw-semibold text-light">{{ app.user.userIdentifier }}</span>
                                    </p>
                                {% endif %}

                                <div class="d-flex flex-wrap gap-2 pt-1">
                                    <a href="{{ path('app_main') }}"
                                       class="btn btn-outline-success fw-semibold px-4">
                                        <i class="bi bi-house-door-fill me-1"></i>
                                        Go to main page
                                    </a>

                                    <button type="button"
                                            onclick="window.history.back();"
                                            class="btn btn-outline-warning px-4">
                                        <i class="bi bi-arrow-left me-1"></i>
                                        Try previous page
                                    </button>

                                </div>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top border-secondary border-opacity-25 d-flex justify-content-between align-items-center small text-secondary">
                            <span>Request ID: <span class="text-light text-opacity-75">N/A</span></span>
                            <span class="d-none d-sm-inline">Error handler • {{ status_code }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
