<form method="post"
      action="{{ path('app_vgallery_delete', {'id': vgallery.id}) }}"
      class="d-inline"
      id="delete-form-{{ vgallery.id }}">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vgallery.id) }}">
    <button type="button" class="btn btn-outline-danger ms-2" onclick="confirmDelete(event, {{ vgallery.id }})">
        <i class="bi bi-trash"></i> Delete
    </button>
</form>

<script>
    function confirmDelete(event, id) {
        event.preventDefault();

        Swal.fire({
            title: 'Are you sure?',
            text: "This will delete the gallery and all its images. You won't be able to revert this!",
            icon: 'warning',
            allowOutsideClick: false,
            allowEscapeKey: false,
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Yes, delete it!',
            customClass: {
                popup: 'rounded-4 border-0',
                confirmButton: 'btn btn-danger px-4 py-2',
                cancelButton: 'btn btn-outline-secondary px-4 py-2 ms-2'
            },
            buttonsStyling: false // Allows your custom Bootstrap classes to take effect
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('delete-form-' + id).submit();
            }
        });
    }
</script>
