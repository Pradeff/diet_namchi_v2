{% extends 'base_dashboard.html.twig' %}

{% block title %}Galleries List{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text_color_default">
                    <i class="bi bi-collection"></i>
                    Galleries
                </h5>
                <a href="{{ path('app_vgallery_new') }}" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-lg"></i>
                    Add New
                </a>
            </div>
        </div>
    </div>

    <div class="container">

        {% if vgalleries is empty %}
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i>
                No galleries found. <a href="{{ path('app_vgallery_new') }}">Create your first gallery</a>.
            </div>
        {% else %}
        <div class="table-responsive table-container p-2">
            <div class="table-responsive">
                <table class="table table-striped" id="d_table">
                    <thead>
                    <tr>
                        <th>Title</th>
                        <th>Cover Image</th>
                        <th>Images Count</th>
                        <th>Created At</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for vgallery in vgalleries %}
                        <tr>
                            <td><strong>{{ vgallery.title }}</strong></td>
                            <td>
                                {% if vgallery.coverImage %}
                                    <img src="/uploads/image/{{ vgallery.coverImage }}"
                                         alt="Cover" class="img-thumbnail"
                                         style="width: 50px; height: 50px; object-fit: cover;">
                                {% else %}
                                    <span class="text-muted">
                                            <i class="bi bi-image"></i> No cover
                                        </span>
                                {% endif %}
                            </td>
                            <td>
                                    <span class="badge bg-secondary">
                                        {{ vgallery.images|length }} images
                                    </span>
                            </td>
                            <td>{{ vgallery.createdAt ? vgallery.createdAt|date('j M, Y') : 'N/A' }}</td>
                            <td>
                                <a href="{{ path('app_vgallery_show', {'id': vgallery.id}) }}"
                                   class="btn btn-sm btn-light-success">
                                    <i class="bi bi-eye"></i> Show
                                </a>
                                <a href="{{ path('app_vgallery_edit', {'id': vgallery.id}) }}"
                                   class="btn btn-sm btn-light-info">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>

                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        {% endif %}
    </div>
{% endblock %}
