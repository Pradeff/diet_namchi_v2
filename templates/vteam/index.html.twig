{% extends 'base_dashboard.html.twig' %}
{% block title %}Team{% endblock %}
{% block body %}
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text_color_default">
                    <i class="bi bi-person-bounding-box"></i>
                    Team Members
                </h5>
                <a href="{{ path('app_vteam_new') }}" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-lg"></i>
                    Add New
                </a>
            </div>
        </div>
    </div>
    <div class="table-responsive table-container p-2">
        <table id="d_table" class="table" style="width:100%">
            <thead>
            <tr>
                <th style="width: 40px;"><i class="bi bi-grip-vertical"></i></th>
                <th>Position</th>
                <th>Image</th>
                <th>Name</th>
                <th>Designation</th>
                <th>Action</th>
            </tr>
            </thead>
            <tbody id="sortable">
            {% for vteam in vteams %}
                <tr data-id="{{ vteam.id }}">
                    <td class="drag-handle"><i class="bi bi-grip-vertical"></i></td>
                    {#                    <td>{{ loop.index }}</td> #}
                    <td>{{ vteam.position }}</td>
                    <td>
                        {% if vteam.image %}
                            {% set imagePath = asset('uploads/image/' ~ vteam.image) %}
                            <img src="{{ imagePath }}" alt="Profile" class="rounded-circle object-fit-cover" width="40"
                                 height="40">
                        {% else %}
                            <div class="bg-secondary rounded-circle d-flex align-items-center justify-content-center"
                                 style="width: 40px; height: 40px;">
                                <i class="bi bi-person text-white"></i>
                            </div>
                        {% endif %}
                        {# {% if vteam.image %}
                            {% set imagePath = asset('uploads/image/' ~ vteam.image) %}
                            <a href="javascript:void(0);" onclick="showImage('{{ imagePath }}', '{{ vteam.title|e('js') }}')">
                                <img src="{{ imagePath }}" width="50" class="thumbnail" alt="">
                            </a>
                        {% else %}
                            <img src="{{ asset('images/no-image.png') }}" width="50" class="thumbnail" alt="">
                        {% endif %} #}
                    </td>
                    <td>{{ vteam.title|striptags|slice(0, 30) ~ ' ...' }}</td>
                    <td>{{ vteam.designation|striptags|slice(0, 30) ~ ' ...' }}</td>
                    <td>
                        <a href="{{ path('app_vteam_edit', {'id': vteam.id}) }}" class="btn btn-xs btn-light-info">
                            <i class="bi bi-pencil me-1"></i> Edit
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>

        </table>
    </div>
{% endblock %}





