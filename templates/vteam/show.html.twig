{% extends 'base_dashboard.html.twig' %}

{% block title %}Vteam{% endblock %}

{% block body %}
    <h1>Vteam</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ vteam.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ vteam.title }}</td>
            </tr>
            <tr>
                <th>Designation</th>
                <td>{{ vteam.designation }}</td>
            </tr>
            <tr>
                <th>Image</th>
                <td>{{ vteam.image }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_vteam_index') }}">back to list</a>

    <a href="{{ path('app_vteam_edit', {'id': vteam.id}) }}">edit</a>

    {{ include('vteam/_delete_form.html.twig') }}
{% endblock %}
