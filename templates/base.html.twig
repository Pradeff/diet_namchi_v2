{#template/base.html.twig#}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('css/fonts.css') }}">
        <link rel="stylesheet" href="{{ asset('css/bootstrap.min.css') }}">
        <link rel="stylesheet" href="{{ asset('css/slick.css') }}">
        <link rel="stylesheet" href="{{ asset('css/slick-theme.css') }}">
        <link rel="stylesheet" href="{{ asset('css/aos.css') }}">
        <link rel="stylesheet" href="{{ asset('css/fancybox.css') }}">
        <link rel="stylesheet" href="{{ asset('fonts/bootstrap-icons/bootstrap-icons.css') }}">
        <link rel="stylesheet" href="{{ asset('css/style-light.css') }}">
    {% endblock %}


</head>
<body>
<!-- Top Bar -->
<div class="top-bar">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 d-none d-md-block">
                <a href="tel:+9103595264521">
                    <i class="bi bi-telephone"></i> 03595-264521
                </a>
                <a href="mailto:dietnamchi12@gmail.com">
                    <i class="bi bi-envelope"></i> dietnamchi12@gmail.com
                </a>
                <span><i class="bi bi-clock"></i> Mon - Sat: 10:00 AM - 5:00 PM</span>
            </div>
            <div class="col-12 col-md-6 text-center text-md-end">
                    <span class="badge bg-warning text-dark">
                        <i class="bi bi-patch-check-fill"></i> NCTE Recognized Institution
                    </span>
            </div>
        </div>
    </div>
</div>

<!-- Header -->
<header class="main-header">
    <div class="container">
        <div class="header-wrapper">
            <!-- Logo -->
            <a href="{{ path('app_main') }}" class="logo-section">
                <img
                    src="{{ asset('images/logo.png') }}"
                    alt="DIET Logo" class="logo-img">
                <div class="logo-text">
                    <h1>D.I.E.T Namchi</h1>
                    <span>District Institute of Education & Training</span>
                </div>
            </a>

            <!-- Desktop Navigation -->
            <nav class="desktop-nav">
                <ul class="nav-menu">
                    <li class="nav-item">
                        <a href="{{ path('app_main') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_main' %}active{% endif %}">
                            Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link">
                            About <i class="bi bi-chevron-down dropdown-indicator"></i>
                        </a>
                        <div class="dropdown-menu-custom">
                            <a href="{{ path('app_about') }}"
                               class="nav-link {% if app.request.attributes.get('_route') == 'app_about' %}active{% endif %}">
                                About DIET
                            </a>
                            <a href="{{ path('app_vision_mission') }}">Vision & Mission</a>
                            <a href="{{ path('app_history') }}">History</a>
                            <a href="{{ path('app_team') }}">Our Team</a>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_admission') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_admission' %}active{% endif %}">
                            Admission
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_training') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_training' %}active{% endif %}">
                            Training
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_notices') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_notices' %}active{% endif %}">
                            Notices
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_gallery') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_gallery' %}active{% endif %}">
                            Gallery
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_rti') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_rti' %}active{% endif %}">
                            RTI
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_contact') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_contact' %}active{% endif %}">
                            Contact
                        </a>
                    </li>
                </ul>
                <a href="{{ path('app_admission') }}" class="btn-apply">Apply Now</a>
            </nav>

            <!-- Mobile Toggle Button -->
            <button class="mobile-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu"
                    aria-label="Toggle navigation">
                <i class="bi bi-list"></i>
            </button>
        </div>
    </div>
</header>

<!-- Mobile Offcanvas Menu -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="mobileMenu" aria-labelledby="mobileMenuLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="mobileMenuLabel">Menu</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <ul class="mobile-nav">
            <li>
                <a href="{{ path('app_main') }}">Home</a>
            </li>
            <li>
                <div class="dropdown-toggle-mobile" onclick="toggleMobileSubmenu(this)">
                    <span>About Us</span>
                    <i class="bi bi-chevron-down dropdown-icon"></i>
                </div>
                <ul class="mobile-submenu">
                    <li><a href="{{ path('app_about') }}">About DIET</a></li>
                    <li><a href="{{ path('app_vision_mission') }}">Vision & Mission</a></li>
                    <li><a href="{{ path('app_history') }}">History</a></li>
                    <li><a href="{{ path('app_team') }}">Our Team</a></li>
                </ul>
            </li>
            <li>
                <a href="{{ path('app_admission') }}">Admission</a>
            </li>
            <li>
                <a href="{{ path('app_training') }}">Training</a>
            </li>
            <li>
                <a href="{{ path('app_notices') }}">Notices</a>
            </li>
            <li>
                <a href="{{ path('app_gallery') }}">Gallery</a>
            </li>
            <li>
                <a href="{{ path('app_rti') }}">RTI</a>
            </li>
            <li>
                <a href="{{ path('app_contact') }}">Contact</a>
            </li>
        </ul>
        <div class="mobile-apply-btn">
            <a href="{{ path('app_admission') }}" class="btn-apply">Apply Now</a>
        </div>
    </div>
</div>
{% block body %}{% endblock %}


<footer class="main-footer">



    <!-- Main Footer Content -->
    <div class="footer-content">
        <div class="container">
            <div class="row g-4">

                <!-- Brand Column -->
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand">
                        <div class="footer-brand-logo">
                            <img src="{{ asset('images/logo.png') }}" alt="DIET Namchi">
                            <div>
                                <h3>D.I.E.T Namchi</h3>
                                <span>Est. 2010</span>
                            </div>
                        </div>
                        <p>District Institute of Education & Training, committed to excellence in teacher
                            education and professional development.</p>
                        <div class="footer-social">
                            <a href="#" aria-label="Facebook"><i class="bi bi-facebook"></i></a>
                            <a href="#" aria-label="Twitter"><i class="bi bi-twitter"></i></a>
                            <a href="#" aria-label="YouTube"><i class="bi bi-youtube"></i></a>
                            <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                        </div>
                    </div>
                </div>

                <!-- Quick Links -->
                <div class="col-6 col-lg-2 col-md-3">
                    <div class="footer-column">
                        <h5 class="footer-column-title">Quick Links</h5>
                        <ul class="footer-column-links">
                            <li><a href="{{ path('app_main') }}"><i class="bi bi-chevron-right"></i>About Us</a></li>
                            <li><a href="{{ path('app_main') }}"><i class="bi bi-chevron-right"></i>Admission</a></li>
                            <li><a href="{{ path('app_main') }}"><i class="bi bi-chevron-right"></i>Training</a></li>
                            <li><a href="{{ path('app_main') }}"><i class="bi bi-chevron-right"></i>Notices</a></li>
                            <li><a href="{{ path('app_main') }}"><i class="bi bi-chevron-right"></i>Contact</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Programs -->
                <div class="col-6 col-lg-2 col-md-3">
                    <div class="footer-column">
                        <h5 class="footer-column-title">Programs</h5>
                        <ul class="footer-column-links">
                            <li><a href="{{ path('app_main') }}"><i class="bi bi-chevron-right"></i>D.El.Ed</a></li>
                            <li><a href="{{ path('app_main') }}"><i class="bi bi-chevron-right"></i>B.Ed</a></li>
                            <li><a href="{{ path('app_main') }}"><i class="bi bi-chevron-right"></i>In-Service Training</a></li>
                            <li><a href="{{ path('app_main') }}"><i class="bi bi-chevron-right"></i>Downloads</a></li>
                            <li><a href="{{ path('app_main') }}"><i class="bi bi-chevron-right"></i>Gallery</a></li>
                        </ul>
                    </div>
                </div>

                <!-- Contact Info -->
                <div class="col-lg-4 col-md-6">
                    <div class="footer-column">
                        <h5 class="footer-column-title">Contact Info</h5>
                        <ul class="footer-contact-list">
                            <li class="footer-contact-item">
                                <i class="bi bi-geo-alt-fill"></i>
                                <span>Namchi, South Sikkim - 737126</span>
                            </li>
                            <li class="footer-contact-item">
                                <i class="bi bi-telephone"></i>
                                <a href="tel:03595264521">03595-264521</a>
                            </li>
                            <li class="footer-contact-item">
                                <i class="bi bi-envelope"></i>
                                <a href="mailto:dietnamchi12@gmail.com">dietnamchi12@gmail.com</a>
                            </li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
        <div class="container">
            <div class="footer-bottom-content">
                <p>&copy; 2026 DIET Namchi. All Rights Reserved.</p>
                <div class="footer-bottom-links">
                    <a href="{{ path('app_main') }}">Privacy Policy</a>
                    <a href="{{ path('app_main') }}">Terms of Use</a>
                    <a href="{{ path('app_main') }}">Sitemap</a>
                </div>
            </div>
        </div>
    </div>

</footer>

<!-- Back to Top Button -->
<div class="back-to-top" id="backToTop">
    <i class="bi bi-arrow-90deg-up"></i>
</div>

{% block javascripts %}
    <script src="{{ asset('js/jquery-3.6.0.min.js') }}" type="text/javascript"></script>
    <script src="{{ asset('js/bootstrap.bundle.min.js') }}" type="text/javascript"></script>
    <script src="{{ asset('js/slick.min.js') }}" type="text/javascript"></script>
    <script src="{{ asset('js/aos.js') }}" type="text/javascript"></script>
    <script src="{{ asset('js/fancybox.umd.js') }}" type="text/javascript"></script>
    <script src="{{ asset('js/main.js') }}" type="text/javascript"></script>
{% endblock %}
</body>
</html>
