{# template/base.html.twig #}
<!DOCTYPE html>
<html lang="en">
<head>
    {% set site_title = global_contact and global_contact.sitetitle ? global_contact.sitetitle : 'Lets Go Sikkim Travel Agency' %}
    {% set site_description = global_contact and global_contact.sitedescription ? global_contact.sitedescription|slice(0, 160) : 'Discover Sikkim with curated travel packages – adventure, family, honeymoon, cultural & more.' %}
    {% set site_url = global_contact and global_contact.sitelink ? global_contact.sitelink : 'https://letsgosikkim.com/' %}
    {% set site_image = global_contact and global_contact.logo1 ? asset('images/WebsiteAssets/' ~ global_contact.logo1) : asset('images/og-image.jpg') %}

    <meta charset="UTF-8">
    <title>
        {% block title %}{{ site_title }}{% endblock %}
    </title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <meta name="description" content="{% block meta_description %}{{ site_description }}{% endblock %}">

    <meta name="keywords" content="{% block meta_keywords %}{{ global_contact.sitekeyword }}{% endblock %}">

    <meta name="author"
          content="{% if global_contact and global_contact.sitetitle %}{{ global_contact.sitetitle }}{% else %}Lets Go Sikkim{% endif %}">

    <link rel="canonical" href="{% block canonical %}{{ app.request ? app.request.uri : site_url }}{% endblock %}">

    <meta property="og:type" content="website">
    <meta property="og:title" content="{% block og_title %}{{ site_title }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ site_description }}{% endblock %}">
    <meta property="og:url" content="{% block og_url %}{{ app.request ? app.request.uri : site_url }}{% endblock %}">
    <meta property="og:image" content="{% block og_image %}{{ site_image }}{% endblock %}">
    <meta property="og:site_name" content="{{ site_title }}">

    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{% block twitter_title %}{{ site_title }}{% endblock %}">
    <meta name="twitter:description" content="{% block twitter_description %}{{ site_description }}{% endblock %}">
    <meta name="twitter:image" content="{% block twitter_image %}{{ site_image }}{% endblock %}">
    <meta name="twitter:site"
          content="{% if global_contact and global_contact.tw %}{{ global_contact.tw|replace({'https://twitter.com/': '@', 'https://x.com/': '@'}) }}{% else %}@LetsGoSikkim{% endif %}">

    {% if global_contact and global_contact.favicon %}
        <link rel="icon" href="{{ asset('images/WebsiteAssets/' ~ global_contact.favicon) }}">
        <link rel="apple-touch-icon" sizes="180x180"
              href="{{ asset('images/WebsiteAssets/' ~ global_contact.favicon) }}">
    {% else %}
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('images/logo.png') }}">
    {% endif %}

    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "EducationInstitution",
            "name": "{% if global_contact and global_contact.sitetitle %}{{ global_contact.sitetitle|e('js') }}{% else %}Lets Go Sikkim{% endif %}
        ",
        {% if global_contact and global_contact.sitedescription %}"description": "{{ global_contact.sitedescription|e('js') }}",{% endif %}
        {% if global_contact and global_contact.sitelink %}"url": "{{ global_contact.sitelink|e('js') }}",{% endif %}
        {% if global_contact and global_contact.phone1 %}"telephone": "+91{{ global_contact.phone1|e('js') }}",{% endif %}
        {% if global_contact and global_contact.email1 %}"email": "{{ global_contact.email1|e('js') }}",{% endif %}
        {% if global_contact and global_contact.address %}"address": {
            "@type": "PostalAddress",
            "streetAddress": "{{ global_contact.address|e('js') }}"
        },{% endif %}
        "sameAs": [
        {% set social_links = [] %}
            {% if global_contact %}
        {% if global_contact.fb %}{% set social_links = social_links|merge(['"' ~ global_contact.fb|e('js') ~ '"']) %}{% endif %}
        {% if global_contact.insta %}{% set social_links = social_links|merge(['"' ~ global_contact.insta|e('js') ~ '"']) %}{% endif %}
        {% if global_contact.tw %}{% set social_links = social_links|merge(['"' ~ global_contact.tw|e('js') ~ '"']) %}{% endif %}
        {% if global_contact.yt %}{% set social_links = social_links|merge(['"' ~ global_contact.yt|e('js') ~ '"']) %}{% endif %}
        {% if global_contact.linkedin %}{% set social_links = social_links|merge(['"' ~ global_contact.linkedin|e('js') ~ '"']) %}{% endif %}
        {% endif %}
            {{ social_links|join(', ')|raw }}
        ]
    }
    </script>

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('css/fonts.css') }}">
        <link rel="stylesheet" href="{{ asset('css/bootstrap.min.css') }}">
        <link rel="stylesheet" href="{{ asset('css/slick.css') }}">
        <link rel="stylesheet" href="{{ asset('css/slick-theme.css') }}">
        <link rel="stylesheet" href="{{ asset('css/aos.css') }}">
        <link rel="stylesheet" href="{{ asset('css/fancybox.css') }}">
        <link rel="stylesheet" href="{{ asset('fonts/bootstrap-icons/bootstrap-icons.css') }}">
        <link rel="stylesheet" href="{{ asset('css/style-light.css') }}">
    {% endblock %}


</head>
<body>
<!-- Top Bar -->
<div class="top-bar">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6 d-none d-md-block">

                {% if global_contact.phone1 %}
                    <a href="tel:{{ global_contact.phone1 }}">
                        <i class="bi bi-telephone"></i> {{ global_contact.phone1 }}
                    </a>
                {% endif %}

                {% if global_contact.email1 %}
                    <a href="mailto:{{ global_contact.email1 }}">
                        <i class="bi bi-envelope"></i> {{ global_contact.email1 }}
                    </a>
                {% endif %}

                {% if global_contact.opentime %}
                    <span>
            <i class="bi bi-clock"></i> {{ global_contact.opentime }}
        </span>
                {% endif %}

            </div>
            <div class="col-12 col-md-6 text-center text-md-end">
                    <span class="badge bg-warning text-dark">
                        <i class="bi bi-patch-check-fill"></i> NCTE Recognized Institution
                    </span>
            </div>
        </div>
    </div>
</div>

<!-- Header -->
<header class="main-header">
    <div class="container">
        <div class="header-wrapper">
            <!-- Logo -->
            <a href="{{ path('app_main') }}" class="logo-section">
                <img
                    src="{{ asset('images/logo.png') }}"
                    alt="DIET Logo" class="logo-img">
                <div class="logo-text">
                    <h1>D.I.E.T Namchi</h1>
                    <span>District Institute of Education & Training</span>
                </div>
            </a>

            <!-- Desktop Navigation -->
            <nav class="desktop-nav">
                <ul class="nav-menu">
                    <li class="nav-item">
                        <a href="{{ path('app_main') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_main' %}active{% endif %}">
                            Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#" class="nav-link {% if app.request.attributes.get('_route') in ['app_about','app_vision_mission','app_team'] %}active{% endif %}">
                            About <i class="bi bi-chevron-down dropdown-indicator"></i>
                        </a>
                        <div class="dropdown-menu-custom">
                            <a href="{{ path('app_about') }}"
                               class="nav-link">
                                About DIET
                            </a>
                            <a href="{{ path('app_vision_mission') }}">Vision & Mission</a>
                            <a href="{{ path('app_history') }}">History</a>
                            <a href="{{ path('app_team') }}">Our Team</a>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_admission') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_admission' %}active{% endif %}">
                            Admission
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_training') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_training' %}active{% endif %}">
                            Training
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_notices') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_notices' %}active{% endif %}">
                            Notices & Downloads
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_gallery') }}"
                           class="nav-link {% if app.request.attributes.get('_route') in ['app_gallery','app_gallery_detail'] %}active{% endif %}">
                            Gallery
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ path('app_pg_faq') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_pg_faq' %}active{% endif %}">
                            FAQ's
                        </a>
                    </li>
                    {# <li class="nav-item">
                        <a href="{{ path('app_contact') }}"
                           class="nav-link {% if app.request.attributes.get('_route') == 'app_contact' %}active{% endif %}">
                            Contact
                        </a>
                    </li> #}
                </ul>
                <a href="{{ path('app_contact') }}" class="btn-apply">Contact Now</a>
            </nav>

            <!-- Mobile Toggle Button -->
            <button class="mobile-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu"
                    aria-label="Toggle navigation">
                <i class="bi bi-list"></i>
            </button>
        </div>
    </div>
</header>

<!-- Mobile Offcanvas Menu -->
<div class="offcanvas offcanvas-start" tabindex="-1" id="mobileMenu" aria-labelledby="mobileMenuLabel">
    <div class="offcanvas-header">
        <h5 class="offcanvas-title" id="mobileMenuLabel">Menu</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body">
        <ul class="mobile-nav">
            <li>
                <a href="{{ path('app_main') }}">Home</a>
            </li>
            <li>
                <div class="dropdown-toggle-mobile" onclick="toggleMobileSubmenu(this)">
                    <span>About Us</span>
                    <i class="bi bi-chevron-down dropdown-icon"></i>
                </div>
                <ul class="mobile-submenu">
                    <li><a href="{{ path('app_about') }}">About DIET</a></li>
                    <li><a href="{{ path('app_vision_mission') }}">Vision & Mission</a></li>
                    <li><a href="{{ path('app_history') }}">History</a></li>
                    <li><a href="{{ path('app_team') }}">Our Team</a></li>
                </ul>
            </li>
            <li>
                <a href="{{ path('app_admission') }}">Admission</a>
            </li>
            <li>
                <a href="{{ path('app_training') }}">Training</a>
            </li>
            <li>
                <a href="{{ path('app_notices') }}">Notices & Downloads</a>
            </li>
            <li>
                <a href="{{ path('app_gallery') }}">Gallery</a>
            </li>
            <li>
                <a href="{{ path('app_rti') }}">RTI</a>
            </li>
        </ul>
        <div class="mobile-apply-btn">
            <a href="{{ path('app_contact') }}" class="btn-apply">Contact us</a>
        </div>
    </div>
</div>
{% block body %}{% endblock %}

<footer class="main-footer">

    <div class="footer-accent-bar"></div>

    <div class="footer-geo"></div>

    <!-- ── Main Body ── -->
    <div class="footer-body">
        <div class="container">
            <div class="footer-grid">

                <!-- Brand Column -->
                <div class="footer-brand">
                    <div class="brand-lockup">
                        <div class="brand-emblem">
                            <img src="{{ asset('images/logo.png') }}" alt="DIET Namchi">
                        </div>
                        <div class="brand-title">
                            <h3>D.I.E.T Namchi</h3>
                            <span>Est. 2010 &middot; South Sikkim</span>
                        </div>
                    </div>
                    <p class="brand-desc">
                        District Institute of Education &amp; Training — nurturing educators,
                        transforming classrooms, and advancing professional excellence across South Sikkim.
                    </p>
                    <div class="brand-badges">
                        <span class="badge-chip"><i class="bi bi-award-fill"></i> NCTE Recognised</span>
                        <span class="badge-chip"><i class="bi bi-building-fill"></i> Govt. of Sikkim</span>
                        <span class="badge-chip"><i class="bi bi-mortarboard-fill"></i> SCERT Affiliated</span>
                    </div>
                    <div class="footer-social">

                        {% if global_contact.fb %}
                            <a href="{{ global_contact.fb }}" target="_blank" aria-label="Facebook">
                                <i class="bi bi-facebook"></i>
                            </a>
                        {% endif %}

                        {% if global_contact.tw %}
                            <a href="{{ global_contact.tw }}" target="_blank" aria-label="Twitter X">
                                <i class="bi bi-twitter-x"></i>
                            </a>
                        {% endif %}

                        {% if global_contact.yt %}
                            <a href="{{ global_contact.yt }}" target="_blank" aria-label="YouTube">
                                <i class="bi bi-youtube"></i>
                            </a>
                        {% endif %}

                        {% if global_contact.insta %}
                            <a href="{{ global_contact.insta }}" target="_blank" aria-label="Instagram">
                                <i class="bi bi-instagram"></i>
                            </a>
                        {% endif %}

                        {% if global_contact.telegram %}
                            <a href="{{ global_contact.telegram }}" target="_blank" aria-label="Telegram">
                                <i class="bi bi-telegram"></i>
                            </a>
                        {% endif %}

                        {% if global_contact.linkedin %}
                            <a href="{{ global_contact.linkedin }}" target="_blank" aria-label="LinkedIn">
                                <i class="bi bi-linkedin"></i>
                            </a>
                        {% endif %}

                    </div>
                </div>

                <!-- Quick Links -->
                <div>
                    <h5 class="footer-col-title">Important Links</h5>
                    <ul class="footer-links">
                        <li><a href="https://sikkim.gov.in/" target="_blank" rel="noopener"><span
                                    class="link-dot"></span>Government of Sikkim</a></li>
                        <li><a href="https://education.sikkim.gov.in/" target="_blank" rel="noopener"><span
                                    class="link-dot"></span>Education Department Sikkim</a></li>
                        <li><a href="https://www.scertsikkim.ac.in/" target="_blank" rel="noopener"><span
                                    class="link-dot"></span>SCERT Sikkim</a></li>
                        <li><a href="https://www.samagrashikshasikkim.org/" target="_blank" rel="noopener"><span
                                    class="link-dot"></span>Samagra Shiksha Sikkim</a></li>
                        <li><a href="https://diksha.gov.in/" target="_blank" rel="noopener"><span
                                    class="link-dot"></span>DIKSHA Portal</a></li>
                        <li><a href="https://sikkim.nic.in/" target="_blank" rel="noopener"><span
                                    class="link-dot"></span>NIC Sikkim</a></li>

                    </ul>
                </div>

                <!-- site menu -->
                {% if quick_link_pages is defined and quick_link_pages is not empty %}

                    <div>
                        <h5 class="footer-col-title">Menu</h5>
                        <ul class="footer-links">
                            {% for page in quick_link_pages %}
                                <li>
                                    <a href="{{ path('page_detail', {'slug': page.slug}) }}">
                                        <span class="link-dot"></span>{{ page.title }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>
                {% else %}

                {% endif %}

                <div>
                    <h5 class="footer-col-title">Contact &amp; Location</h5>
                    <ul class="contact-list">

                        {% if global_contact.address %}
                            <li class="contact-item">
                                <div class="contact-icon">
                                    <i class="bi bi-geo-alt-fill"></i>
                                </div>
                                <div class="contact-info">
                                    <span class="contact-label">Address</span>
                                    <span>{{ global_contact.address|raw }}</span>
                                </div>
                            </li>
                        {% endif %}

                        {% if global_contact.phone1 %}
                            <li class="contact-item">
                                <div class="contact-icon">
                                    <i class="bi bi-telephone-fill"></i>
                                </div>
                                <div class="contact-info">
                                    <span class="contact-label">Phone</span>
                                    <a href="tel:{{ global_contact.phone1 }}">
                                        {{ global_contact.phone1 }}
                                    </a>
                                </div>
                            </li>
                        {% endif %}

                        {% if global_contact.email1 %}
                            <li class="contact-item">
                                <div class="contact-icon">
                                    <i class="bi bi-envelope-fill"></i>
                                </div>
                                <div class="contact-info">
                                    <span class="contact-label">Email</span>
                                    <a href="mailto:{{ global_contact.email1 }}">
                                        {{ global_contact.email1 }}
                                    </a>
                                </div>
                            </li>
                        {% endif %}

                        {# {% if global_contact.opentime %}
                            <li class="contact-item">
                                <div class="contact-icon">
                                    <i class="bi bi-clock-fill"></i>
                                </div>
                                <div class="contact-info">
                                    <span class="contact-label">Office Hours</span>
                                    <span>{{ global_contact.opentime }}</span>
                                </div>
                            </li>
                        {% endif %} #}

                    </ul>
                    {# <div class="map-card">
                        <div class="map-card-inner">
                            <i class="bi bi-geo-alt-fill"></i>
                            Namchi, South Sikkim, India
                        </div>
                    </div> #}
                </div>

            </div>
        </div>
    </div>

    <!-- Divider -->
    <div class="footer-divider">
        <div class="footer-divider-icon"><i class="bi bi-asterisk"></i></div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
        <div class="container">
            <div class="footer-bottom-inner">
                <div class="footer-bottom-left">
                    <p class="footer-copyright">
                        <strong>&copy; {{ "now"|date("Y") }} DIET Namchi. All Rights Reserved.</strong>
                    </p>
                    {# <div class="footer-bottom-sep"></div>
                    <nav class="footer-bottom-nav">
                        <a href="{{ path('app_main') }}">Privacy Policy</a>
                        <a href="{{ path('app_main') }}">Terms of Use</a>
                        <a href="{{ path('app_main') }}">Sitemap</a>
                        <a href="{{ path('app_main') }}">RTI</a>
                    </nav> #}
                </div>
                <div class="footer-bottom-right">
          <span class="govt-badge">
            <i class="bi bi-shield-fill-check"></i> Govt. of Sikkim
          </span>
                    <span class="footer-made-with">
            Made with <i class="bi bi-heart-fill"></i> for education
          </span>
                </div>
            </div>
        </div>
    </div>

</footer>

<!-- Back to Top Button -->
<div class="back-to-top" id="backToTop">
    <i class="bi bi-arrow-90deg-up"></i>
</div>

{% block javascripts %}
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>

    <script src="{{ asset('js/jquery-3.6.0.min.js') }}" type="text/javascript"></script>
    <script src="{{ asset('js/bootstrap.bundle.min.js') }}" type="text/javascript"></script>
    <script src="{{ asset('js/slick.min.js') }}" type="text/javascript"></script>
    <script src="{{ asset('js/aos.js') }}" type="text/javascript"></script>
    <script src="{{ asset('js/fancybox.umd.js') }}" type="text/javascript"></script>
    <script src="{{ asset('js/main.js') }}" type="text/javascript"></script>
{% endblock %}
</body>
</html>
