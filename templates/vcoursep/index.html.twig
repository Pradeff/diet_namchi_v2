{% extends 'base_dashboard.html.twig' %}

{% block title %}Vcourses List{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text_color_default">
                    <i class="bi bi-book"></i>
                    Course
                </h5>
                <a href="{{ path('app_vcourse_new') }}" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-lg"></i>
                    Add New
                </a>
            </div>
        </div>
    </div>

    <div class="container mt-4">
        {% if vcourses is empty %}
            <p>No vcourses found.</p>
        {% else %}
            <div class="table-responsive table-container p-2">
                <table id="d_table" class="table" style="width:100%">
                    <thead>
                    <tr>
                        <th>Title</th>
                        <th>Cover Image</th>
                        <th>Images Count</th>
                        <th>Created At</th>
                        <th>Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for vcourse in vcourses %}
                        <tr>
                            <td>{{ vcourse.title }}</td>
                            <td>
                                {% if vcourse.coverImage %}
                                    <img src="{{ asset('uploads/image/' ~ vcourse.coverImage) }}" alt="Cover Image"
                                         class="img-thumbnail" width="50" />
                                {% else %}
                                    <span class="text-muted">No cover</span>
                                {% endif %}
                            </td>
                            <td>{{ vcourse.images|length }}</td>
                            <td>{{ vcourse.createdAt ? vcourse.createdAt|date('j M, Y ') : 'N/A' }}</td>
                            <td>
                                <a href="{{ path('app_vcourse_edit', {'id': vcourse.id}) }}" class="btn btn-xs btn-light-info">
                                    <i class="bi bi-pencil me-1"></i> Edit
                                </a>
                                <a href="{{ path('app_vcourse_show', {'id': vcourse.id}) }}" class="btn btn-xs btn-light-success">
                                    <i class="bi bi-eye me-1"></i> Show
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
{% endblock %}
