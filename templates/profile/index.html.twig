{# templates/profile/index.html.twig #}
{% extends 'base_dashboard.html.twig' %}

{% block title %}My Profile{% endblock %}

{% block body %}
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong class="card-title mb-0"><i class="bi bi-person-circle"></i> My Profile</strong>
                        <div>
                            <a href="{{ path('app_profile_edit') }}" class="btn btn-xs btn-primary">
                                <i class="bi bi-pencil"></i> Edit Profile
                            </a>
                            <a href="{{ path('app_profile_change_password') }}" class="btn btn-light-success">
                                <i class="bi bi-lock"></i> Change Password
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 text-center">
                                <div class="profile-photo-container mb-3">
                                    {% if user.profilePhoto %}
                                        <img src="{{ asset('uploads/image/' ~ user.profilePhoto) }}"
                                             alt="{{ user.name }}"
                                             class="img-fluid rounded-circle profile-photo"
                                             style="width: 200px; height: 200px; object-fit: cover;">
                                    {% else %}
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto"
                                             style="width: 200px; height: 200px; font-size: 48px;">
                                            {{ user.name|first|upper }}
                                        </div>
                                    {% endif %}
                                </div>
                                <h4 class="mb-1">{{ user.name }}</h4>
                                <p class="text-muted">{{ user.email }}</p>

                                {% if user.isActive %}
                                    <span class="badge bg-success">Active</span>
                                {% else %}
                                    <span class="badge bg-danger">Inactive</span>
                                {% endif %}
                            </div>
                            <div class="col-md-8">
                                <div class="table-responsive">
                                    <table class="table table-borderless">
                                        <tbody>
                                        <tr>
                                            <td><strong>Full Name:</strong></td>
                                            <td>{{ user.name }}</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Email:</strong></td>
                                            <td>{{ user.email }}</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Phone:</strong></td>
                                            <td>{{ user.phone ?? 'N/A' }}</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Address:</strong></td>
                                            <td>{{ user.address ?? 'N/A' }}</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Account Created:</strong></td>
                                            <td>{{ user.createdAt|date('Y-m-d H:i:s') }}</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Last Updated:</strong></td>
                                            <td>{{ user.updatedAt|date('Y-m-d H:i:s') }}</td>
                                        </tr>
                                        <tr>
                                            <td><strong>Last Login:</strong></td>
                                            <td>
                                                {% if user.lastLoginAt %}
                                                    {{ user.lastLoginAt|date('Y-m-d H:i:s') }}
                                                    {% if user.lastLoginIp %}
                                                        <br><small class="text-muted">IP: {{ user.lastLoginIp }}</small>
                                                    {% endif %}
                                                {% else %}
                                                    Never
                                                {% endif %}
                                            </td>
                                        </tr>
                                        <tr>
                                            <td><strong>Roles:</strong></td>
                                            <td>
                                                {% set roleColors = ['notii_badge_success', 'notii_badge_warning', 'notii_badge_info', 'notii_badge_danger'] %}
                                                {% set roleIcons = {
                                                    'ROLE_ADMIN': 'bi-shield-lock',
                                                    'ROLE_USER': 'bi-person',
                                                    'ROLE_MANAGER': 'bi-briefcase',
                                                    'ROLE_EDITOR': 'bi-pencil-square',
                                                    'ROLE_VIEWER': 'bi-eye',
                                                    'ROLE_SUPPORT': 'bi-headset',
                                                    'ROLE_DEVELOPER': 'bi-code-slash',
                                                    'ROLE_FINANCE': 'bi-cash-stack',
                                                    'ROLE_HR': 'bi-people'
                                                } %}

                                                {% for role in user.roles %}
                                                    {% set colorClass = roleColors[loop.index0 % roleColors|length] %}
                                                    {% set roleText = role|replace({'ROLE_': '', '_': ' '})|title %}
                                                    {% set iconClass = roleIcons[role] ?? 'bi-person-badge' %} {# fallback icon #}

                                                    <span class="badge {{ colorClass }} me-1 mb-2">
            <i class="bi {{ iconClass }} me-1"></i> {{ roleText }}
        </span>
                                                {% endfor %}
                                            </td>
                                        </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
