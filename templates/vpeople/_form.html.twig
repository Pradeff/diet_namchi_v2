{{ form_start(form, { 'attr': {'id': 'form', 'enctype':'multipart/form-data'} }) }}

<div class="p-3 rounded-3 trans_bg1">
    <div class="row">
        <div class="col-xl-8 mb-4">
            <div class="card">
                <div class="card-body">
                    <div class="form-group">
                        <h6><label>Name</label></h6>
                        {{ form_widget(form.title,{'attr': {'class': 'form-control','placeholder': 'Full Name'}}) }}
                    </div>

                    <div class="form-group my-3">
                        <h6><label>Designation</label></h6>
                        {{ form_widget(form.designation,{'attr': {'class': 'form-control'}}) }}
                    </div>

                    <div class="row">
                        {#<div class="col">
                            <div class="form-group my-3">
                                <h6><label>Phone</label></h6>
                                {{ form_widget(form.phone, {
                                    'attr': {
                                        'class': 'form-control',
                                        'placeholder': '10 digit Phone no.',
                                        'pattern': '[0-9]*',
                                        'minlength': '10',
                                        'maxlength': '10',
                                        'inputmode': 'numeric'
                                    }
                                }) }}
                            </div>
                        </div>#}
                        <div class="col">
                            <div class="form-group my-3">
                                <h6><label>Email Address</label></h6>
                                {{ form_widget(form.extra1,{'attr': {'class': 'form-control'}}) }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4">
            <div class="card">
                <div class="card-header"><strong>Profile Photo</strong></div>
                <div class="card-body">
                    <div class="form-group">
                        {{ form_widget(form.image, {
                            'id': 'imageInput',
                            'attr': {
                                'class': 'dropify',
                                'accept': 'image/*',
                                'data-max-file-size': '2M',
                                'data-allowed-file-extensions': 'jpg jpeg png gif'
                            }
                        }) }}
                    </div>

                    {# Show current + cropped preview side by side when editing #}
                    {% if image_url is defined and image_url %}
                        <div class="mt-2 row align-items-center">
                            <div class="col-md-6 text-center">
                                <h6>Current Image:</h6>
                                <img src="{{ asset('uploads/image/' ~ image_url) }}" class="img-thumbnail border" width="150">
                            </div>
                            <div class="col-md-6 text-center d-none" id="previewContainer">
                                <h6 class="text-success fw-bold">Cropped Preview:</h6>
                                <img id="croppedPreview" class="img-thumbnail border border-success shadow" width="300" height="360"/>
                            </div>
                        </div>
                    {% else %}
                        <div id="previewContainer" class="mt-3 d-none text-center">
                            <h6 class="text-success fw-bold">Cropped Preview:</h6>
                            <img id="croppedPreview" class="img-thumbnail border border-success shadow" width="300" height="360"/>
                        </div>
                    {% endif %}

                    <input type="hidden" id="croppedImageData" name="croppedImageData">
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-xl-12">
            <button class="btn btn-light-info" id="submitBtn" type="submit">
                <span id="submitText">{{ button_label|default('Save') }}</span>
                <span id="submitSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status">
                    <span class="visually-hidden">Loading...</span>
                </span>
            </button>
            <a href="{{ path('app_vpeople_index') }}" class="btn btn-secondary ms-2">
                <i class="bi bi-arrow-left me-1"></i>Cancel
            </a>
            <div class="progress mt-2 d-none" id="uploadProgress">
                <div class="progress-bar" role="progressbar" style="width: 0%">0%</div>
            </div>
        </div>
    </div>
</div>

{{ form_end(form) }}



<script>
    window.addEventListener("load", function () {
        let drInput = $('#imageInput').dropify();
        let croppedField = document.getElementById("croppedImageData");
        let previewContainer = document.getElementById("previewContainer");
        let croppedPreview = document.getElementById("croppedPreview");
        let cropper;

        // When image selected in Dropify
        drInput.on('change', function (e) {
            let file = e.target.files[0];
            if (file) {
                let reader = new FileReader();
                reader.onload = function (evt) {
                    Swal.fire({
                        title: "",
                        html: '<div style="width:100%;max-height:80vh;display:flex;align-items:center;justify-content:center;"><img id="cropImage" src="'+evt.target.result+'" style="max-height:80vh;max-width:100%;"/></div>',
                        showCancelButton: false,
                        confirmButtonText: "Crop & Set",
                        allowOutsideClick: false,
                        allowEscapeKey: false,
                        didOpen: () => {
                            let cropImage = document.getElementById("cropImage");
                            cropper = new Cropper(cropImage, {
                                aspectRatio: 300 / 360,
                                viewMode: 1,
                                autoCropArea: 1,
                                dragMode: 'move'
                            });
                        },
                        preConfirm: () => {
                            let canvas = cropper.getCroppedCanvas({ width: 300, height: 360 });
                            let dataUrl = canvas.toDataURL("image/png");
                            croppedField.value = dataUrl;
                            croppedPreview.src = dataUrl;
                            previewContainer.classList.remove("d-none");

                            // Remove Dropify preview
                            let drEvent = $('#imageInput').dropify();
                            let dropify = drEvent.data('dropify');
                            if (dropify) {
                                dropify.resetPreview();
                                dropify.clearElement();
                            }
                        }
                    });
                };
                reader.readAsDataURL(file);
            }
        });

        // Prevent submitting without crop only if file selected
        document.getElementById("form").addEventListener("submit", function (e) {
            let fileInput = document.getElementById("imageInput");

            if (fileInput.files.length > 0 && !croppedField.value) {
                e.preventDefault();
                Swal.fire("Error", "Please crop the image before saving.", "error");
                return;
            }

            if (croppedField.value) {
                // Show progress bar
                e.preventDefault();
                let form = this;
                let progress = document.getElementById("uploadProgress");
                let bar = progress.querySelector(".progress-bar");
                progress.classList.remove("d-none");

                let xhr = new XMLHttpRequest();
                xhr.open(form.method, form.action);
                xhr.upload.addEventListener("progress", function (evt) {
                    if (evt.lengthComputable) {
                        let percent = Math.round((evt.loaded / evt.total) * 100);
                        bar.style.width = percent + "%";
                        bar.innerText = percent + "%";
                    }
                });
                xhr.onload = function () {
                    if (xhr.status === 200) {
                        window.location.href = "{{ path('app_vpeople_index') }}";
                    }
                };
                xhr.send(new FormData(form));
            }
        });
    });
</script>
