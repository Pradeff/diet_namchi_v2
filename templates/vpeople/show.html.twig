{% extends 'base_dashboard.html.twig' %}
{% block title %}Person Details{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text_color_default">Person Details</h5>
                <nav class="breadcrumb-nav">
                    <a href="{{ path('app_dashboard') }}">Home</a>
                    <i class="bi bi-chevron-right mx-2"></i>
                    <a href="{{ path('app_vpeople_index') }}">People</a>
                    <i class="bi bi-chevron-right mx-2"></i>
                    <span>{{ vpeople.title }}</span>
                </nav>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-person-fill me-2"></i>Person Information</h6>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-3"><strong>Name:</strong></div>
                        <div class="col-sm-9">{{ vpeople.title }}</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-3"><strong>Designation:</strong></div>
                        <div class="col-sm-9">{{ vpeople.designation ?? 'Not specified' }}</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-3"><strong>Phone:</strong></div>
                        <div class="col-sm-9">
                            {% if vpeople.phone %}
                                <a href="tel:{{ vpeople.phone }}" class="text-decoration-none">
                                    <i class="bi bi-telephone me-1"></i>{{ vpeople.phone }}
                                </a>
                            {% else %}
                                Not provided
                            {% endif %}
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-3"><strong>Email:</strong></div>
                        <div class="col-sm-9">
                            {% if vpeople.email %}
                                <a href="mailto:{{ vpeople.email }}" class="text-decoration-none">
                                    <i class="bi bi-envelope me-1"></i>{{ vpeople.email }}
                                </a>
                            {% else %}
                                Not provided
                            {% endif %}
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-3"><strong>Position:</strong></div>
                        <div class="col-sm-9">{{ vpeople.position }}</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0"><i class="bi bi-image me-2"></i>Profile Photo</h6>
                </div>
                <div class="card-body text-center">
                    {% if vpeople.image %}
                        {% set imagePath = asset('uploads/image/' ~ vpeople.image) %}
                        <img src="{{ imagePath }}" alt="{{ vpeople.title }}" class="img-fluid rounded shadow" style="max-height: 300px;">
                    {% else %}
                        <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 200px;">
                            <i class="bi bi-person fs-1 text-muted"></i>
                        </div>
                        <p class="text-muted mt-2">No photo available</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <a href="{{ path('app_vpeople_edit', {'id': vpeople.id}) }}" class="btn btn-light-primary">
                <i class="bi bi-pencil-square me-1"></i>Edit
            </a>
            <a href="{{ path('app_vpeople_index') }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to List
            </a>
            {{ include('vpeople/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
