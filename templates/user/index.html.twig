{# templates/user/index.html.twig #}
{% extends 'base_dashboard.html.twig' %}

{% block title %}Users Management{% endblock %}

{% block body %}

    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text_color_default">
                    <i class="bi bi-people"></i>
                    Users Management
                </h5>
                <a href="{{ path('app_user_new') }}" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-lg"></i>
                    Add New
                </a>
            </div>
        </div>
    </div>


    {% if users|length > 0 %}
        <div class="table-responsive table-container p-2">
            <table class="table table-striped table-hover" id="d_table">
                <thead class="table-dark">
                <tr>
                    <th>Photo</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Status</th>
                    {#<th>Created</th>
                    <th>Last Login</th>#}
                    <th>Roles</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td>
                            {% if user.profilePhoto %}
                                <img src="{{ asset('uploads/image/' ~ user.profilePhoto) }}"
                                     alt="{{ user.name }}"
                                     class="rounded-circle"
                                     width="40" height="40">
                            {% else %}
                                <div
                                    class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center"
                                    style="width: 40px; height: 40px; font-weight: bold;">
                                    {{ user.name|first|upper }}
                                </div>
                            {% endif %}
                        </td>
                        <td>{{ user.name }}</td>
                        <td>{{ user.email }}</td>
                        <td>{{ user.phone ?? 'N/A' }}</td>
                        <td>
                            {% if user.isActive %}
                                <span class="badge bg-success">
                                                        <i class="bi bi-check-circle"></i> Active
                                                    </span>
                            {% else %}
                                <span class="badge bg-secondary">
                                                        <i class="bi bi-x-circle"></i> Inactive
                                                    </span>
                            {% endif %}
                        </td>
                        {#<td>{{ user.createdAt|date('Y-m-d H:i') }}</td>
                        <td>
                            {% if user.lastLoginAt %}
                                {{ user.lastLoginAt|date('Y-m-d H:i') }}
                                {% if user.lastLoginIp %}
                                    <br><small class="text-muted">{{ user.lastLoginIp }}</small>
                                {% endif %}
                            {% else %}
                                <span class="text-muted">Never</span>
                            {% endif %}
                        </td>#}
                        <td>
                            {% set roleColors = ['notii_badge_success', 'notii_badge_warning', 'notii_badge_info', 'notii_badge_danger'] %}
                            {% set roleIcons = {
                                'ROLE_ADMIN': 'bi-shield-lock',
                                'ROLE_USER': 'bi-person',
                                'ROLE_MANAGER': 'bi-briefcase',
                                'ROLE_EDITOR': 'bi-pencil-square',
                                'ROLE_VIEWER': 'bi-eye',
                                'ROLE_SUPPORT': 'bi-headset',
                                'ROLE_DEVELOPER': 'bi-code-slash',
                                'ROLE_FINANCE': 'bi-cash-stack',
                                'ROLE_HR': 'bi-people'
                            } %}

                            {% for role in user.roles %}
                                {% set colorClass = roleColors[loop.index0 % roleColors|length] %}
                                {% set roleText = role|replace({'ROLE_': '', '_': ' '})|title %}
                                {% set iconClass = roleIcons[role] ?? 'bi-person-badge' %} {# fallback icon #}

                                <span class="badge {{ colorClass }} me-1 mb-2">
            <i class="bi {{ iconClass }} me-1"></i> {{ roleText }}
        </span>
                            {% endfor %}
                        </td>

                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_user_show', {'id': user.id}) }}"
                                   class="btn btn-sm btn-warning">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('app_user_edit', {'id': user.id}) }}"
                                   class="btn btn-sm btn-info">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>

    {% else %}
        <div class="text-center py-4">
            <i class="bi bi-people display-1 text-muted"></i>
            <h4 class="mt-3">No users found</h4>
            <p class="text-muted">Start by adding your first user.</p>
            <a href="{{ path('app_user_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add First User
            </a>
        </div>
    {% endif %}

{% endblock %}
