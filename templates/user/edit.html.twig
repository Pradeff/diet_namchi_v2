{# templates/user/edit.html.twig #}
{% extends 'base_dashboard.html.twig' %}

{% block title %}Edit User{% endblock %}

{% block body %}
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong class="card-title mb-0"><i class="bi bi-person"></i> Edit User: {{ user.name }}</strong>
                        <div>
                            <a href="{{ path('app_user_show', {'id': user.id}) }}" class="btn btn-light-primary btn-sm">
                                <i class="bi bi-eye"></i> View Details
                            </a>
                            {% include 'user/_delete_form.html.twig' %}
                        </div>
                    </div>
                    <div class="card-body p-0 py-3">
                        {% include 'user/_form.html.twig' %}
                    </div>

                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('dashboard/js/user-form.js') }}"></script>
{% endblock %}
