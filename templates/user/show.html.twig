{# templates/user/show.html.twig #}
{% extends 'base_dashboard.html.twig' %}

{% block title %}User Details{% endblock %}

{% block body %}
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <strong class="card-title mb-0">User Details: {{ user.name }}</strong>
                        <div>
                            <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-light-info btn-sm">
                                <i class="bi bi-pencil"></i> Edit User
                            </a>
                            {% include 'user/_delete_form.html.twig' %}
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-4 text-center">
                                {% if user.profilePhoto %}
                                    <img src="{{ asset('uploads/image/' ~ user.profilePhoto) }}"
                                         alt="{{ user.name }}"
                                         class="rounded-circle img-fluid mb-3"
                                         style="width: 200px; height: 200px; object-fit: cover;">
                                {% else %}
                                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                                         style="width: 200px; height: 200px; font-size: 4rem; font-weight: bold;">
                                        {{ user.name|first|upper }}
                                    </div>
                                {% endif %}
                                <h5>{{ user.name }}</h5>
                                {% if user.isActive %}
                                    <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> Active
                                </span>
                                {% else %}
                                    <span class="badge bg-secondary">
                                    <i class="bi bi-x-circle"></i> Inactive
                                </span>
                                {% endif %}
                            </div>
                            <div class="col-md-8">
                                <table class="table table-borderless">
                                    <tbody>
                                    <tr>
                                        <th width="30%">Email:</th>
                                        <td class="text_color_default">{{ user.email }}</td>
                                    </tr>
                                    <tr>
                                        <th>Phone:</th>
                                        <td>{{ user.phone ?? 'N/A' }}</td>
                                    </tr>
                                    <tr>
                                        <th>Address:</th>
                                        <td>{{ user.address ?? 'N/A' }}</td>
                                    </tr>
                                    <tr>
                                        <th>Created At:</th>
                                        <td>{{ user.createdAt|date('d m Y') }}</td>
                                    </tr>
                                    <tr>
                                        <th>Updated At:</th>
                                        <td>{{ user.updatedAt|date('d m Y') }}</td>
                                    </tr>
                                    <tr>
                                        <th>Last Login:</th>
                                        <td>
                                            {% if user.lastLoginAt %}
                                                {{ user.lastLoginAt|date('d m Y') }}
                                                {% if user.lastLoginIp %}
                                                    <br><small class="text_color_default">IP: {{ user.lastLoginIp }}</small>
                                                {% endif %}
                                            {% else %}
                                                <span class="text_color_default">Never</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Roles:</th>
                                        <td>
                                            {% set roleColors = ['notii_badge_success', 'notii_badge_warning', 'notii_badge_info', 'notii_badge_danger'] %}
                                            {% set roleIcons = {
                                                'ROLE_ADMIN': 'bi-shield-lock',
                                                'ROLE_USER': 'bi-person',
                                                'ROLE_MANAGER': 'bi-briefcase',
                                                'ROLE_EDITOR': 'bi-pencil-square',
                                                'ROLE_VIEWER': 'bi-eye',
                                                'ROLE_SUPPORT': 'bi-headset',
                                                'ROLE_DEVELOPER': 'bi-code-slash',
                                                'ROLE_FINANCE': 'bi-cash-stack',
                                                'ROLE_HR': 'bi-people'
                                            } %}

                                            {% for role in user.roles %}
                                                {% set colorClass = roleColors[loop.index0 % roleColors|length] %}
                                                {% set roleText = role|replace({'ROLE_': '', '_': ' '})|title %}
                                                {% set iconClass = roleIcons[role] ?? 'bi-person-badge' %} {# fallback icon #}

                                                <span class="badge {{ colorClass }} me-1 mb-2">
            <i class="bi {{ iconClass }} me-1"></i> {{ roleText }}
        </span>
                                            {% endfor %}
                                        </td>
                                    </tr>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer">
                        <a href="{{ path('app_user_index') }}" class="btn btn-sm btn-light-secondary">
                            <i class="bi bi-arrow-left"></i> Back to Users
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
