{# main/admission.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Admission - DIET Namchi{% endblock %}

{% block body %}
    <!-- Compact Hero/Breadcrumb Section -->
    <section class="compact-hero" style="background-image: url('{{ asset('images/breadcrumb.webp') }}');">
        <div class="compact-hero-overlay"></div>
        <div class="container h-100">
            <div class="row h-100 align-items-center">
                <div class="col-12" data-aos="fade-up">
                    <div class="compact-hero-content">
                        <span class="compact-hero-badge">
                            <i class="bi bi-mortarboard"></i> Admissions Open
                        </span>
                        <h1 class="compact-hero-title">Admission 2026-28</h1>
                        <nav aria-label="breadcrumb" class="compact-breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_main') }}" class="text-white">
                                        <i class="bi bi-house-door"></i> Home
                                    </a>
                                </li>
                                <li class="breadcrumb-item active text-white-50" aria-current="page">Admission</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Admission Overview -->
    <section class="section-padding">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-calendar-check"></i> Session 2026-2028
                </span>
                <h2 class="section-title">Join DIET Namchi</h2>
                <p>Embark on a rewarding career in education with our NCTE-recognized teacher training programs. We offer quality education aligned with NEP 2020 to shape the future educators of Sikkim.</p>
            </div>

            <!-- Programs Offered -->
            <div class="row g-4 mb-5">
                <!-- D.El.Ed Program -->
                <div class="col-lg-6" data-aos="fade-up" data-aos-delay="100">
                    <div class="program-card h-100">
                        <div class="program-img-wrapper">
                            <img src="{{ asset('images/dummy/2.jpg') }}" alt="D.El.Ed Program">
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-success px-3 py-2">Admission Open</span>
                            </div>
                        </div>
                        <div class="program-content">
                            <h3 class="program-title">Diploma in Elementary Education (D.El.Ed)</h3>
                            <div class="program-meta">
                                <span><i class="bi bi-clock"></i> 2 Years</span>
                                <span><i class="bi bi-award"></i> NCTE Recognized</span>
                            </div>
                            <p>Comprehensive 2-year diploma program preparing teachers for classes I-VIII. Focus on child development, pedagogy, and classroom management.</p>

                            <h6 class="mt-3 mb-2">Eligibility Criteria:</h6>
                            <ul class="list-unstyled mb-3">
                                <li><i class="bi bi-check2 text-primary me-2"></i>Higher Secondary (10+2) with minimum 50% marks</li>
                                <li><i class="bi bi-check2 text-primary me-2"></i>Relaxation of 5% for SC/ST/OBC candidates</li>
                                <li><i class="bi bi-check2 text-primary me-2"></i>Age: 18-35 years (relaxation as per govt. norms)</li>
                                <li><i class="bi bi-check2 text-primary me-2"></i>Sikkim domicile certificate required</li>
                            </ul>

                            <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                                <div>
                                    <strong class="text-primary">Seats:</strong> 100
                                </div>
                                <a href="#" class="btn-apply">Apply Now</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- B.Ed Program -->
                <div class="col-lg-6" data-aos="fade-up" data-aos-delay="200">
                    <div class="program-card h-100">
                        <div class="program-img-wrapper">
                            <img src="{{ asset('images/dummy/2.jpg') }}" alt="B.Ed Program">
                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-warning text-dark px-3 py-2">Coming Soon</span>
                            </div>
                        </div>
                        <div class="program-content">
                            <h3 class="program-title">Bachelor of Education (B.Ed)</h3>
                            <div class="program-meta">
                                <span><i class="bi bi-clock"></i> 2 Years</span>
                                <span><i class="bi bi-award"></i> NCTE Recognized</span>
                            </div>
                            <p>Professional degree program for secondary and higher secondary level teaching. Specializations in multiple subjects available.</p>

                            <h6 class="mt-3 mb-2">Eligibility Criteria:</h6>
                            <ul class="list-unstyled mb-3">
                                <li><i class="bi bi-check2 text-primary me-2"></i>Graduation with minimum 50% marks</li>
                                <li><i class="bi bi-check2 text-primary me-2"></i>Mathematics/Science/Arts stream</li>
                                <li><i class="bi bi-check2 text-primary me-2"></i>Entrance examination required</li>
                                <li><i class="bi bi-check2 text-primary me-2"></i>Age: 21-35 years</li>
                            </ul>

                            <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                                <div>
                                    <strong class="text-primary">Seats:</strong> 100
                                </div>
                                <button class="btn btn-outline-primary" disabled>Notify Me</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Important Dates -->
            <div class="row g-4 mb-5">
                <div class="col-12" data-aos="fade-up">
                    <div class="feature-card">
                        <h3 class="feature-title mb-4">
                            <i class="bi bi-calendar-event me-2"></i>Important Dates - D.El.Ed 2026
                        </h3>
                        <div class="row g-3">
                            <div class="col-md-6 col-lg-3">
                                <div class="text-center p-3 rounded-3" style="background: var(--bg-soft);">
                                    <i class="bi bi-calendar-plus fs-1 text-primary mb-2 d-block"></i>
                                    <strong>Application Start</strong><br>
                                    <span class="text-muted">March 01, 2026</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="text-center p-3 rounded-3" style="background: var(--bg-soft);">
                                    <i class="bi bi-calendar-x fs-1 text-danger mb-2 d-block"></i>
                                    <strong>Last Date</strong><br>
                                    <span class="text-muted">March 31, 2026</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="text-center p-3 rounded-3" style="background: var(--bg-soft);">
                                    <i class="bi bi-file-earmark-check fs-1 text-success mb-2 d-block"></i>
                                    <strong>Entrance Exam</strong><br>
                                    <span class="text-muted">April 15, 2026</span>
                                </div>
                            </div>
                            <div class="col-md-6 col-lg-3">
                                <div class="text-center p-3 rounded-3" style="background: var(--bg-soft);">
                                    <i class="bi bi-megaphone fs-1 text-warning mb-2 d-block"></i>
                                    <strong>Result</strong><br>
                                    <span class="text-muted">May 01, 2026</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Application Process -->
            <div class="row g-4 mb-5">
                <div class="col-12" data-aos="fade-up">
                    <h3 class="mb-4">How to Apply</h3>
                    <div class="row g-4">
                        <div class="col-md-3 text-center">
                            <div class="feature-icon mx-auto mb-3" style="width: 80px; height: 80px; font-size: 32px;">
                                <i class="bi bi-laptop"></i>
                            </div>
                            <h5>Step 1: Online Registration</h5>
                            <p class="small">Visit our admission portal and create your account with valid email and mobile number.</p>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="feature-icon mx-auto mb-3" style="width: 80px; height: 80px; font-size: 32px;">
                                <i class="bi bi-file-earmark-fill"></i>
                            </div>
                            <h5>Step 2: Fill Application</h5>
                            <p class="small">Complete the application form with personal, educational, and contact details.</p>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="feature-icon mx-auto mb-3" style="width: 80px; height: 80px; font-size: 32px;">
                                <i class="bi bi-upload"></i>
                            </div>
                            <h5>Step 3: Upload Documents</h5>
                            <p class="small">Upload scanned copies of photographs, signatures, and supporting documents.</p>
                        </div>
                        <div class="col-md-3 text-center">
                            <div class="feature-icon mx-auto mb-3" style="width: 80px; height: 80px; font-size: 32px;">
                                <i class="bi bi-credit-card"></i>
                            </div>
                            <h5>Step 4: Pay Fee</h5>
                            <p class="small">Pay application fee of Rs. 500/- online through net banking/UPI/card.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Required Documents -->
            <div class="row g-4">
                <div class="col-lg-6" data-aos="fade-right">
                    <div class="feature-card h-100">
                        <h4 class="feature-title mb-3">
                            <i class="bi bi-folder-check me-2"></i>Required Documents
                        </h4>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>10th Mark Sheet & Certificate</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>12th Mark Sheet & Certificate</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Character Certificate</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Domicile Certificate (Sikkim)</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Category Certificate (if applicable)</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Passport Size Photographs (6)</li>
                            <li class="mb-2"><i class="bi bi-check-circle text-success me-2"></i>Aadhaar Card</li>
                            <li><i class="bi bi-check-circle text-success me-2"></i>Income Certificate (for fee concession)</li>
                        </ul>
                    </div>
                </div>

                <div class="col-lg-6" data-aos="fade-left">
                    <div class="feature-card h-100">
                        <h4 class="feature-title mb-3">
                            <i class="bi bi-cash-coin me-2"></i>Fee Structure
                        </h4>
                        <div class="table-responsive">
                            <table class="table table-borderless mb-0">
                                <tbody>
                                <tr>
                                    <td>Application Fee</td>
                                    <td class="text-end"><strong>Rs. 500/-</strong></td>
                                </tr>
                                <tr class="border-top">
                                    <td>Admission Fee (One Time)</td>
                                    <td class="text-end"><strong>Rs. 5,000/-</strong></td>
                                </tr>
                                <tr class="border-top">
                                    <td>Tuition Fee (Per Semester)</td>
                                    <td class="text-end"><strong>Rs. 8,000/-</strong></td>
                                </tr>
                                <tr class="border-top">
                                    <td>Examination Fee (Per Semester)</td>
                                    <td class="text-end"><strong>Rs. 2,000/-</strong></td>
                                </tr>
                                <tr class="border-top">
                                    <td>Library & Sports Fee (Annual)</td>
                                    <td class="text-end"><strong>Rs. 1,500/-</strong></td>
                                </tr>
                                <tr class="border-top bg-light">
                                    <td><strong>Total (Per Year)</strong></td>
                                    <td class="text-end"><strong>Rs. 22,500/-</strong></td>
                                </tr>
                                </tbody>
                            </table>
                        </div>
                        <p class="small text-muted mt-3 mb-0">* Fee concession available for SC/ST/OBC candidates as per government norms.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div data-aos="fade-up">
                <span class="section-subtitle mb-3">
                    <i class="bi bi-hand-thumbs-up"></i> Start Your Journey
                </span>
                <h2 class="mb-3">Ready to Become an Educator?</h2>
                <p class="mx-auto mb-4">Join DIET Namchi and embark on a fulfilling career shaping the future generation of Sikkim.</p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="#" class="btn-apply">
                        <i class="bi bi-pencil-square me-2"></i>Apply Online Now
                    </a>
                    <a href="#" class="btn btn-outline-primary px-4 py-2 rounded-pill">
                        <i class="bi bi-download me-1"></i>Download Prospectus
                    </a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
