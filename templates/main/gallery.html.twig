{# main/gallery.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Gallery - DIET Namchi{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* ── Album Grid ───────────────────────────────────────────── */
        .gallery-section {
            padding: 80px 0 100px;
            background: #f8f9fc;
        }

        .album-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 28px;
            margin-top: 50px;
        }

        /* ── Album Card ───────────────────────────────────────────── */
        .album-card {
            position: relative;
            border-radius: 16px;
            overflow: hidden;
            background: #fff;
            box-shadow: 0 4px 20px rgba(0,0,0,.07);
            transition: transform .35s ease, box-shadow .35s ease;
            text-decoration: none;
            display: block;
        }
        .album-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 16px 40px rgba(0,0,0,.13);
        }

        /* Cover image */
        .album-cover {
            position: relative;
            width: 100%;
            padding-top: 65%;          /* aspect ratio ~3:2 */
            overflow: hidden;
            background: #dee2e6;
        }
        .album-cover img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .5s ease;
        }
        .album-card:hover .album-cover img {
            transform: scale(1.07);
        }

        /* Image count badge */
        .album-count {
            position: absolute;
            top: 14px;
            right: 14px;
            background: rgba(0,0,0,.55);
            backdrop-filter: blur(6px);
            color: #fff;
            font-size: .75rem;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 20px;
            letter-spacing: .4px;
        }

        /* Hover overlay */
        .album-hover-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(15,23,42,.6) 0%, transparent 55%);
            display: flex;
            align-items: flex-end;
            justify-content: center;
            padding-bottom: 22px;
            opacity: 0;
            transition: opacity .35s ease;
        }
        .album-card:hover .album-hover-overlay {
            opacity: 1;
        }
        .album-hover-overlay span {
            color: #fff;
            font-size: .9rem;
            font-weight: 600;
            letter-spacing: .5px;
        }
        .album-hover-overlay i { margin-right: 6px; }

        /* Card body */
        .album-body {
            padding: 18px 20px 20px;
        }
        .album-title {
            font-size: 1.05rem;
            font-weight: 700;
            color: #1e293b;
            margin: 0 0 6px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .album-meta {
            font-size: .8rem;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .album-meta i { color: #94a3b8; }

        /* No cover placeholder */
        .album-cover-placeholder {
            position: absolute;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #e2e8f0 0%, #cbd5e1 100%);
            color: #94a3b8;
            font-size: 2.5rem;
        }
        .album-cover-placeholder small {
            font-size: .75rem;
            margin-top: 8px;
            color: #94a3b8;
        }

        /* Empty state */
        .gallery-empty {
            grid-column: 1 / -1;
            text-align: center;
            padding: 80px 20px;
            color: #94a3b8;
        }
        .gallery-empty i { font-size: 4rem; display: block; margin-bottom: 16px; }
        .gallery-empty p { font-size: 1.05rem; }
    </style>
{% endblock %}

{% block body %}
    <!-- Compact Hero/Breadcrumb Section -->
    <section class="compact-hero" style="background-image: url('{{ asset('images/dummy/2.jpg') }}');">
        <div class="compact-hero-overlay"></div>
        <div class="container h-100">
            <div class="row h-100 align-items-center">
                <div class="col-12" data-aos="fade-up">
                    <div class="compact-hero-content">
                        <span class="compact-hero-badge">
                            <i class="bi bi-images"></i> Moments
                        </span>
                        <h1 class="compact-hero-title">Photo Gallery</h1>
                        <nav aria-label="breadcrumb" class="compact-breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_main') }}" class="text-white">
                                        <i class="bi bi-house-door"></i> Home
                                    </a>
                                </li>
                                <li class="breadcrumb-item active text-white-50" aria-current="page">Gallery</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Gallery Albums Section -->
    <section class="gallery-section" id="gallery">
        <div class="container">
            <div class="section-title-block" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-images"></i> Our Gallery
                </span>
                <p>Browse our albums — click any to explore the full collection.</p>
            </div>

            <div class="album-grid">
                {% if vgalleries is not empty %}
                    {% for gallery in vgalleries %}
                        <a href="{{ path('app_gallery_detail', {'slug': gallery.slug}) }}"
                           class="album-card"
                           data-aos="fade-up"
                           data-aos-delay="{{ loop.index0 % 3 * 100 }}">

                            <div class="album-cover">
                                {% if gallery.coverImage %}
                                    <img src="{{ asset('uploads/image/' ~ gallery.coverImage) }}"
                                         alt="{{ gallery.title }}"
                                         loading="lazy">
                                {% elseif gallery.images is not empty %}
                                    <img src="{{ asset('uploads/image/' ~ gallery.images[0].filename) }}"
                                         alt="{{ gallery.title }}"
                                         loading="lazy">
                                {% else %}
                                    <div class="album-cover-placeholder">
                                        <i class="bi bi-image"></i>
                                        <small>No images yet</small>
                                    </div>
                                {% endif %}

                                <span class="album-count">
                                    <i class="bi bi-images"></i>
                                    {{ gallery.images|length }}
                                </span>

                                <div class="album-hover-overlay">
                                    <span><i class="bi bi-eye"></i> View Album</span>
                                </div>
                            </div>

                            <div class="album-body">
                                <h3 class="album-title">{{ gallery.title }}</h3>
                                <div class="album-meta">
                                    <span><i class="bi bi-images"></i> {{ gallery.images|length }} photo{{ gallery.images|length != 1 ? 's' : '' }}</span>
                                </div>
                            </div>
                        </a>
                    {% endfor %}
                {% else %}
                    <div class="gallery-empty" data-aos="fade-up">
                        <i class="bi bi-images"></i>
                        <p>No gallery albums have been published yet. Check back soon!</p>
                    </div>
                {% endif %}
            </div>

        </div>
    </section>
{% endblock %}
