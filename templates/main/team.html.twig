    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div data-aos="fade-up">
                <span class="section-subtitle mb-3">
                    <i class="bi bi-hand-thumbs-up"></i> Join Our Team
                </span>
                <h2 class="mb-3">Interested in Working With Us?</h2>
                <p class="mx-auto mb-4">Check our current openings and become part of the DIET Namchi family.</p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="{{ path('app_notices') }}" class="btn-apply">View Openings</a>
                    <a href="{{ path('app_contact') }}" class="btn btn-outline-primary px-4 py-2 rounded-pill">Contact HR</a>
