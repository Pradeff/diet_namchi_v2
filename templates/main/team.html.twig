            </div>
        </div>
    </section>

    <!-- Support Staff -->
    <section class="section-padding">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-heart"></i> Support Staff
                </span>
                <h2 class="section-title">Administrative & Support Team</h2>
            </div>

            <div class="row g-4 justify-content-center">
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #0ea5e9, #22c55e);">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>
                        <h5 class="mb-2">Office Staff</h5>
                        <p class="small text-muted mb-0">5 Members</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #f59e0b, #ef4444);">
                            <i class="bi bi-tools"></i>
                        </div>
