                        </div>
                    </div>
                </div>

                <!-- Faculty 3 -->
                <div class="col-lg-3 col-md-6" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card text-center">
                        <img src="{{ asset('images/dummy/2.jpg') }}" alt="Faculty" class="rounded-circle mb-3 mx-auto" style="width: 100px; height: 100px; object-fit: cover; border: 3px solid var(--bg-soft);">
                        <h5 class="mb-1">Mr./Ms. [Faculty Name]</h5>
                        <p class="text-primary small mb-2">Assistant Professor</p>
