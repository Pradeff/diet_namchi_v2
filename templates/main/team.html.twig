{# main/team.html.twig — Bound to Vteam data #}
{% extends 'base.html.twig' %}

{% block title %}Our Team — DIET Namchi{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --navy:    #0f172a;
            --blue:    #1e3a8a;
            --rose:    #99406a;
            --rose-lt: #c46594;
            --gold:    #e8b86d;
            --slate:   #475569;
            --muted:   #94a3b8;
            --bg-off:  #f8fafc;
            --border:  #e2e8f0;
            --ease:    cubic-bezier(.4,0,.2,1);
            --r:       14px;
        }

        /* ══ HERO ══ */
        .team-hero {
            position: relative;
            height: 240px;
            display: flex;
            align-items: flex-end;
            background: url('{{ asset('images/breadcrumb.webp') }}') center/cover no-repeat;
            overflow: hidden;
        }
        .team-hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg,
            rgba(15,23,42,.82) 0%,
            rgba(30,58,138,.55) 50%,
            rgba(153,64,106,.45) 100%);
        }
        .team-hero-body {
            position: relative;
            z-index: 2;
            padding: 0 0 52px;
            width: 100%;
        }
        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 6px 14px;
            border-radius: 100px;
            border: 1px solid rgba(255,255,255,.18);
            background: rgba(255,255,255,.08);
            backdrop-filter: blur(6px);
            font-size: 12px;
            font-weight: 600;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: #fff;
            margin-bottom: 14px;
        }
        .hero-eyebrow i { color: var(--gold); }
        .team-hero h1 {
            font-size: clamp(2rem, 5vw, 3.2rem);
            font-weight: 700;
            color: #fff;
            line-height: 1.15;
            margin-bottom: 14px;
        }
        .team-hero h1 em { font-style: italic; color: var(--gold); }
        .team-breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: rgba(255,255,255,.55);
        }
        .team-breadcrumb a { color: rgba(255,255,255,.75); text-decoration: none; transition: color .2s; }
        .team-breadcrumb a:hover { color: #fff; }
        .hero-wave {
            display: block;
            position: absolute;
            bottom: -1px; left: 0; right: 0;
            height: 60px;
            z-index: 3;
        }

        /* ══ SECTION SCAFFOLD ══ */
        .team-section { padding: 80px 0; }
        .team-section.alt { background: var(--bg-off); }
        .team-label {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--rose);
            margin-bottom: 10px;
        }
        .team-label::before {
            content: '';
            width: 24px; height: 2px;
            border-radius: 2px;
            background: var(--rose);
        }
        .team-heading {
            font-size: clamp(1.8rem, 3.5vw, 2.5rem);
            font-weight: 700;
            color: var(--navy);
            line-height: 1.2;
            margin-bottom: 12px;
        }
        .team-sub {
            font-size: 15px;
            color: var(--slate);
            line-height: 1.7;
        }

        /* ══ PRINCIPAL CARD ══ */
        .principal-card {
            display: grid;
            grid-template-columns: 300px 1fr;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(15,23,42,.10);
            background: #fff;
            border: 1px solid var(--border);
            transition: box-shadow .3s var(--ease), transform .3s var(--ease);
        }
        .principal-card:hover {
            box-shadow: 0 30px 80px rgba(15,23,42,.16);
            transform: translateY(-3px);
        }
        .principal-photo { position: relative; overflow: hidden; }
        .principal-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .principal-photo::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, transparent 70%, rgba(255,255,255,.4) 100%);
        }
        .principal-role-tag {
            position: absolute;
            bottom: 20px; left: 20px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 14px;
            border-radius: 8px;
            background: rgba(15,23,42,.75);
            backdrop-filter: blur(8px);
            font-size: 12px;
            font-weight: 600;
            color: #fff;
            z-index: 1;
        }
        .principal-role-tag i { color: var(--gold); }
        .principal-info {
            padding: 40px 44px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
        }
        .principal-info::before {
            content: '"';
            position: absolute;
            top: 20px; right: 36px;
            font-size: 120px;
            line-height: 1;
            color: rgba(153,64,106,.06);
            pointer-events: none;
        }
        .principal-eyebrow {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--rose);
            margin-bottom: 12px;
        }
        .principal-info h2 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--navy);
            line-height: 1.2;
            margin-bottom: 6px;
        }
        .principal-info h2 span { color: var(--blue); }
        .principal-degree { font-size: 13px; color: var(--muted); margin-bottom: 18px; }
        .principal-quote {
            font-size: 16px;
            font-style: italic;
            color: var(--slate);
            line-height: 1.7;
            border-left: 3px solid var(--rose);
            padding-left: 16px;
            margin-bottom: 16px;
        }
        .principal-contacts { display: flex; flex-wrap: wrap; gap: 10px; }
        .contact-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 14px;
            border-radius: 9px;
            background: var(--bg-off);
            border: 1px solid var(--border);
            font-size: 12.5px;
            color: var(--slate);
            text-decoration: none;
            transition: all .2s var(--ease);
        }
        .contact-pill i { color: var(--blue); font-size: 13px; }
        .contact-pill:hover { background: var(--blue); color: #fff; border-color: var(--blue); }
        .contact-pill:hover i { color: #fff; }

        /* ══ READ MORE BUTTON ══ */
        .btn-read-more {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 9px 20px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--rose), var(--rose-lt));
            color: #fff;
            font-size: 13px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            margin-bottom: 20px;
            transition: all .25s var(--ease);
            box-shadow: 0 4px 14px rgba(153,64,106,.25);
            letter-spacing: .3px;
        }
        .btn-read-more:hover {
            opacity: .9;
            transform: translateY(-1px);
            box-shadow: 0 8px 22px rgba(153,64,106,.38);
            color: #fff;
        }
        .btn-read-more i { font-size: 14px; }

        /* ══ FACULTY GRID ══ */
        .faculty-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 32px; }
        .faculty-card {
            background: #fff;
            border-radius: var(--r);
            border: 1px solid var(--border);
            padding: 28px 20px 24px;
            text-align: center;
            position: relative;
            transition: all .3s var(--ease);
            overflow: hidden;
        }
        .faculty-card::before {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--blue), var(--rose-lt));
            transform: scaleX(0);
            transform-origin: left;
            transition: transform .3s var(--ease);
        }
        .faculty-card:hover::before { transform: scaleX(1); }
        .faculty-card:hover { box-shadow: 0 16px 44px rgba(15,23,42,.09); transform: translateY(-4px); border-color: transparent; }
        .faculty-photo {
            width: 86px; height: 86px;
            border-radius: 50%;
            overflow: hidden;
            margin: 0 auto 16px;
            border: 3px solid var(--bg-off);
            box-shadow: 0 6px 20px rgba(15,23,42,.10);
            transition: border-color .3s;
        }
        .faculty-card:hover .faculty-photo { border-color: var(--rose-lt); }
        .faculty-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .faculty-name { font-size: 16px; font-weight: 700; color: var(--navy); margin-bottom: 4px; line-height: 1.3; }
        .faculty-role { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--rose); margin-bottom: 6px; }
        .faculty-subject {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 100px;
            background: var(--bg-off);
            font-size: 11.5px;
            color: var(--slate);
            margin-bottom: 8px;
            word-break: break-all;
        }
        .faculty-subject i { color: var(--blue); font-size: 11px; }
        .faculty-ext { font-size: 12px; color: var(--muted); display: flex; align-items: center; justify-content: center; gap: 5px; }
        .faculty-ext i { color: var(--blue); }

        /* ══ SUPPORT STAFF ══ */
        .support-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
        .support-card {
            border-radius: var(--r);
            padding: 32px 28px;
            border: 1px solid var(--border);
            background: #fff;
            display: flex;
            align-items: center;
            gap: 22px;
            transition: all .3s var(--ease);
        }
        .support-card:hover { box-shadow: 0 16px 44px rgba(15,23,42,.09); transform: translateY(-3px); border-color: transparent; }
        .support-icon-wrap { width: 58px; height: 58px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 22px; color: #fff; flex-shrink: 0; }
        .support-text { flex: 1; }
        .support-text h5 { font-size: 17px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
        .support-count { font-size: 13px; color: var(--muted); margin-bottom: 8px; }
        .support-bar { height: 4px; border-radius: 2px; background: var(--border); overflow: hidden; width: 100%; }
        .support-bar-fill { height: 100%; border-radius: 2px; background: linear-gradient(90deg, var(--blue), var(--rose-lt)); }

        /* ══ CTA ══ */
        .team-cta {
            position: relative;
            border-radius: 24px;
            overflow: hidden;
            background: var(--navy);
            padding: 64px 56px;
            text-align: center;
            margin: 80px 0;
        }
        .team-cta::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse 60% 70% at 20% 50%, rgba(30,58,138,.5) 0%, transparent 60%),
                radial-gradient(ellipse 50% 60% at 80% 50%, rgba(153,64,106,.4) 0%, transparent 60%);
            pointer-events: none;
        }
        .team-cta-inner { position: relative; z-index: 1; }
        .team-cta-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 6px 14px;
            border-radius: 100px;
            border: 1px solid rgba(255,255,255,.15);
            background: rgba(255,255,255,.07);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 20px;
        }
        .team-cta h2 { font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700; color: #fff; margin-bottom: 14px; }
        .team-cta p { font-size: 15px; color: rgba(255,255,255,.6); max-width: 440px; margin: 0 auto 32px; line-height: 1.7; }
        .btn-cta-primary {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 14px 28px; border-radius: 12px;
            background: linear-gradient(135deg, var(--rose), var(--rose-lt));
            color: #fff; font-size: 14px; font-weight: 600;
            text-decoration: none; transition: all .25s var(--ease);
        }
        .btn-cta-primary:hover { opacity: .88; transform: translateY(-2px); box-shadow: 0 12px 28px rgba(153,64,106,.4); color: #fff; }
        .btn-cta-outline {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 14px 28px; border-radius: 12px;
            border: 1px solid rgba(255,255,255,.2);
            color: rgba(255,255,255,.8); background: transparent;
            font-size: 14px; font-weight: 600;
            text-decoration: none; transition: all .25s var(--ease);
        }
        .btn-cta-outline:hover { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.4); color: #fff; }

        /* ══ NO-IMAGE PLACEHOLDER ══ */
        .photo-placeholder {
            width: 100%; height: 100%;
            display: flex; align-items: center; justify-content: center;
            background: linear-gradient(135deg, var(--bg-off), var(--border));
            color: var(--muted);
            font-size: 2rem;
        }

        /* ══ RESPONSIVE ══ */
        @media (max-width: 1024px) {
            .faculty-grid { grid-template-columns: repeat(2, 1fr); }
            .support-grid { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 768px) {
            .principal-card  { grid-template-columns: 1fr; }
            .principal-photo { height: 360px; }
            .support-grid    { grid-template-columns: 1fr; }
            .team-cta        { padding: 48px 28px; }
            .principal-info{ padding: 15px }
            .team-hero{ height: 220px; }
            .team-section{ padding: 10px 0;}
        }
        @media (max-width: 480px) {
            .faculty-grid { grid-template-columns: 1fr; }
        }

        /* ══ PRINCIPAL BIO MODAL ══ */
        .bio-modal .modal-dialog {
            max-width: 680px;
            margin: 1.75rem auto;
        }
        .bio-modal .modal-content {
            border: none;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 40px 100px rgba(15,23,42,.22);
        }
        .bio-modal-header {
            position: relative;
            background: linear-gradient(135deg, var(--navy) 0%, #1e2d5a 60%, #3d1a2e 100%);
            padding: 36px 40px 28px;
            border-bottom: none;
        }
        .bio-modal-header::before {
            content: '"';
            position: absolute;
            top: -10px; right: 32px;
            font-size: 140px;
            line-height: 1;
            color: rgba(255,255,255,.04);
            pointer-events: none;
            font-family: Georgia, serif;
        }
        .bio-modal-avatar {
            width: 72px; height: 72px;
            border-radius: 50%;
            overflow: hidden;
            border: 3px solid rgba(255,255,255,.2);
            box-shadow: 0 8px 24px rgba(0,0,0,.3);
            flex-shrink: 0;
        }
        .bio-modal-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .bio-modal-avatar-placeholder {
            width: 72px; height: 72px;
            border-radius: 50%;
            background: rgba(255,255,255,.1);
            border: 3px solid rgba(255,255,255,.2);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.6rem; color: rgba(255,255,255,.5);
            flex-shrink: 0;
        }
        .bio-modal-title-group { flex: 1; min-width: 0; }
        .bio-modal-eyebrow {
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: 1.6px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 5px;
            opacity: .85;
        }
        .bio-modal-name {
            font-size: 1.55rem;
            font-weight: 700;
            color: #fff;
            line-height: 1.2;
            margin-bottom: 4px;
        }
        .bio-modal-role {
            font-size: 12px;
            color: rgba(255,255,255,.5);
            font-weight: 500;
        }
        .bio-modal-close {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
            color: rgba(255,255,255,.6);
            display: flex; align-items: center; justify-content: center;
            cursor: pointer;
            transition: all .2s;
            flex-shrink: 0;
            font-size: 16px;
            padding: 0;
        }
        .bio-modal-close:hover {
            background: rgba(255,255,255,.16);
            color: #fff;
            border-color: rgba(255,255,255,.25);
        }
        .bio-modal-divider {
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,.12) 30%, rgba(255,255,255,.12) 70%, transparent);
            margin: 0 40px;
        }
        .bio-modal-body {
            padding: 32px 20px 36px;
            background: #fff;
        }
        .bio-modal-body-label {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 10.5px;
            font-weight: 700;
            letter-spacing: 1.4px;
            text-transform: uppercase;
            color: var(--rose);
            margin-bottom: 14px;
        }
        .bio-modal-body-label::before {
            content: '';
            width: 20px; height: 2px;
            background: var(--rose);
            border-radius: 2px;
        }
        .bio-modal-text {
            font-size: 15px;
            font-style: italic;
            color: var(--slate);
            line-height: 1.78;
            border-left: 3px solid var(--rose);
            padding-left: 18px;
            margin: 0;
        }
        .bio-modal-contacts {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 28px;
            padding-top: 24px;
            border-top: 1px solid var(--border);
        }

        @media (max-width: 600px) {
            .bio-modal .modal-dialog { margin: 0; max-width: 100%; }
            .bio-modal .modal-content { border-radius: 20px 20px 0 0; }
            .bio-modal-header { padding: 28px 24px 22px; }
            .bio-modal-body  { padding: 24px 24px 28px; }
            .bio-modal-divider { margin: 0 24px; }
        }
    </style>
{% endblock %}

{% block body %}

    {# ── HERO ── #}
    <section class="team-hero">
        <div class="team-hero-body">
            <div class="container">
                <div data-aos="fade-up">
                    <div class="hero-eyebrow"><i class="bi bi-people-fill"></i> Our People</div>
                    <h1>Meet Our <em>Faculty</em> &amp; Staff</h1>
                    <nav class="team-breadcrumb" aria-label="breadcrumb">
                        <a href="{{ path('app_main') }}"><i class="bi bi-house-door-fill"></i> Home</a>
                        <i class="bi bi-chevron-right"></i>
                        <span>Team</span>
                    </nav>
                </div>
            </div>
        </div>
        <svg class="hero-wave" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f8fafc"/>
        </svg>
    </section>

    {% set principal = null %}
    {% set faculty   = [] %}
    {% for member in vteams %}
        {% if member.position == 1 %}
            {% set principal = member %}
        {% else %}
            {% set faculty = faculty|merge([member]) %}
        {% endif %}
    {% endfor %}


    {# ── LEADERSHIP / PRINCIPAL ── #}
    <section class="team-section alt">
        <div class="container">

            <div data-aos="fade-up" style="margin-bottom:40px;">
                <div class="team-label"><i class="bi bi-star-fill"></i> Leadership</div>
                <h2 class="team-heading">Administrative Team</h2>
                <p class="team-sub">Our dedicated leadership ensures academic excellence and institutional growth across every programme.</p>
            </div>

            {% if principal %}

                {% set raw_desc     = principal.description|striptags %}
                {% set words        = raw_desc|split(' ') %}
                {% set word_count   = words|length %}
                {% set is_long      = word_count > 100 %}

                {% if is_long %}
                    {% set preview_words = [] %}
                    {% for i in 0..55 %}
                        {% set preview_words = preview_words|merge([words[i]]) %}
                    {% endfor %}
                    {% set preview_text = preview_words|join(' ') ~ '…' %}
                {% endif %}

                <div class="principal-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="principal-photo">
                        {% if principal.image %}
                            <img src="{{ asset('uploads/image/' ~ principal.image) }}" alt="{{ principal.title }}">
                        {% else %}
                            <div class="photo-placeholder"><i class="bi bi-person-fill"></i></div>
                        {% endif %}
                        <div class="principal-role-tag">
                            <i class="bi bi-award-fill"></i>
                            {{ principal.designation ?? 'Principal' }}
                        </div>
                    </div>
                    <div class="principal-info">
                        <div class="principal-eyebrow">Leading With Vision</div>
                        <h2><span>{{ principal.title }}</span></h2>
                        {% if principal.designation %}
                            <p class="principal-degree">{{ principal.designation }}</p>
                        {% endif %}

                        {% if principal.description %}
                            {% if is_long %}
                                {# Show truncated plain-text preview #}
                                <p class="principal-quote">{{ preview_text }}
                                    {# "Read full message" button triggers modal #}
                                    <a class=""
                                       type="button"
                                       data-bs-toggle="modal"
                                       data-bs-target="#principalBioModal">
                                        <i class="bi bi-book-open"></i> Read Full Message
                                    </a>
                                </p>


                            {% else %}
                                <p class="principal-quote">{{ principal.description|raw }}


                                </p>
                            {% endif %}
                        {% endif %}

                        <div class="principal-contacts">
                            {% if principal.email %}
                                <a href="mailto:{{ principal.email }}" class="contact-pill">
                                    <i class="bi bi-envelope-fill"></i> {{ principal.email }}
                                </a>
                            {% endif %}
                            {% if principal.phone %}
                                <span class="contact-pill">
                                    <i class="bi bi-telephone-fill"></i> {{ principal.phone }}
                                </span>
                            {% endif %}
                        </div>
                    </div>
                </div>

                {# ── MODERN BIO MODAL ── #}
                {% if is_long %}
                    <div class="modal fade bio-modal" id="principalBioModal" tabindex="-1"
                         aria-labelledby="principalBioModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
                    <div class="modal-content">

                    {# — Modal Header — #}
                    <div class="bio-modal-header d-flex align-items-start gap-3">
                        <div class="bio-modal-avatar">
                            {% if principal.image %}
                                <img src="{{ asset('uploads/image/' ~ principal.image) }}"
                                     alt="{{ principal.title }}">
                            {% else %}
                                <div class="bio-modal-avatar-placeholder">
                                    <i class="bi bi-person-fill"></i>
                                </div>
                            {% endif %}
                        </div>

                        <div class="bio-modal-title-group">
                            <div class="bio-modal-eyebrow">Principal's Message</div>
                            <div class="bio-modal-name" id="principalBioModalLabel">
                                {{ principal.title }}
                            </div>
                            {% if principal.designation %}
                                <div class="bio-modal-role">{{ principal.designation }}</div>
                            {% endif %}
                        </div>

                        <button type="button"
                                class="bio-modal-close"
                                data-bs-dismiss="modal"
                                aria-label="Close">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>

                    <div class="bio-modal-divider"></div>

                    {# — Modal Body — #}
                    <div class="modal-body p-0">
                        <div class="bio-modal-body">
                            <div class="bio-modal-body-label">
                                <i class="bi bi-quote"></i> Full Message
                            </div>
                            <div class="bio-modal-text">
                                {{ principal.description|raw }}
                            </div>

                            {% if principal.email or principal.phone %}
                                <div class="bio-modal-contacts">
                                    {% if principal.email %}
                                        <a href="mailto:{{ principal.email }}" class="contact-pill">
                                            <i class="bi bi-envelope-fill"></i> {{ principal.email }}
                                        </a>
                                    {% endif %}
                                    {% if principal.phone %}
                                        <span class="contact-pill">
                                                    <i class="bi bi-telephone-fill"></i> {{ principal.phone }}
                                                </span>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    </div>{# /.modal-content #}
                    </div>{# /.modal-dialog #}
                    </div>{# /.modal #}
                {% endif %}

            {% endif %}

        </div>
    </section>


    {# ── FACULTY ── #}
    {% if faculty|length > 0 %}
        <section class="team-section">
            <div class="container">

                <div data-aos="fade-up" style="margin-bottom: 8px;">
                    <div class="team-label"><i class="bi bi-mortarboard-fill"></i> Academic Faculty</div>
                    <h2 class="team-heading">Our Expert Faculty</h2>
                    <p class="team-sub">Learn from experienced educators dedicated to your professional growth and development.</p>
                </div>

                <div class="faculty-grid">
                    {% for member in faculty %}
                        <div class="faculty-card" data-aos="fade-up" data-aos-delay="{{ loop.index * 60 }}">
                            <div class="faculty-photo">
                                {% if member.image %}
                                    <img src="{{ asset('uploads/image/' ~ member.image) }}" alt="{{ member.title }}">
                                {% else %}
                                    <div class="photo-placeholder" style="font-size:1.6rem;">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="faculty-name">{{ member.title }}</div>
                            {% if member.designation %}
                                <div class="faculty-role">{{ member.designation }}</div>
                            {% endif %}
                            {% if member.email %}
                                <div class="faculty-subject">
                                    <i class="bi bi-envelope-fill"></i>
                                    {{ member.email }}
                                </div>
                            {% endif %}
                            {% if member.phone %}
                                <div class="faculty-ext">
                                    <i class="bi bi-telephone"></i> {{ member.phone }}
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>

            </div>
        </section>
    {% endif %}


    {# ── CTA ── #}
    <section class="team-section alt">
        <div class="container">
            <div class="team-cta" data-aos="fade-up">
                <div class="team-cta-inner">
                    <div class="team-cta-eyebrow"><i class="bi bi-briefcase-fill"></i> Join Our Team</div>
                    <h2>Interested in Working With Us?</h2>
                    <p>Check our current openings and become part of the DIET Namchi family, shaping the future of education in Sikkim.</p>
                    <div style="display:flex;align-items:center;justify-content:center;gap:14px;flex-wrap:wrap;">
                        <a href="{{ path('app_contact') }}" class="btn-cta-primary">
                            <i class="bi bi-briefcase"></i> Contact us
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
