{# main/team.html.twig — Redesigned #}
{% extends 'base.html.twig' %}

{% block title %}Our Team — DIET Namchi{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root {
            --navy:    #0f172a;
            --blue:    #1e3a8a;
            --rose:    #99406a;
            --rose-lt: #c46594;
            --gold:    #e8b86d;
            --slate:   #475569;
            --muted:   #94a3b8;
            --bg-off:  #f8fafc;
            --border:  #e2e8f0;
            --ease:    cubic-bezier(.4,0,.2,1);
            --r:       14px;
        }

        /* ══ HERO ══ */
        .team-hero {
            position: relative;
            height: 340px;
            display: flex;
            align-items: flex-end;
            background: url('{{ asset('images/dummy/2.jpg') }}') center/cover no-repeat;
            overflow: hidden;
        }
        .team-hero::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg,
            rgba(15,23,42,.82) 0%,
            rgba(30,58,138,.55) 50%,
            rgba(153,64,106,.45) 100%);
        }
        .team-hero-body {
            position: relative;
            z-index: 2;
            padding: 0 0 52px;
            width: 100%;
        }
        .hero-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 6px 14px;
            border-radius: 100px;
            border: 1px solid rgba(255,255,255,.18);
            background: rgba(255,255,255,.08);
            backdrop-filter: blur(6px);
            font-family: var(--sans);
            font-size: 12px;
            font-weight: 600;
            letter-spacing: .8px;
            text-transform: uppercase;
            color: #fff;
            margin-bottom: 14px;
        }
        .hero-eyebrow i { color: var(--gold); }
        .team-hero h1 {
            font-family: var(--serif);
            font-size: clamp(2rem, 5vw, 3.2rem);
            font-weight: 700;
            color: #fff;
            line-height: 1.15;
            margin-bottom: 14px;
        }
        .team-hero h1 em { font-style: italic; color: var(--gold); }
        .team-breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: rgba(255,255,255,.55);
            font-family: var(--sans);
        }
        .team-breadcrumb a { color: rgba(255,255,255,.75); text-decoration: none; transition: color .2s; }
        .team-breadcrumb a:hover { color: #fff; }
        .hero-wave {
            display: block;
            position: absolute;
            bottom: -1px; left: 0; right: 0;
            height: 60px;
            z-index: 3;
        }

        /* ══ SECTION SCAFFOLD ══ */
        .team-section { padding: 80px 0; }
        .team-section.alt { background: var(--bg-off); }
        .team-label {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-family: var(--sans);
            font-size: 11.5px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--rose);
            margin-bottom: 10px;
        }
        .team-label::before {
            content: '';
            width: 24px; height: 2px;
            border-radius: 2px;
            background: var(--rose);
        }
        .team-heading {
            font-family: var(--serif);
            font-size: clamp(1.8rem, 3.5vw, 2.5rem);
            font-weight: 700;
            color: var(--navy);
            line-height: 1.2;
            margin-bottom: 12px;
        }
        .team-sub {
            font-size: 15px;
            color: var(--slate);
            max-width: 480px;
            line-height: 1.7;
        }

        /* ══ PRINCIPAL CARD ══ */
        .principal-card {
            display: grid;
            grid-template-columns: 300px 1fr;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 60px rgba(15,23,42,.10);
            background: #fff;
            border: 1px solid var(--border);
            transition: box-shadow .3s var(--ease), transform .3s var(--ease);
        }
        .principal-card:hover {
            box-shadow: 0 30px 80px rgba(15,23,42,.16);
            transform: translateY(-3px);
        }
        .principal-photo { position: relative; overflow: hidden; }
        .principal-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .principal-photo::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(to right, transparent 70%, rgba(255,255,255,.4) 100%);
        }
        .principal-role-tag {
            position: absolute;
            bottom: 20px; left: 20px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 14px;
            border-radius: 8px;
            background: rgba(15,23,42,.75);
            backdrop-filter: blur(8px);
            font-family: var(--sans);
            font-size: 12px;
            font-weight: 600;
            color: #fff;
        }
        .principal-role-tag i { color: var(--gold); }
        .principal-info {
            padding: 40px 44px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
        }
        .principal-info::before {
            content: '"';
            position: absolute;
            top: 20px; right: 36px;
            font-family: var(--serif);
            font-size: 120px;
            line-height: 1;
            color: rgba(153,64,106,.06);
            pointer-events: none;
        }
        .principal-eyebrow {
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--rose);
            margin-bottom: 12px;
        }
        .principal-info h2 {
            font-family: var(--serif);
            font-size: 2rem;
            font-weight: 700;
            color: var(--navy);
            line-height: 1.2;
            margin-bottom: 6px;
        }
        .principal-info h2 span { color: var(--blue); }
        .principal-degree { font-size: 13px; color: var(--muted); margin-bottom: 18px; }
        .principal-quote {
            font-family: var(--serif);
            font-size: 16px;
            font-style: italic;
            color: var(--slate);
            line-height: 1.7;
            border-left: 3px solid var(--rose);
            padding-left: 16px;
            margin-bottom: 24px;
        }
        .principal-contacts { display: flex; flex-wrap: wrap; gap: 10px; }
        .contact-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 8px 14px;
            border-radius: 9px;
            background: var(--bg-off);
            border: 1px solid var(--border);
            font-size: 12.5px;
            color: var(--slate);
            text-decoration: none;
            transition: all .2s var(--ease);
        }
        .contact-pill i { color: var(--blue); font-size: 13px; }
        .contact-pill:hover { background: var(--blue); color: #fff; border-color: var(--blue); }
        .contact-pill:hover i { color: #fff; }

        /* ══ ADMIN GRID ══ */
        .admin-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-top: 32px;
        }
        .admin-card {
            background: #fff;
            border-radius: var(--r);
            border: 1px solid var(--border);
            overflow: hidden;
            transition: all .3s var(--ease);
        }
        .admin-card:hover { box-shadow: 0 20px 50px rgba(15,23,42,.10); transform: translateY(-4px); border-color: transparent; }
        .admin-card-top { height: 6px; background: linear-gradient(90deg, var(--blue), var(--rose)); }
        .admin-card-body { padding: 28px 24px 24px; display: flex; align-items: flex-start; gap: 18px; }
        .admin-avatar {
            width: 72px; height: 72px;
            border-radius: 14px;
            overflow: hidden;
            flex-shrink: 0;
            border: 2px solid var(--bg-off);
            box-shadow: 0 6px 18px rgba(15,23,42,.10);
        }
        .admin-avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .admin-role { font-size: 11.5px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--rose); margin-bottom: 4px; }
        .admin-name { font-family: var(--serif); font-size: 17px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
        .admin-qual { font-size: 12px; color: var(--muted); margin-bottom: 10px; }
        .admin-ext { display: inline-flex; align-items: center; gap: 5px; font-size: 12px; color: var(--blue); font-weight: 500; }

        /* ══ STAT RIBBON ══ */
        .stat-ribbon {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            background: var(--navy);
            border-radius: 18px;
            overflow: hidden;
            margin: 52px 0 0;
            position: relative;
        }
        .stat-ribbon::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 70% 80% at 80% 20%, rgba(153,64,106,.22) 0%, transparent 60%);
            pointer-events: none;
        }
        .stat-item { padding: 32px 28px; text-align: center; border-right: 1px solid rgba(255,255,255,.08); position: relative; }
        .stat-item:last-child { border-right: none; }
        .stat-num { font-family: var(--serif); font-size: 2.8rem; font-weight: 700; color: var(--gold); line-height: 1; margin-bottom: 6px; }
        .stat-desc { font-size: 12.5px; color: rgba(255,255,255,.5); font-weight: 500; text-transform: uppercase; letter-spacing: .8px; }

        /* ══ FACULTY GRID ══ */
        .faculty-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
        .faculty-card {
            background: #fff;
            border-radius: var(--r);
            border: 1px solid var(--border);
            padding: 28px 20px 24px;
            text-align: center;
            position: relative;
            transition: all .3s var(--ease);
            overflow: hidden;
        }
        .faculty-card::before {
            content: '';
            position: absolute;
            bottom: 0; left: 0; right: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--blue), var(--rose-lt));
            transform: scaleX(0);
            transform-origin: left;
            transition: transform .3s var(--ease);
        }
        .faculty-card:hover::before { transform: scaleX(1); }
        .faculty-card:hover { box-shadow: 0 16px 44px rgba(15,23,42,.09); transform: translateY(-4px); border-color: transparent; }
        .faculty-photo {
            width: 86px; height: 86px;
            border-radius: 50%;
            overflow: hidden;
            margin: 0 auto 16px;
            border: 3px solid var(--bg-off);
            box-shadow: 0 6px 20px rgba(15,23,42,.10);
            transition: border-color .3s;
        }
        .faculty-card:hover .faculty-photo { border-color: var(--rose-lt); }
        .faculty-photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
        .faculty-name { font-family: var(--serif); font-size: 16px; font-weight: 700; color: var(--navy); margin-bottom: 4px; line-height: 1.3; }
        .faculty-role { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--rose); margin-bottom: 6px; }
        .faculty-subject {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            border-radius: 100px;
            background: var(--bg-off);
            font-size: 11.5px;
            color: var(--slate);
            margin-bottom: 12px;
        }
        .faculty-subject i { color: var(--blue); font-size: 11px; }
        .faculty-ext { font-size: 12px; color: var(--muted); display: flex; align-items: center; justify-content: center; gap: 5px; }
        .faculty-ext i { color: var(--blue); }

        /* ══ SUPPORT STAFF ══ */
        .support-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
        .support-card {
            border-radius: var(--r);
            padding: 32px 28px;
            border: 1px solid var(--border);
            background: #fff;
            display: flex;
            align-items: center;
            gap: 22px;
            transition: all .3s var(--ease);
        }
        .support-card:hover { box-shadow: 0 16px 44px rgba(15,23,42,.09); transform: translateY(-3px); border-color: transparent; }
        .support-icon-wrap { width: 58px; height: 58px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 22px; color: #fff; flex-shrink: 0; }
        .support-text { flex: 1; }
        .support-text h5 { font-family: var(--serif); font-size: 17px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
        .support-count { font-size: 13px; color: var(--muted); margin-bottom: 8px; }
        .support-bar { height: 4px; border-radius: 2px; background: var(--border); overflow: hidden; width: 100%; }
        .support-bar-fill { height: 100%; border-radius: 2px; background: linear-gradient(90deg, var(--blue), var(--rose-lt)); }

        /* ══ CTA ══ */
        .team-cta {
            position: relative;
            border-radius: 24px;
            overflow: hidden;
            background: var(--navy);
            padding: 64px 56px;
            text-align: center;
            margin: 80px 0;
        }
        .team-cta::before {
            content: '';
            position: absolute;
            inset: 0;
            background:
                radial-gradient(ellipse 60% 70% at 20% 50%, rgba(30,58,138,.5) 0%, transparent 60%),
                radial-gradient(ellipse 50% 60% at 80% 50%, rgba(153,64,106,.4) 0%, transparent 60%);
            pointer-events: none;
        }
        .team-cta-inner { position: relative; z-index: 1; }
        .team-cta-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 6px 14px;
            border-radius: 100px;
            border: 1px solid rgba(255,255,255,.15);
            background: rgba(255,255,255,.07);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: var(--gold);
            margin-bottom: 20px;
        }
        .team-cta h2 { font-family: var(--serif); font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700; color: #fff; margin-bottom: 14px; }
        .team-cta p { font-size: 15px; color: rgba(255,255,255,.6); max-width: 440px; margin: 0 auto 32px; line-height: 1.7; }
        .btn-cta-primary {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 14px 28px; border-radius: 12px;
            background: linear-gradient(135deg, var(--rose), var(--rose-lt));
            color: #fff; font-size: 14px; font-weight: 600;
            text-decoration: none; transition: all .25s var(--ease);
        }
        .btn-cta-primary:hover { opacity: .88; transform: translateY(-2px); box-shadow: 0 12px 28px rgba(153,64,106,.4); color: #fff; }
        .btn-cta-outline {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 14px 28px; border-radius: 12px;
            border: 1px solid rgba(255,255,255,.2);
            color: rgba(255,255,255,.8); background: transparent;
            font-size: 14px; font-weight: 600;
            text-decoration: none; transition: all .25s var(--ease);
        }
        .btn-cta-outline:hover { background: rgba(255,255,255,.1); border-color: rgba(255,255,255,.4); color: #fff; }

        /* ══ RESPONSIVE ══ */
        @media (max-width: 1024px) {
            .faculty-grid { grid-template-columns: repeat(2, 1fr); }
            .stat-ribbon  { grid-template-columns: repeat(2, 1fr); }
            .stat-item:nth-child(2) { border-right: none; }
            .stat-item:nth-child(1), .stat-item:nth-child(2) { border-bottom: 1px solid rgba(255,255,255,.08); }
        }
        @media (max-width: 768px) {
            .principal-card  { grid-template-columns: 1fr; }
            .principal-photo { height: 260px; }
            .admin-grid      { grid-template-columns: 1fr; }
            .support-grid    { grid-template-columns: 1fr; }
            .team-cta        { padding: 48px 28px; }
        }
        @media (max-width: 480px) {
            .faculty-grid { grid-template-columns: 1fr; }
        }
    </style>
{% endblock %}

{% block body %}

    {# ── HERO ── #}
    <section class="team-hero">
        <div class="team-hero-body">
            <div class="container">
                <div data-aos="fade-up">
                    <div class="hero-eyebrow"><i class="bi bi-people-fill"></i> Our People</div>
                    <h1>Meet Our <em>Faculty</em> &amp; Staff</h1>
                    <nav class="team-breadcrumb" aria-label="breadcrumb">
                        <a href="{{ path('app_main') }}"><i class="bi bi-house-door-fill"></i> Home</a>
                        <i class="bi bi-chevron-right"></i>
                        <span>Team</span>
                    </nav>
                </div>
            </div>
        </div>
        <svg class="hero-wave" viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f8fafc"/>
        </svg>
    </section>


    {# ── LEADERSHIP ── #}
    <section class="team-section alt">
        <div class="container">

            <div data-aos="fade-up" style="margin-bottom:40px;">
                <div class="team-label"><i class="bi bi-star-fill"></i> Leadership</div>
                <h2 class="team-heading">Administrative Team</h2>
                <p class="team-sub">Our dedicated leadership ensures academic excellence and institutional growth across every programme.</p>
            </div>

            {# Principal #}
            <div class="principal-card" data-aos="fade-up" data-aos-delay="100">
                <div class="principal-photo">
                    <img src="{{ asset('images/dummy/2.jpg') }}" alt="Principal">
                    <div class="principal-role-tag"><i class="bi bi-award-fill"></i> Principal</div>
                </div>
                <div class="principal-info">
                    <div class="principal-eyebrow">Leading With Vision</div>
                    <h2>Dr. <span>[Principal Name]</span></h2>
                    <p class="principal-degree">Ph.D. in Education &nbsp;&middot;&nbsp; M.Ed. &nbsp;&middot;&nbsp; 20+ Years Experience</p>
                    <p class="principal-quote">
                        "Our mission is to nurture reflective, compassionate educators who will transform classrooms and inspire the next generation."
                    </p>
                    <div class="principal-contacts">
                        <a href="mailto:principal@dietnamchi.org" class="contact-pill">
                            <i class="bi bi-envelope-fill"></i> principal@dietnamchi.org
                        </a>
                        <span class="contact-pill"><i class="bi bi-telephone-fill"></i> Ext. 101</span>
                        <span class="contact-pill"><i class="bi bi-calendar3"></i> Appointment available</span>
                    </div>
                </div>
            </div>

            {# Admin cards #}
            <div class="admin-grid">
                <div class="admin-card" data-aos="fade-up" data-aos-delay="150">
                    <div class="admin-card-top"></div>
                    <div class="admin-card-body">
                        <div class="admin-avatar"><img src="{{ asset('images/dummy/2.jpg') }}" alt="Vice Principal"></div>
                        <div>
                            <div class="admin-role">Vice Principal</div>
                            <div class="admin-name">Dr. [VP Name]</div>
                            <div class="admin-qual">M.Ed., Ph.D. in Education</div>
                            <span class="admin-ext"><i class="bi bi-telephone"></i> Ext. 102</span>
                        </div>
                    </div>
                </div>
                <div class="admin-card" data-aos="fade-up" data-aos-delay="220">
                    <div class="admin-card-top"></div>
                    <div class="admin-card-body">
                        <div class="admin-avatar"><img src="{{ asset('images/dummy/2.jpg') }}" alt="Admin Officer"></div>
                        <div>
                            <div class="admin-role">Administrative Officer</div>
                            <div class="admin-name">Mr./Ms. [AO Name]</div>
                            <div class="admin-qual">MBA, M.Com</div>
                            <span class="admin-ext"><i class="bi bi-telephone"></i> Ext. 103</span>
                        </div>
                    </div>
                </div>
                <div class="admin-card" data-aos="fade-up" data-aos-delay="290">
                    <div class="admin-card-top"></div>
                    <div class="admin-card-body">
                        <div class="admin-avatar"><img src="{{ asset('images/dummy/2.jpg') }}" alt="Training Coordinator"></div>
                        <div>
                            <div class="admin-role">Training Coordinator</div>
                            <div class="admin-name">Dr. [TC Name]</div>
                            <div class="admin-qual">M.Ed., NET Qualified</div>
                            <span class="admin-ext"><i class="bi bi-telephone"></i> Ext. 104</span>
                        </div>
                    </div>
                </div>
            </div>

            {# Stats #}
            <div class="stat-ribbon" data-aos="fade-up">
                <div class="stat-item"><div class="stat-num">16+</div><div class="stat-desc">Faculty Members</div></div>
                <div class="stat-item"><div class="stat-num">25+</div><div class="stat-desc">Years of Excellence</div></div>
                <div class="stat-item"><div class="stat-num">98%</div><div class="stat-desc">PG / PhD Qualified</div></div>
                <div class="stat-item"><div class="stat-num">500+</div><div class="stat-desc">Educators Trained</div></div>
            </div>

        </div>
    </section>


    {# ── FACULTY ── #}
    <section class="team-section">
        <div class="container">

            <div data-aos="fade-up" style="margin-bottom:40px;">
                <div class="team-label"><i class="bi bi-mortarboard-fill"></i> Academic Faculty</div>
                <h2 class="team-heading">Our Expert Faculty</h2>
                <p class="team-sub">Learn from experienced educators dedicated to your professional growth and development.</p>
            </div>

            <div class="faculty-grid">

                <div class="faculty-card" data-aos="fade-up" data-aos-delay="80">
                    <div class="faculty-photo"><img src="{{ asset('images/dummy/2.jpg') }}" alt="Faculty"></div>
                    <div class="faculty-name">Dr. [Faculty Name]</div>
                    <div class="faculty-role">Associate Professor</div>
                    <div class="faculty-subject"><i class="bi bi-brain"></i> Educational Psychology</div>
                    <div class="faculty-ext"><i class="bi bi-telephone"></i> Ext. 105</div>
                </div>

                <div class="faculty-card" data-aos="fade-up" data-aos-delay="140">
                    <div class="faculty-photo"><img src="{{ asset('images/dummy/2.jpg') }}" alt="Faculty"></div>
                    <div class="faculty-name">Mr./Ms. [Faculty Name]</div>
                    <div class="faculty-role">Assistant Professor</div>
                    <div class="faculty-subject"><i class="bi bi-journal-richtext"></i> Curriculum Dev.</div>
                    <div class="faculty-ext"><i class="bi bi-telephone"></i> Ext. 106</div>
                </div>

                <div class="faculty-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="faculty-photo"><img src="{{ asset('images/dummy/2.jpg') }}" alt="Faculty"></div>
                    <div class="faculty-name">Mr./Ms. [Faculty Name]</div>
                    <div class="faculty-role">Assistant Professor</div>
                    <div class="faculty-subject"><i class="bi bi-laptop"></i> ICT in Education</div>
                    <div class="faculty-ext"><i class="bi bi-telephone"></i> Ext. 107</div>
                </div>

