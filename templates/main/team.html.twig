                        <p class="small text-muted mb-0">3 Members</p>
                    </div>
                </div>
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #8b5cf6, #ec4899);">
