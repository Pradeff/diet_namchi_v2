                        <img src="{{ asset('images/dummy/2.jpg') }}" alt="Faculty" class="rounded-circle mb-3 mx-auto" style="width: 100px; height: 100px; object-fit: cover; border: 3px solid var(--bg-soft);">
                        <h5 class="mb-1">Dr. [Faculty Name]</h5>
