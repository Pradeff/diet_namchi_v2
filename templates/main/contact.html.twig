{# main/contact.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Contact DIET Namchi{% endblock %}

{% block body %}
    <!-- Compact Hero/Breadcrumb Section -->
    <section class="compact-hero" style="background-image: url('{{ asset('images/dummy/1.webp') }}');">
        <div class="compact-hero-overlay"></div>
        <div class="container h-100">
            <div class="row h-100 align-items-center">
                <div class="col-12" data-aos="fade-up">
                    <div class="compact-hero-content">
                        <span class="compact-hero-badge">
                            <i class="bi bi-geo-alt"></i> Get in Touch
                        </span>
                        <h1 class="compact-hero-title">We're Here to Help</h1>
                        <nav aria-label="breadcrumb" class="compact-breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_main') }}" class="text-white">
                                        <i class="bi bi-house-door"></i> Home
                                    </a>
                                </li>
                                <li class="breadcrumb-item active text-white-50" aria-current="page">Contact</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Info Cards -->
    <section class="section-padding">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-telephone"></i> Contact Information
                </span>
                <h2 class="section-title">Reach Out to Us</h2>
                <p>Have questions about admissions, programs, or partnerships? We'd love to hear from you.</p>
            </div>

            <div class="row g-4">
                <!-- Address Card -->
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <h4 class="feature-title">Visit Us</h4>
                        <p class="mb-0">Namchi, South Sikkim<br>737126, India</p>
                        <a href="https://maps.google.com/?q=DIET+Namchi" target="_blank" class="program-link mt-2">
                            View on Map <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Phone Card -->
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-telephone-fill"></i>
                        </div>
                        <h4 class="feature-title">Call Us</h4>
                        <p class="mb-0">
                            <a href="tel:03595264521" class="text-decoration-none text-body">03595-264521</a><br>
                            <small class="text-muted">Mon-Sat: 10AM-5PM</small>
                        </p>
                        <a href="tel:03595264521" class="program-link mt-2">
                            Call Now <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Email Card -->
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-envelope-fill"></i>
                        </div>
                        <h4 class="feature-title">Email Us</h4>
                        <p class="mb-0">
                            <a href="mailto:dietnamchi12@gmail.com" class="text-decoration-none text-body">dietnamchi12@gmail.com</a><br>
                            <small class="text-muted">Response within 24h</small>
                        </p>
                        <a href="mailto:dietnamchi12@gmail.com" class="program-link mt-2">
                            Send Email <i class="bi bi-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Hours Card -->
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-clock-fill"></i>
                        </div>
                        <h4 class="feature-title">Office Hours</h4>
                        <p class="mb-0">
                            Monday - Friday: 10AM-5PM<br>
                            Saturday: 10AM-1PM<br>
                            <small class="text-muted">Sunday: Closed</small>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Map & Location Section -->
    <section class="section-padding bg-light-section">
        <div class="container">
            <div class="row g-5 align-items-center">
                <!-- Map -->
                <div class="col-lg-7" data-aos="fade-right">
                    <div class="rounded-4 overflow-hidden shadow-soft" style="height: 380px; background: var(--bg-soft);">
                        <iframe
                            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3555.123456789!2d88.364!3d27.166!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMjfCsDA5JzU3LjYiTiA4OMKwMjEnNTAuNCJF!5e0!3m2!1sen!2sin!4v1234567890"
                            width="100%"
                            height="100%"
                            style="border:0;"
                            allowfullscreen=""
                            loading="lazy"
                            title="DIET Namchi Location">
                        </iframe>
                    </div>
                </div>

                <!-- Location Details -->
                <div class="col-lg-5" data-aos="fade-left">
                    <span class="section-subtitle">
                        <i class="bi bi-map"></i> Our Location
                    </span>
                    <h2 class="section-title mb-4">Find Us in Namchi</h2>
                    <p class="mb-4">DIET Namchi is conveniently located in the heart of South Sikkim, easily accessible from Gangtok and surrounding districts.</p>

                    <div class="feature-card mb-3">
                        <div class="d-flex gap-3">
                            <div class="feature-icon" style="width: 48px; height: 48px; font-size: 20px; margin-bottom: 0;">
                                <i class="bi bi-train-front"></i>
                            </div>
                            <div>
                                <strong class="d-block">By Train</strong>
                                <small class="text-muted">New Jalpaiguri (NJP) - 140km<br>Then taxi/bus to Namchi</small>
                            </div>
                        </div>
                    </div>

                    <div class="feature-card mb-3">
                        <div class="d-flex gap-3">
                            <div class="feature-icon" style="width: 48px; height: 48px; font-size: 20px; margin-bottom: 0;">
                                <i class="bi bi-airplane"></i>
                            </div>
                            <div>
                                <strong class="d-block">By Air</strong>
                                <small class="text-muted">Pakyong Airport - 65km<br>Bagdogra Airport - 150km</small>
                            </div>
                        </div>
                    </div>

                    <div class="feature-card">
                        <div class="d-flex gap-3">
                            <div class="feature-icon" style="width: 48px; height: 48px; font-size: 20px; margin-bottom: 0;">
                                <i class="bi bi-bus-front"></i>
                            </div>
                            <div>
                                <strong class="d-block">By Road</strong>
                                <small class="text-muted">Regular buses from Gangtok<br>Taxi services available</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Contact Options -->
    <section class="section-padding">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-chat-dots"></i> Quick Contact
                </span>
                <h2 class="section-title">Connect Your Way</h2>
                <p>Choose your preferred method to reach us</p>
            </div>

            <div class="row g-4 justify-content-center">
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="100">
                    <a href="tel:03595264521" class="feature-card text-center text-decoration-none h-100">
                        <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #10b981, #059669);">
                            <i class="bi bi-telephone"></i>
                        </div>
                        <h4 class="feature-title">Phone Call</h4>
                        <p class="mb-0">Speak directly with our team</p>
                    </a>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="200">
                    <a href="mailto:dietnamchi12@gmail.com" class="feature-card text-center text-decoration-none h-100">
                        <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8);">
                            <i class="bi bi-envelope"></i>
                        </div>
                        <h4 class="feature-title">Email</h4>
                        <p class="mb-0">Send detailed inquiries</p>
                    </a>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="300">
                    <a href="https://wa.me/919876543210" target="_blank" class="feature-card text-center text-decoration-none h-100">
                        <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #25d366, #128c7e);">
                            <i class="bi bi-whatsapp"></i>
                        </div>
                        <h4 class="feature-title">WhatsApp</h4>
                        <p class="mb-0">Quick chat support</p>
                    </a>
                </div>
                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="400">
                    <a href="#faq" class="feature-card text-center text-decoration-none h-100">
                        <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                            <i class="bi bi-question-circle"></i>
                        </div>
                        <h4 class="feature-title">FAQs</h4>
                        <p class="mb-0">Find instant answers</p>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="section-padding bg-light-section">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-question-circle"></i> FAQs
                </span>
                <h2 class="section-title">Common Questions</h2>
            </div>

            <div class="accordion" id="contactFaq" data-aos="fade-up">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">
                            What documents do I need for admission inquiry?
                        </button>
                    </h2>
                    <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#contactFaq">
                        <div class="accordion-body">
                            For admission inquiries, please have your educational certificates, ID proof, and passport-size photographs ready. Our team will guide you through the exact requirements based on your chosen program.
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">
                            How long does it take to get a response?
                        </button>
                    </h2>
                    <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#contactFaq">
                        <div class="accordion-body">
                            We aim to respond to all inquiries within 24 working hours. For urgent matters, please call our office directly during working hours.
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">
                            Can I visit the campus without an appointment?
                        </button>
                    </h2>
                    <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#contactFaq">
                        <div class="accordion-body">
                            Yes, campus visits are welcome during office hours. However, for personalized guidance, we recommend scheduling an appointment in advance by calling or emailing us.
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">
                            Do you offer virtual counseling sessions?
                        </button>
                    </h2>
                    <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#contactFaq">
                        <div class="accordion-body">
                            Yes! We offer virtual counseling via video call for prospective students outside Sikkim. Request this option when you call or email us.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div data-aos="fade-up">
                <span class="section-subtitle mb-3">
                    <i class="bi bi-hand-thumbs-up"></i> Start Your Journey
                </span>
                <h2 class="mb-3">Ready to Join DIET Namchi?</h2>
                <p class="mx-auto mb-4">Explore our NCTE-recognized programs and become part of Sikkim's educational transformation.</p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="{{ path('app_main') }}" class="btn-apply">Explore Programs</a>
                    <a href="tel:03595264521" class="btn btn-outline-primary px-4 py-2 rounded-pill">
                        <i class="bi bi-telephone me-1"></i> Call Now
                    </a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
