{# main/contact.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Contact DIET Namchi{% endblock %}

{% block body %}
    <!-- Compact Hero/Breadcrumb Section -->
    <section class="compact-hero" style="background-image: url('{{ asset('images/breadcrumb.webp') }}');">
        <div class="compact-hero-overlay"></div>
        <div class="container h-100">
            <div class="row h-100 align-items-center">
                <div class="col-12" data-aos="fade-up">
                    <div class="compact-hero-content">
                        <span class="compact-hero-badge">
                            <i class="bi bi-geo-alt"></i> Get in Touch
                        </span>
                        <h1 class="compact-hero-title">We're Here to Help</h1>
                        <nav aria-label="breadcrumb" class="compact-breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_main') }}" class="text-white">
                                        <i class="bi bi-house-door"></i> Home
                                    </a>
                                </li>
                                <li class="breadcrumb-item active text-white-50" aria-current="page">Contact</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Info Cards -->
    <section class="section-padding">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-telephone"></i> Contact Information
                </span>
                <h2 class="section-title">Reach Out to Us</h2>
                <p>Have questions about admissions, programs, or partnerships? We'd love to hear from you.</p>
            </div>

            <div class="row g-4">
                <!-- Address Card -->
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <h4 class="feature-title">Visit Us</h4>
                        <p class="mb-0">
                            {% if global_contact and global_contact.address %}
                                {{ global_contact.address|nl2br }}
                            {% else %}

                            {% endif %}
                        </p>
                        {% if global_contact and global_contact.map %}
                            {# Extract src URL from the stored <iframe> string #}
                            {% set map_src = global_contact.map|replace({'<iframe': '', '</iframe>': ''})|trim %}
                            {% set map_src = map_src|split('src="')[1]|split('"')[0] %}

                        {% else %}

                        {% endif %}
                    </div>
                </div>

                <!-- Phone Card -->
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-telephone-fill"></i>
                        </div>
                        <h4 class="feature-title">Call Us</h4>
                        <p class="mb-0">
                            {% if global_contact and global_contact.phone1 %}
                                <a href="tel:{{ global_contact.phone1 }}" class="text-decoration-none text-body">{{ global_contact.phone1 }}</a>
                            {% endif %}
                            {% if global_contact and global_contact.phone2 %}
                                <br><a href="tel:{{ global_contact.phone2 }}" class="text-decoration-none text-body">{{ global_contact.phone2 }}</a>
                            {% endif %}
                            {% if global_contact and global_contact.phone3 %}
                                <br><a href="tel:{{ global_contact.phone3 }}" class="text-decoration-none text-body">{{ global_contact.phone3 }}</a>
                            {% endif %}
                            {% if global_contact and global_contact.opentime %}
                                <br><small class="text-muted">{{ global_contact.opentime }}</small>
                            {% else %}
                                <br><small class="text-muted"></small>
                            {% endif %}
                        </p>
                        {% if global_contact and global_contact.phone1 %}
                            <a href="tel:{{ global_contact.phone1 }}" class="program-link mt-2">
                                Call Now <i class="bi bi-arrow-right"></i>
                            </a>
                        {% endif %}
                    </div>
                </div>

                <!-- Email Card -->
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-envelope-fill"></i>
                        </div>
                        <h4 class="feature-title">Email Us</h4>
                        <p class="mb-0">
                            {% if global_contact and global_contact.email1 %}
                                <a href="mailto:{{ global_contact.email1 }}" class="text-decoration-none text-body">{{ global_contact.email1 }}</a>
                            {% endif %}
                            {% if global_contact and global_contact.email2 %}
                                <br><a href="mailto:{{ global_contact.email2 }}" class="text-decoration-none text-body">{{ global_contact.email2 }}</a>
                            {% endif %}
                            <br><small class="text-muted">Response within 24h</small>
                        </p>
                        {% if global_contact and global_contact.email1 %}
                            <a href="mailto:{{ global_contact.email1 }}" class="program-link mt-2">
                                Send Email <i class="bi bi-arrow-right"></i>
                            </a>
                        {% endif %}
                    </div>
                </div>

                <!-- Hours Card -->
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-clock-fill"></i>
                        </div>
                        <h4 class="feature-title">Office Hours</h4>
                        <p class="mb-0">
                            {% if global_contact and global_contact.opentime %}
                                {{ global_contact.opentime|nl2br }}
                            {% else %}

                            {% endif %}
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Map & Location Section -->
    <section class="section-padding bg-light-section">
        <div class="container">
            <div class="row g-5 align-items-center">
                <!-- Map -->
                <div class="col-lg-7" data-aos="fade-right">
                    <div class="rounded-4 overflow-hidden shadow-soft" style="height: 380px; background: var(--bg-soft);">
                        {% if global_contact and global_contact.map %}
                            {# Extract src from stored <iframe> HTML string #}
                            {% set map_src = global_contact.map|split('src="')[1]|split('"')[0] %}
                            <iframe
                                src="{{ map_src }}"
                                width="100%"
                                height="100%"
                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"
                                title="DIET Namchi Location">
                            </iframe>
                        {% else %}

                        {% endif %}
                    </div>
                </div>

                <!-- Location Details -->
                <div class="col-lg-5" data-aos="fade-left">
                    <span class="section-subtitle">
                        <i class="bi bi-map"></i> Our Location
                    </span>
                    <h2 class="section-title mb-4">Find Us in Namchi</h2>
                    <p class="mb-4">DIET Namchi is conveniently located in the heart of South Sikkim, easily accessible from Gangtok and surrounding districts.</p>

                    <div class="feature-card mb-3">
                        <div class="d-flex gap-3">
                            <div class="feature-icon" style="width: 48px; height: 48px; font-size: 20px; margin-bottom: 0;">
                                <i class="bi bi-train-front"></i>
                            </div>
                            <div>
                                <strong class="d-block">By Train</strong>
                                <small class="text-muted">New Jalpaiguri (NJP) - 140km<br>Then taxi/bus to Namchi</small>
                            </div>
                        </div>
                    </div>

                    <div class="feature-card mb-3">
                        <div class="d-flex gap-3">
                            <div class="feature-icon" style="width: 48px; height: 48px; font-size: 20px; margin-bottom: 0;">
                                <i class="bi bi-airplane"></i>
                            </div>
                            <div>
                                <strong class="d-block">By Air</strong>
                                <small class="text-muted">Pakyong Airport - 65km<br>Bagdogra Airport - 103km</small>
                            </div>
                        </div>
                    </div>

                    <div class="feature-card">
                        <div class="d-flex gap-3">
                            <div class="feature-icon" style="width: 48px; height: 48px; font-size: 20px; margin-bottom: 0;">
                                <i class="bi bi-bus-front"></i>
                            </div>
                            <div>
                                <strong class="d-block">By Road</strong>
                                <small class="text-muted">Regular buses from Gangtok<br>Taxi services available</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Quick Contact Options -->
    <section class="section-padding">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-chat-dots"></i> Quick Contact
                </span>
                <h2 class="section-title">Connect Your Way</h2>
                <p>Choose your preferred method to reach us</p>
            </div>

            <div class="row g-4 justify-content-center">
                {% if global_contact and global_contact.phone1 %}
                    <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="100">
                        <a href="tel:{{ global_contact.phone1 }}" class="feature-card text-center text-decoration-none h-100">
                            <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #10b981, #059669);">
                                <i class="bi bi-telephone"></i>
                            </div>
                            <h4 class="feature-title">Phone Call</h4>
                            <p class="mb-0">Speak directly with our team</p>
                        </a>
                    </div>
                {% endif %}

                {% if global_contact and global_contact.email1 %}
                    <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="200">
                        <a href="mailto:{{ global_contact.email1 }}" class="feature-card text-center text-decoration-none h-100">
                            <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #3b82f6, #1d4ed8);">
                                <i class="bi bi-envelope"></i>
                            </div>
                            <h4 class="feature-title">Email</h4>
                            <p class="mb-0">Send detailed inquiries</p>
                        </a>
                    </div>
                {% endif %}

                {% if global_contact and global_contact.phone1 %}
                    <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="300">
                        <a href="https://wa.me/{{ global_contact.phone2|replace({'+': '', ' ': '', '-': ''}) }}"
                           target="_blank" class="feature-card text-center text-decoration-none h-100">
                            <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #25d366, #128c7e);">
                                <i class="bi bi-whatsapp"></i>
                            </div>
                            <h4 class="feature-title">WhatsApp</h4>
                            <p class="mb-0">Quick chat support</p>
                        </a>
                    </div>
                {% endif %}

                <div class="col-6 col-md-3" data-aos="zoom-in" data-aos-delay="400">
                    <a href="#faq" class="feature-card text-center text-decoration-none h-100">
                        <div class="feature-icon mx-auto" style="background: linear-gradient(135deg, #f59e0b, #d97706);">
                            <i class="bi bi-question-circle"></i>
                        </div>
                        <h4 class="feature-title">FAQs</h4>
                        <p class="mb-0">Find instant answers</p>
                    </a>
                </div>
            </div>

            {# Social links — only rendered if at least one is set #}
            {% if global_contact and (global_contact.fb or global_contact.insta or global_contact.yt or global_contact.tw or global_contact.linkedin or global_contact.telegram) %}
                <div class="row g-3 justify-content-center mt-2">
                    {% if global_contact.fb %}
                        <div class="col-auto" data-aos="zoom-in" data-aos-delay="100">
                            <a href="{{ global_contact.fb }}" target="_blank" class="feature-card text-center text-decoration-none px-4 py-3 d-flex align-items-center gap-2">
                                <i class="bi bi-facebook"></i> Facebook
                            </a>
                        </div>
                    {% endif %}
                    {% if global_contact.insta %}
                        <div class="col-auto" data-aos="zoom-in" data-aos-delay="150">
                            <a href="{{ global_contact.insta }}" target="_blank" class="feature-card text-center text-decoration-none px-4 py-3 d-flex align-items-center gap-2">
                                <i class="bi bi-instagram"></i> Instagram
                            </a>
                        </div>
                    {% endif %}
                    {% if global_contact.yt %}
                        <div class="col-auto" data-aos="zoom-in" data-aos-delay="200">
                            <a href="{{ global_contact.yt }}" target="_blank" class="feature-card text-center text-decoration-none px-4 py-3 d-flex align-items-center gap-2">
                                <i class="bi bi-youtube"></i> YouTube
                            </a>
                        </div>
                    {% endif %}
                    {% if global_contact.tw %}
                        <div class="col-auto" data-aos="zoom-in" data-aos-delay="250">
                            <a href="{{ global_contact.tw }}" target="_blank" class="feature-card text-center text-decoration-none px-4 py-3 d-flex align-items-center gap-2">
                                <i class="bi bi-twitter-x"></i> Twitter/X
                            </a>
                        </div>
                    {% endif %}
                    {% if global_contact.linkedin %}
                        <div class="col-auto" data-aos="zoom-in" data-aos-delay="300">
                            <a href="{{ global_contact.linkedin }}" target="_blank" class="feature-card text-center text-decoration-none px-4 py-3 d-flex align-items-center gap-2">
                                <i class="bi bi-linkedin"></i> LinkedIn
                            </a>
                        </div>
                    {% endif %}
                    {% if global_contact.telegram %}
                        <div class="col-auto" data-aos="zoom-in" data-aos-delay="350">
                            <a href="{{ global_contact.telegram }}" target="_blank" class="feature-card text-center text-decoration-none px-4 py-3 d-flex align-items-center gap-2">
                                <i class="bi bi-telegram"></i> Telegram
                            </a>
                        </div>
                    {% endif %}
                </div>
            {% endif %}

        </div>
    </section>

    {{ render(controller('App\\Controller\\MainController::SecFaq')) }}

{% endblock %}
