    <section class="section-padding notices-section">
        <div class="container">
            <div class="row align-items-start">
                <div class="col-lg-4 mb-5 mb-lg-0" data-aos="fade-right">
                    <span class="section-subtitle">Stay Updated</span>
                    <h4>Latest News & Announcements</h4>
                    <p class="mb-4">
                        Get the latest updates about admissions, examinations, workshops, and important notices.
                    </p>
                    <a href="#" class="btn-hero-primary">View All Notices</a>
                </div>
                <div class="col-lg-8" data-aos="fade-left">
                    <div class="notices-slider">
                        <div class="notice-item">
                            {#<div class="notice-date-box">
                                <span class="notice-day">01</span>
                                <span class="notice-month">Mar</span>
                            </div>#}
                            <div class="notice-content">
                                <h5 class="fst-italic text-primary">Date and Time </h5>
                                <h5>Admission Open for D.El.Ed 2026-28</h5>
                                <p>Applications are now invited for Diploma in Elementary Education program. Last date: March 31, 2026.</p>
                                <a href="#" target="_blank" class="program-link">Download File <i class="bi bi-download"></i></a>
                            </div>
                        </div>

                        <div class="notice-item">
                            <div class="notice-date-box">
                                <span class="notice-day">25</span>
                                <span class="notice-month">Feb</span>
                            </div>
                            <div class="notice-content">
                                <h5>In-Service Training Workshop</h5>
                                <p>5-day workshop on ICT Integration in Teaching from March 10-15, 2026. Registration open.</p>
                            </div>
                        </div>

                        <div class="notice-item">
                            <div class="notice-date-box">
                                <span class="notice-day">20</span>
                                <span class="notice-month">Feb</span>
                            </div>
                            <div class="notice-content">
                                <h5>Result Declared - B.Ed Semester II</h5>
                                <p>Results for B.Ed Semester II examination now available on student portal.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <section class="cta-section border-top">
        <div class="container">
            <div data-aos="fade-up">
            <span class="section-subtitle mb-3">
                <i class="bi bi-hand-thumbs-up"></i> Start Your Journey
            </span>
                <h2 class="mb-3">Ready to Join DIET Namchi?</h2>
                <p class="mx-auto mb-4">Explore our NCTE-recognized programs and become part of Sikkim's
                    educational transformation.</p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="{{ path('app_main') }}" class="btn-apply">Explore Programs</a>
                    <a href="tel:03595264521" class="btn btn-outline-primary px-4 py-2 rounded-pill">
                        <i class="bi bi-telephone me-1"></i> Call Now
                    </a>
                </div>
            </div>
        </div>
    </section>

    {{ include('main/_staff_section.html.twig') }}
    {{ include('main/_faq_section.html.twig') }}

{% endblock %}
