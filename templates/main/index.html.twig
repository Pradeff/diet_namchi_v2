{% extends 'base.html.twig' %}

{% block title %}DIET{% endblock %}

{% block body %}
    <div class="container-fluid px-0">
        <div class="row g-0">
            <div class="col-lg-9 col-md-8 col-12">
                {{ render(controller('App\\Controller\\VsliderController::HomeSlider')) }}
            </div>
            <div class="col-lg-3 col-md-4 col-12">
                {{ render(controller('App\\Controller\\VpeopleController::CM')) }}

                {% set default_principal = {
                    title: 'Mrs. Bandana Rai',
                    designation: 'Principal, DIET Namchi',
                    image: asset('images/default.webp'),
                    description: 'Welcome to DIET Namchi. We are committed to nurturing future educators with quality training...'
                } %}

                {% set principal = vteams[0] ?? app.request.attributes.get('principal') ?? default_principal %}

                <div class="principal-card-profile mb-4" data-aos="fade-left">
                    <div class="principal-cover-wrapper">
                        <img src="{{ asset('uploads/image/' ~ principal.image) }}" alt="{{ principal.title }}">
                        <div class="principal-cover-overlay"></div>
                    </div>

                    <div class="principal-profile-inner">
                        <div class="principal-avatar-wrapper">
                            <div class="principal-avatar-ring">
                                <img src="{{ asset('uploads/image/' ~ principal.image) }}" alt="{{ principal.title }}">
                            </div>
                        </div>

                        <button class="principal-chip-role">
                            <i class="bi bi-mortarboard"></i>
                            {{ principal.designation|default(default_principal.designation) }}
                        </button>

                        <h3 class="principal-profile-name">{{ principal.title|default(default_principal.title) }}</h3>
                        <p class="principal-sub-text">
                            {{ principal.description|default(default_principal.description)|slice(0, 200)|raw ~ '...' }}
                        </p>
                        <a href="{{ path('app_team') }}" class="principal-cta">
                            Read Full Message
                            <i class="bi bi-arrow-right-short"></i>
                        </a>
                    </div>
                </div>


            </div>
        </div>
    </div>

    <section class="why-choose-section">
        <div class="container">

            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">Why Choose Us</span>
                <h2 class="section-title">Excellence in Teacher Education</h2>
                <p>
                    We provide world-class teacher training programs with modern infrastructure and
                    experienced faculty dedicated to your growth.
                </p>
            </div>

            <!-- Grid Container -->
            <div class="features-grid">

                <!-- Item 1 -->
                <div class="feature-card" data-aos="fade-up" data-aos-delay="0">
                    <div class="feature-icon-wrapper">
                        <i class="bi bi-award"></i>
                    </div>
                    <h3 class="feature-title">Quality Programs</h3>
                    <p>
                        NCTE recognized D.El.Ed and B.Ed programs designed to meet modern educational standards and NEP
                        2020 guidelines.
                    </p>
                </div>

                <!-- Item 2 -->
                <div class="feature-card" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-icon-wrapper">
                        <i class="bi bi-people"></i>
                    </div>
                    <h3 class="feature-title">Expert Faculty</h3>
                    <p>
                        Learn from experienced educators and subject matter experts dedicated to your professional
                        growth.
                    </p>
                </div>

                <!-- Item 3 -->
                <div class="feature-card" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-icon-wrapper">
                        <i class="bi bi-building"></i>
                    </div>
                    <h3 class="feature-title">Modern Infrastructure</h3>
                    <p>
                        State-of-the-art classrooms, ICT labs, library, and digital resources for enhanced learning.
                    </p>
                </div>

                <!-- Item 4 -->
                <div class="feature-card" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-icon-wrapper">
                        <i class="bi bi-patch-check"></i>
                    </div>
                    <h3 class="feature-title">Recognized</h3>
                    <p>
                        Fully recognized by NCTE and affiliated with SCERT, ensuring valid and valuable certifications.
                    </p>
                </div>

            </div>
        </div>
    </section>

