{# main/vision-mission.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Vision & Mission - DIET Namchi{% endblock %}

{% block body %}
    <!-- Compact Hero/Breadcrumb Section -->
    <section class="compact-hero" style="background-image: url('{{ asset('images/dummy/2.jpg') }}');">
        <div class="compact-hero-overlay"></div>
        <div class="container h-100">
            <div class="row h-100 align-items-center">
                <div class="col-12" data-aos="fade-up">
                    <div class="compact-hero-content">
                        <span class="compact-hero-badge">
                            <i class="bi bi-lightbulb"></i> Our Direction
                        </span>
                        <h1 class="compact-hero-title">Vision & Mission</h1>
                        <nav aria-label="breadcrumb" class="compact-breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_main') }}" class="text-white">
                                        <i class="bi bi-house-door"></i> Home
                                    </a>
                                </li>
                                <li class="breadcrumb-item active text-white-50" aria-current="page">Vision & Mission</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Vision & Mission Section -->
    <section class="section-padding">
        <div class="container">
            <div class="row g-5">
                <!-- Vision -->
                <div class="col-lg-6" data-aos="fade-right">
                    <div class="feature-card h-100">
                        <div class="feature-icon">
                            <i class="bi bi-eye"></i>
                        </div>
                        <h3 class="feature-title">Our Vision</h3>
                        <p class="lead text-primary mb-4">To be the premier teacher training institute in South Sikkim, fostering inclusive, quality education for a progressive tomorrow.</p>
                        <p>We envision a future where every child in Sikkim learns from inspired, well-equipped educators who are committed to excellence, innovation, and holistic development. DIET Namchi strives to be a center of educational innovation that sets benchmarks for teacher education across the Northeast region.</p>

                        <h5 class="mt-4 mb-3">Vision Pillars:</h5>
                        <ul class="list-unstyled">
                            <li class="d-flex gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <span>Regional center of educational innovation and research</span>
                            </li>
                            <li class="d-flex gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <span>Research-driven teaching methodologies and practices</span>
                            </li>
                            <li class="d-flex gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <span>Sustainable impact on Sikkim's education ecosystem</span>
                            </li>
                            <li class="d-flex gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <span>Inclusive education accessible to all communities</span>
                            </li>
                            <li class="d-flex gap-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <span>Technology-enabled learning environments</span>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Mission -->
                <div class="col-lg-6" data-aos="fade-left">
                    <div class="feature-card h-100">
                        <div class="feature-icon">
                            <i class="bi bi-bullseye"></i>
                        </div>
                        <h3 class="feature-title">Our Mission</h3>
                        <p class="lead text-primary mb-4">To prepare competent, compassionate educators equipped with innovative teaching skills and modern pedagogical practices for Sikkim's schools.</p>
                        <p>DIET Namchi is dedicated to nurturing future educators through comprehensive training programs that emphasize critical thinking, cultural sensitivity, technological proficiency, and student-centered pedagogy aligned with NEP 2020 frameworks.</p>

                        <h5 class="mt-4 mb-3">Mission Objectives:</h5>
                        <ul class="list-unstyled">
                            <li class="d-flex gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <span>Student-centered pedagogical training programs</span>
                            </li>
                            <li class="d-flex gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <span>Integration of technology in education and teaching</span>
                            </li>
                            <li class="d-flex gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <span>Community engagement and inclusive practices</span>
                            </li>
                            <li class="d-flex gap-2 mb-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <span>Continuous professional development for educators</span>
                            </li>
                            <li class="d-flex gap-2">
                                <i class="bi bi-check-circle-fill text-success mt-1"></i>
                                <span>Quality assurance and academic excellence</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Values -->
    <section class="section-padding bg-light-section">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-heart"></i> Our Foundation
                </span>
                <h2 class="section-title">Core Values</h2>
                <p>The principles that guide everything we do at DIET Namchi</p>
            </div>

            <div class="row g-4">
                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="100">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-star"></i>
                        </div>
                        <h5 class="mb-2">Excellence</h5>
                        <p class="small text-muted mb-0">Commitment to the highest standards in teacher education and professional development.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="200">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-people"></i>
                        </div>
                        <h5 class="mb-2">Inclusivity</h5>
                        <p class="small text-muted mb-0">Ensuring education is accessible and equitable for all communities and learners.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="300">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-lightbulb"></i>
                        </div>
                        <h5 class="mb-2">Innovation</h5>
                        <p class="small text-muted mb-0">Embracing new ideas, technologies, and methodologies in education.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="400">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <h5 class="mb-2">Integrity</h5>
                        <p class="small text-muted mb-0">Upholding ethical standards and transparency in all institutional practices.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="500">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-flower1"></i>
                        </div>
                        <h5 class="mb-2">Compassion</h5>
                        <p class="small text-muted mb-0">Nurturing educators who care deeply about student wellbeing and development.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="600">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-book"></i>
                        </div>
                        <h5 class="mb-2">Lifelong Learning</h5>
                        <p class="small text-muted mb-0">Promoting continuous growth and development for educators and students alike.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="700">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-globe"></i>
                        </div>
                        <h5 class="mb-2">Community</h5>
                        <p class="small text-muted mb-0">Building strong partnerships with schools, parents, and local communities.</p>
                    </div>
                </div>

                <div class="col-md-6 col-lg-3" data-aos="fade-up" data-aos-delay="800">
                    <div class="feature-card text-center">
                        <div class="feature-icon mx-auto">
                            <i class="bi bi-trophy"></i>
                        </div>
                        <h5 class="mb-2">Accountability</h5>
                        <p class="small text-muted mb-0">Taking responsibility for outcomes and continuous improvement.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Strategic Goals -->
    <section class="section-padding">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-graph-up"></i> Strategic Focus
                </span>
                <h2 class="section-title">Strategic Goals 2026-2030</h2>
            </div>

            <div class="row g-4">
                <div class="col-lg-6" data-aos="fade-up" data-aos-delay="100">
                    <div class="notice-item">
                        <div class="notice-date-box">
                            <span class="notice-day">01</span>
                            <span class="notice-month">Goal</span>
                        </div>
                        <div class="notice-content">
                            <h5>Expand Program Offerings</h5>
                            <p>Introduce new specialized courses in early childhood education, special needs education, and educational technology by 2028.</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6" data-aos="fade-up" data-aos-delay="200">
                    <div class="notice-item">
                        <div class="notice-date-box">
                            <span class="notice-day">02</span>
                            <span class="notice-month">Goal</span>
                        </div>
                        <div class="notice-content">
                            <h5>Digital Infrastructure</h5>
                            <p>Establish a fully digital learning environment with smart classrooms, online learning platforms, and digital resource libraries.</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6" data-aos="fade-up" data-aos-delay="300">
                    <div class="notice-item">
                        <div class="notice-date-box">
                            <span class="notice-day">03</span>
                            <span class="notice-month">Goal</span>
                        </div>
                        <div class="notice-content">
                            <h5>Research & Development</h5>
                            <p>Establish a dedicated research center for educational innovation and publish annual research journals.</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6" data-aos="fade-up" data-aos-delay="400">
                    <div class="notice-item">
                        <div class="notice-date-box">
                            <span class="notice-day">04</span>
                            <span class="notice-month">Goal</span>
                        </div>
                        <div class="notice-content">
                            <h5>Community Outreach</h5>
                            <p>Reach 10,000+ teachers through in-service training programs and community education initiatives annually.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div data-aos="fade-up">
                <span class="section-subtitle mb-3">
                    <i class="bi bi-hand-thumbs-up"></i> Be Part of Our Vision
                </span>
                <h2 class="mb-3">Join Us in Transforming Education</h2>
                <p class="mx-auto mb-4">Together, we can build a brighter future for Sikkim's children through quality teacher education.</p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="{{ path('app_admission') }}" class="btn-apply">Apply Now</a>
                    <a href="{{ path('app_training') }}" class="btn btn-outline-primary px-4 py-2 rounded-pill">Explore Training</a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
