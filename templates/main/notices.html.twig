{# main/notices.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Notices & Announcements - DIET Namchi{% endblock %}

{% block body %}
    <!-- Compact Hero/Breadcrumb Section -->
    <section class="compact-hero" style="background-image: url('{{ asset('images/breadcrumb.webp') }}');">
        <div class="compact-hero-overlay"></div>
        <div class="container h-100">
            <div class="row h-100 align-items-center">
                <div class="col-12" data-aos="fade-up">
                    <div class="compact-hero-content">
                        <span class="compact-hero-badge">
                            <i class="bi bi-megaphone"></i> Updates
                        </span>
                        <h1 class="compact-hero-title">Notices & Announcements</h1>
                        <nav aria-label="breadcrumb" class="compact-breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_main') }}" class="text-white">
                                        <i class="bi bi-house-door"></i> Home
                                    </a>
                                </li>
                                <li class="breadcrumb-item active text-white-50" aria-current="page">Notices</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Notices Section -->
    <section class="section-padding">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-calendar-event"></i> Latest Updates
                </span>
                <h2 class="section-title">Stay Informed</h2>
                <p>Check here for the latest circulars, exam schedules, admission updates, and important announcements from DIET Namchi.</p>
            </div>

            <div class="row g-4">
                <!-- Notice 1 -->
                <div class="col-lg-8" data-aos="fade-up" data-aos-delay="100">
                    <div class="notice-item">
                        <div class="notice-date-box">
                            <span class="notice-day">15</span>
                            <span class="notice-month">Mar 2026</span>
                        </div>
                        <div class="notice-content">
                            <h5>Admission Open for D.El.Ed Session 2026-2028</h5>
                            <p>Applications are invited from eligible candidates for admission to the 2-year Diploma in Elementary Education (D.El.Ed) program. Last date to apply: March 31, 2026.</p>
                            <a href="#" class="program-link">
                                Download Notice <i class="bi bi-download"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Notice 2 -->
                <div class="col-lg-8" data-aos="fade-up" data-aos-delay="200">
                    <div class="notice-item">
                        <div class="notice-date-box">
                            <span class="notice-day">12</span>
                            <span class="notice-month">Mar 2026</span>
                        </div>
                        <div class="notice-content">
                            <h5>In-Service Teacher Training Workshop - April 2026</h5>
                            <p>5-day training program on "Integrating Technology in Classroom Teaching" for practicing teachers. Registration deadline: March 25, 2026.</p>
                            <a href="#" class="program-link">
                                View Details <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Notice 3 -->
                <div class="col-lg-8" data-aos="fade-up" data-aos-delay="300">
                    <div class="notice-item">
                        <div class="notice-date-box">
                            <span class="notice-day">08</span>
                            <span class="notice-month">Mar 2026</span>
                        </div>
                        <div class="notice-content">
                            <h5>Examination Schedule for B.Ed Semester IV</h5>
                            <p>The theory and practical examinations for B.Ed Semester IV will commence from April 10, 2026. Admit cards will be available from April 1, 2026.</p>
                            <a href="#" class="program-link">
                                Download Schedule <i class="bi bi-download"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Notice 4 -->
                <div class="col-lg-8" data-aos="fade-up" data-aos-delay="400">
                    <div class="notice-item">
                        <div class="notice-date-box">
                            <span class="notice-day">05</span>
                            <span class="notice-month">Mar 2026</span>
                        </div>
                        <div class="notice-content">
                            <h5>NEP 2020 Implementation Workshop for Faculty</h5>
                            <p>Mandatory orientation program for all faculty members on National Education Policy 2020 implementation strategies. Date: March 20, 2026.</p>
                            <a href="#" class="program-link">
                                Read More <i class="bi bi-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Notice 5 -->
                <div class="col-lg-8" data-aos="fade-up" data-aos-delay="500">
                    <div class="notice-item">
                        <div class="notice-date-box">
                            <span class="notice-day">01</span>
                            <span class="notice-month">Mar 2026</span>
                        </div>
                        <div class="notice-content">
                            <h5>Library Membership Renewal - Academic Year 2026-27</h5>
                            <p>All students and faculty members are requested to renew their library membership by March 15, 2026. New members can also apply.</p>
                            <a href="#" class="program-link">
                                View Circular <i class="bi bi-file-text"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Pagination -->
            <nav class="mt-5" data-aos="fade-up">
                <ul class="pagination justify-content-center">
                    <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
                    <li class="page-item active"><a class="page-link" href="#">1</a></li>
                    <li class="page-item"><a class="page-link" href="#">2</a></li>
                    <li class="page-item"><a class="page-link" href="#">3</a></li>
                    <li class="page-item"><a class="page-link" href="#">Next</a></li>
                </ul>
            </nav>
        </div>
    </section>

    <!-- Archive Section -->
    <section class="section-padding bg-light-section">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <span class="section-subtitle">
                    <i class="bi bi-archive"></i> Archives
                </span>
                <h2 class="section-title">Previous Notices</h2>
            </div>

            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="accordion" id="archiveAccordion" data-aos="fade-up">
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#archive2025">
                                    Year 2025
                                </button>
                            </h2>
                            <div id="archive2025" class="accordion-collapse collapse show" data-bs-parent="#archiveAccordion">
                                <div class="accordion-body">
                                    <ul class="list-unstyled mb-0">
                                        <li class="mb-2">
                                            <a href="#" class="text-decoration-none">
                                                <i class="bi bi-file-pdf text-danger me-2"></i>
                                                Annual Examination Results 2025
                                            </a>
                                            <small class="text-muted d-block">December 2025</small>
                                        </li>
                                        <li class="mb-2">
                                            <a href="#" class="text-decoration-none">
                                                <i class="bi bi-file-pdf text-danger me-2"></i>
                                                D.El.Ed Admission Notice 2025
                                            </a>
                                            <small class="text-muted d-block">March 2025</small>
                                        </li>
                                        <li>
                                            <a href="#" class="text-decoration-none">
                                                <i class="bi bi-file-pdf text-danger me-2"></i>
                                                Faculty Recruitment Notification
                                            </a>
                                            <small class="text-muted d-block">January 2025</small>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#archive2024">
                                    Year 2024
                                </button>
                            </h2>
                            <div id="archive2024" class="accordion-collapse collapse" data-bs-parent="#archiveAccordion">
                                <div class="accordion-body">
                                    <ul class="list-unstyled mb-0">
                                        <li class="mb-2">
                                            <a href="#" class="text-decoration-none">
                                                <i class="bi bi-file-pdf text-danger me-2"></i>
                                                NCTE Inspection Report 2024
                                            </a>
                                            <small class="text-muted d-block">November 2024</small>
                                        </li>
                                        <li>
                                            <a href="#" class="text-decoration-none">
                                                <i class="bi bi-file-pdf text-danger me-2"></i>
                                                Workshop Schedule 2024
                                            </a>
                                            <small class="text-muted d-block">January 2024</small>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div data-aos="fade-up">
                <span class="section-subtitle mb-3">
                    <i class="bi bi-bell"></i> Never Miss an Update
                </span>
                <h2 class="mb-3">Subscribe to Our Newsletter</h2>
                <p class="mx-auto mb-4">Get the latest notices, exam schedules, and important announcements delivered to your inbox.</p>
                <div class="row justify-content-center">
                    <div class="col-md-6">
                        <form class="footer-newsletter-form mx-auto">
                            <input type="email" class="form-control" placeholder="Enter your email" required>
                            <button type="submit" class="btn btn-primary">Subscribe</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
