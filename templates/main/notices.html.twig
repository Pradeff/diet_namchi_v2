{# templates/main/notices.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Notices & Announcements - DIET Namchi{% endblock %}

{% block body %}

    {# ── Custom CSS for Empty States ─────────────────────────────────────── #}
    <style>
        .empty-state-card {
            background-color: #f8f9fa;
            border: 2px dashed #dee2e6;
            border-radius: 12px;
            padding: 3rem 1.5rem;
            text-align: center;
            transition: all 0.3s ease;
        }
        .empty-state-icon {
            font-size: 3rem;
            color: #adb5bd;
            margin-bottom: 1rem;
            display: inline-block;
        }
        .empty-state-title {
            color: #495057;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }
        .empty-state-text {
            color: #6c757d;
            font-size: 0.95rem;
        }

        /* Sidebar specific adjustments */
        .sidebar-empty-state {
            background-color: transparent;
            border: 1px dashed #ced4da;
            padding: 2rem 1rem;
        }
        .sidebar-empty-state .empty-state-icon {
            font-size: 2rem;
        }
        .sidebar-empty-state .empty-state-title {
            font-size: 1rem;
        }
    </style>

    {# ── Hero Section ────────────────────────────────────────────────────── #}
    <section class="compact-hero" style="background-image: url('{{ asset('images/breadcrumb.webp') }}');">
        <div class="compact-hero-overlay"></div>
        <div class="container h-100">
            <div class="row h-100 align-items-center">
                <div class="col-12" data-aos="fade-up">
                    <div class="compact-hero-content">
                        <span class="compact-hero-badge">
                            <i class="bi bi-megaphone"></i> Updates
                        </span>
                        <h1 class="compact-hero-title">Notices & Announcements</h1>
                        <nav aria-label="breadcrumb" class="compact-breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_main') }}" class="text-white">
                                        <i class="bi bi-house-door"></i> Home
                                    </a>
                                </li>
                                <li class="breadcrumb-item active text-white-50" aria-current="page">Notices</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ── Notices Section ──────────────────────────────────────────────────── #}
    <section class="section-padding">
        <div class="container">
            <div class="row g-4">

                {# ── LEFT: Current-year notices ──────────────────────────── #}
                <div class="col-lg-8">

                    {% if notices|length > 0 %}
                        {% for vnotice in notices %}
                            <div class="notice-item mb-4" data-aos="fade-up">
                                <div class="notice-date-box">
                                    <span class="notice-day">{{ vnotice.noticeDate|date('d') }}</span>
                                    <span class="notice-month">{{ vnotice.noticeDate|date('M Y') }}</span>
                                </div>

                                <div class="notice-content">
                                    <h5>{{ vnotice.title }}</h5>
                                    {% if vnotice.description %}
                                        <p>{{ vnotice.description }}</p>
                                    {% endif %}

                                    {% if vnotice.pdfFilename %}
                                        <a href="{{ asset('uploads/pdf/' ~ vnotice.pdfFilename) }}"
                                           target="_blank"
                                           class="program-link">
                                            Download Notice <i class="bi bi-download"></i>
                                        </a>
                                    {% else %}
                                        <a href="#" class="program-link">
                                            View Details <i class="bi bi-arrow-right"></i>
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="empty-state-card" data-aos="fade-up">
                            <i class="bi bi-inbox empty-state-icon"></i>
                            <h4 class="empty-state-title">No notices available</h4>
                            <p class="empty-state-text">
                                There are currently no notices posted for this period.<br>
                                Please check back later for updates.
                            </p>
                        </div>
                    {% endif %}

                    {% if totalPages > 1 %}
                        <nav class="mt-5">
                            <ul class="pagination justify-content-center">

                                <li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
                                    <a class="page-link"
                                       href="{{ path('app_notices', {'page': currentPage - 1}) }}">
                                        Previous
                                    </a>
                                </li>

                                {% for p in 1..totalPages %}
                                    <li class="page-item {{ p == currentPage ? 'active' : '' }}">
                                        <a class="page-link"
                                           href="{{ path('app_notices', {'page': p}) }}">
                                            {{ p }}
                                        </a>
                                    </li>
                                {% endfor %}

                                <li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
                                    <a class="page-link"
                                       href="{{ path('app_notices', {'page': currentPage + 1}) }}">
                                        Next
                                    </a>
                                </li>

                            </ul>
                        </nav>
                    {% endif %}

                </div>

                <div class="col-lg-4">

                    <div class="archive-box p-4 bg-light rounded shadow-sm" data-aos="fade-up">

                        <h5 class="mb-3">
                            <i class="bi bi-archive me-2"></i>
                            Previous Notices
                        </h5>

                        {% if archivedNotices is not empty %}
                            <div class="accordion" id="archiveAccordion">

                                {% for year, yearNotices in archivedNotices %}
                                    <div class="accordion-item">
                                        <h2 class="accordion-header">
                                            <button class="accordion-button {{ loop.first ? '' : 'collapsed' }}"
                                                    type="button"
                                                    data-bs-toggle="collapse"
                                                    data-bs-target="#archive{{ year }}">
                                                {{ year }}
                                            </button>
                                        </h2>

                                        <div id="archive{{ year }}"
                                             class="accordion-collapse collapse {{ loop.first ? 'show' : '' }}"
                                             data-bs-parent="#archiveAccordion">
                                            <div class="accordion-body">
                                                <ul class="list-unstyled mb-0">
                                                    {% for notice in yearNotices %}
                                                        <li class="{{ loop.last ? '' : 'mb-3' }}">
                                                            {% if notice.pdfFilename %}
                                                                <a href="{{ asset('uploads/pdf/' ~ notice.pdfFilename) }}"
                                                                   target="_blank"
                                                                   class="text-decoration-none text-dark hover-primary">
                                                                    <i class="bi bi-file-pdf text-danger me-2"></i>
                                                                    {{ notice.title }}
                                                                </a>
                                                            {% else %}
                                                                <span class="text-dark">
                                                                    <i class="bi bi-file-text me-2"></i>
                                                                    {{ notice.title }}
                                                                </span>
                                                            {% endif %}
                                                        </li>
                                                    {% endfor %}
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                {% endfor %}

                            </div>
                        {% else %}
                            <div class="sidebar-empty-state text-center">
                                <i class="bi bi-archive empty-state-icon"></i>
                                <p class="empty-state-title mb-0">No archives found</p>
                            </div>
                        {% endif %}

                    </div>
                </div>

            </div>
        </div>
    </section>

{% endblock %}
