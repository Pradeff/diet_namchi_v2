{# main/training.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Training & Workshops - DIET Namchi{% endblock %}

{% block body %}
    <!-- Compact Hero/Breadcrumb Section -->
    <section class="compact-hero" style="background-image: url('{{ asset('images/breadcrumb.webp') }}');">
        <div class="compact-hero-overlay"></div>
        <div class="container h-100">
            <div class="row h-100 align-items-center">
                <div class="col-12" data-aos="fade-up">
                    <div class="compact-hero-content">
                        <span class="compact-hero-badge">
                            <i class="bi bi-bookmark-check"></i> Professional Development
                        </span>
                        <h1 class="compact-hero-title">Training & Workshops</h1>
                        <nav aria-label="breadcrumb" class="compact-breadcrumb">
                            <ol class="breadcrumb mb-0">
                                <li class="breadcrumb-item">
                                    <a href="{{ path('app_main') }}" class="text-white">
                                        <i class="bi bi-house-door"></i> Home
                                    </a>
                                </li>
                                <li class="breadcrumb-item active text-white-50" aria-current="page">Training</li>
                            </ol>
                        </nav>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content with Sidebar -->
    <section class="section-padding">
        <div class="container">
            <div class="row g-5">
                <!-- Main Content -->
                <div class="col-lg-8">
                    <div class="section-header" data-aos="fade-up">
                        <span class="section-subtitle">
                            <i class="bi bi-people"></i> Capacity Building
                        </span>
                        <h2 class="section-title">In-Service Teacher Training Programs</h2>
                        <p>DIET Namchi offers comprehensive professional development programs designed to enhance teaching skills, integrate modern pedagogy, and implement NEP 2020 frameworks effectively.</p>
                    </div>

                    <!-- Training Programs -->
                    <div class="row g-4">
                        <!-- Program 1 -->
                        <div class="col-12" data-aos="fade-up" data-aos-delay="100">
                            <div class="program-card">
                                <div class="program-img-wrapper">
                                    <img src="{{ asset('images/dummy/2.jpg') }}" alt="Technology Integration">
                                </div>
                                <div class="program-content">
                                    <div class="program-meta">
                                        <span><i class="bi bi-calendar"></i> 5 Days</span>
                                        <span><i class="bi bi-clock"></i> 30 Hours</span>
                                        <span><i class="bi bi-people"></i> 50 Participants</span>
                                    </div>
                                    <h3 class="program-title">Technology Integration in Classroom Teaching</h3>
                                    <p>Learn to effectively use digital tools, educational apps, and multimedia resources to create engaging, interactive learning experiences. Covers smart classroom management, online assessment tools, and blended learning strategies.</p>
                                    <div class="mt-3">
                                        <h6>Key Learning Outcomes:</h6>
                                        <ul class="list-unstyled">
                                            <li><i class="bi bi-check2 text-primary me-2"></i>Digital literacy and ICT skills</li>
                                            <li><i class="bi bi-check2 text-primary me-2"></i>Educational software proficiency</li>
                                            <li><i class="bi bi-check2 text-primary me-2"></i>Online content creation</li>
                                            <li><i class="bi bi-check2 text-primary me-2"></i>Virtual classroom management</li>
                                        </ul>
                                    </div>
                                    <a href="#" class="program-link">
                                        Register Now <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Program 2 -->
                        <div class="col-12" data-aos="fade-up" data-aos-delay="200">
                            <div class="program-card">
                                <div class="program-img-wrapper">
                                    <img src="{{ asset('images/dummy/2.jpg') }}" alt="NEP 2020 Implementation">
                                </div>
                                <div class="program-content">
                                    <div class="program-meta">
                                        <span><i class="bi bi-calendar"></i> 3 Days</span>
                                        <span><i class="bi bi-clock"></i> 18 Hours</span>
                                        <span><i class="bi bi-people"></i> 100 Participants</span>
                                    </div>
                                    <h3 class="program-title">NEP 2020 Implementation Strategies</h3>
                                    <p>Comprehensive orientation on National Education Policy 2020, focusing on competency-based education, multidisciplinary approach, and holistic development frameworks for elementary education.</p>
                                    <div class="mt-3">
                                        <h6>Key Learning Outcomes:</h6>
                                        <ul class="list-unstyled">
                                            <li><i class="bi bi-check2 text-primary me-2"></i>NEP 2020 framework understanding</li>
                                            <li><i class="bi bi-check2 text-primary me-2"></i>Competency-based assessment</li>
                                            <li><i class="bi bi-check2 text-primary me-2"></i>Foundational literacy & numeracy</li>
                                            <li><i class="bi bi-check2 text-primary me-2"></i>21st-century skills integration</li>
                                        </ul>
                                    </div>
                                    <a href="#" class="program-link">
                                        Register Now <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Program 3 -->
                        <div class="col-12" data-aos="fade-up" data-aos-delay="300">
                            <div class="program-card">
                                <div class="program-img-wrapper">
                                    <img src="{{ asset('images/dummy/2.jpg') }}" alt="Inclusive Education">
                                </div>
                                <div class="program-content">
                                    <div class="program-meta">
                                        <span><i class="bi bi-calendar"></i> 4 Days</span>
                                        <span><i class="bi bi-clock"></i> 24 Hours</span>
                                        <span><i class="bi bi-people"></i> 40 Participants</span>
                                    </div>
                                    <h3 class="program-title">Inclusive Education & Special Needs</h3>
                                    <p>Develop skills to create inclusive classrooms that accommodate diverse learners, including children with special needs. Focus on differentiated instruction, adaptive teaching methods, and universal design for learning.</p>
                                    <div class="mt-3">
                                        <h6>Key Learning Outcomes:</h6>
                                        <ul class="list-unstyled">
                                            <li><i class="bi bi-check2 text-primary me-2"></i>Inclusive classroom strategies</li>
                                            <li><i class="bi bi-check2 text-primary me-2"></i>IEP development</li>
                                            <li><i class="bi bi-check2 text-primary me-2"></i>Assistive technology use</li>
                                            <li><i class="bi bi-check2 text-primary me-2"></i>Multi-sensory teaching</li>
                                        </ul>
                                    </div>
                                    <a href="#" class="program-link">
                                        Register Now <i class="bi bi-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Upcoming Workshops -->
                    <div class="mt-5" data-aos="fade-up">
                        <h3 class="mb-4">Upcoming Workshops</h3>
                        <div class="notice-item">
                            <div class="notice-date-box">
                                <span class="notice-day">15</span>
                                <span class="notice-month">Apr 2026</span>
                            </div>
                            <div class="notice-content">
                                <h5>Art Integration in Teaching</h5>
                                <p>2-day workshop on using visual and performing arts to enhance learning across subjects.</p>
                            </div>
                        </div>
                        <div class="notice-item">
                            <div class="notice-date-box">
                                <span class="notice-day">22</span>
                                <span class="notice-month">Apr 2026</span>
                            </div>
                            <div class="notice-content">
                                <h5>Assessment & Evaluation Techniques</h5>
                                <p>3-day intensive program on formative and summative assessment strategies.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sidebar -->
                <div class="col-lg-4">
                    <!-- Quick Links -->
                    <div class="feature-card mb-4" data-aos="fade-left">
                        <h4 class="feature-title mb-3">
                            <i class="bi bi-link-45deg me-2"></i>Quick Links
                        </h4>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <a href="#" class="text-decoration-none d-flex align-items-center gap-2">
                                    <i class="bi bi-chevron-right text-primary"></i>
                                    Training Calendar 2026
                                </a>
                            </li>
                            <li class="mb-2">
                                <a href="#" class="text-decoration-none d-flex align-items-center gap-2">
                                    <i class="bi bi-chevron-right text-primary"></i>
                                    Resource Materials
                                </a>
                            </li>
                            <li class="mb-2">
                                <a href="#" class="text-decoration-none d-flex align-items-center gap-2">
                                    <i class="bi bi-chevron-right text-primary"></i>
                                    Online Registration
                                </a>
                            </li>
                            <li class="mb-2">
                                <a href="#" class="text-decoration-none d-flex align-items-center gap-2">
                                    <i class="bi bi-chevron-right text-primary"></i>
                                    Training Certificates
                                </a>
                            </li>
                            <li class="mb-2">
                                <a href="#" class="text-decoration-none d-flex align-items-center gap-2">
                                    <i class="bi bi-chevron-right text-primary"></i>
                                    Previous Workshops
                                </a>
                            </li>
                            <li>
                                <a href="#" class="text-decoration-none d-flex align-items-center gap-2">
                                    <i class="bi bi-chevron-right text-primary"></i>
                                    Download Brochure
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Training Categories -->
                    <div class="feature-card mb-4" data-aos="fade-left" data-aos-delay="100">
                        <h4 class="feature-title mb-3">
                            <i class="bi bi-grid me-2"></i>Training Categories
                        </h4>
                        <div class="d-flex flex-wrap gap-2">
                            <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-pill">Pedagogy</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-pill">Technology</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-pill">NEP 2020</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-pill">Assessment</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-pill">Inclusive Ed</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-pill">Leadership</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-pill">ICT Skills</span>
                            <span class="badge bg-primary bg-opacity-10 text-primary p-2 rounded-pill">Life Skills</span>
                        </div>
                    </div>

                    <!-- Contact for Training -->
                    <div class="feature-card" data-aos="fade-left" data-aos-delay="200">
                        <h4 class="feature-title mb-3">
                            <i class="bi bi-headset me-2"></i>Training Coordinator
                        </h4>
                        <div class="d-flex gap-3 mb-3">
                            <div class="feature-icon" style="width: 48px; height: 48px; font-size: 20px; margin-bottom: 0;">
                                <i class="bi bi-person-badge"></i>
                            </div>
                            <div>
                                <strong>Dr. Training Coordinator</strong><br>
                                <small class="text-muted">Program In-Charge</small>
                            </div>
                        </div>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="bi bi-telephone text-primary me-2"></i>
                                03595-264521 (Ext. 102)
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-envelope text-primary me-2"></i>
                                training@dietnamchi.org
                            </li>
                            <li>
                                <i class="bi bi-clock text-primary me-2"></i>
                                Mon-Sat: 10AM-5PM
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
        <div class="container">
            <div data-aos="fade-up">
                <span class="section-subtitle mb-3">
                    <i class="bi bi-star"></i> Professional Growth
                </span>
                <h2 class="mb-3">Ready to Enhance Your Teaching Skills?</h2>
                <p class="mx-auto mb-4">Join our upcoming training programs and workshops to stay updated with the latest pedagogical practices and educational technologies.</p>
                <div class="d-flex justify-content-center gap-3 flex-wrap">
                    <a href="#" class="btn-apply">View All Programs</a>
                    <a href="{{ path('app_contact') }}" class="btn btn-outline-primary px-4 py-2 rounded-pill">
                        <i class="bi bi-envelope me-1"></i> Request Training
                    </a>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
