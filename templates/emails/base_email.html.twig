{# templates/emails/base_email.html.twig #}
<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{% block email_title %}Lets Go Sikkim Travels{% endblock %}</title>
</head>
<body style="margin: 0; padding: 0; font-family: Arial, sans-serif; background-color: #f4f6f9;">

<!-- Main Container -->
<table cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #f4f6f9; padding: 20px 0;">
    <tr>
        <td align="center">

            <!-- Email Container -->
            <table cellpadding="0" cellspacing="0" border="0" width="600" style="max-width: 600px; background-color: #ffffff; border-radius: 8px;" bgcolor="#ffffff">

                <!-- Header -->
                <tr>
                    <td style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); background-color: #1e3a8a; padding: 40px 30px; text-align: center; border-radius: 8px 8px 0 0;" bgcolor="#1e3a8a" align="center">

                        <!-- Header Icon -->
                        <div style="font-size: 48px; margin-bottom: 15px; color: #ffffff;">{% block header_icon %}🏔️{% endblock %}</div>

                        <!-- Header Title -->
                        <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; font-family: Arial, sans-serif;">
                            {% block header_title %}Lets Go Sikkim Travels{% endblock %}
                        </h1>

                        <!-- Header Subtitle -->
                        <p style="margin: 8px 0 0 0; color: #ffffff; font-size: 16px; opacity: 0.9; font-family: Arial, sans-serif;">
                            {% block header_subtitle %}Your trusted travel partner{% endblock %}
                        </p>

                    </td>
                </tr>

                <!-- Content -->
                <tr>
                    <td style="padding: 40px 30px; font-family: Arial, sans-serif; line-height: 1.6; color: #333333;">
                        {% block email_content %}
                            <p style="margin: 0; font-size: 16px; color: #333333; font-family: Arial, sans-serif;">Default email content</p>
                        {% endblock %}
                    </td>
                </tr>

                <!-- Footer -->
                <tr>
                    <td style="background-color: #f8fafc; padding: 30px; text-align: center; border-top: 1px solid #e2e8f0;" bgcolor="#f8fafc" align="center">

                        <!-- Footer Message -->
                        <p style="margin: 0 0 15px 0; font-size: 16px; font-weight: bold; color: #1e293b; font-family: Arial, sans-serif;">
                            {% block footer_message %}Thank you for choosing Lets Go Sikkim Travels{% endblock %}
                        </p>

                        <!-- Company Address -->
                       {# <p style="margin: 0 0 15px 0; font-size: 14px; color: #64748b; line-height: 1.5; font-family: Arial, sans-serif;">
                            {% block company_address %}Gangtok Indira Bypass Road Opposite SDF Bhawan, Below Khadi Building, Gangtok 737102 India{% endblock %}
                        </p>#}

                        <!-- Copyright -->
                        <p style="margin: 15px 0 0 0; font-size: 12px; color: #94a3b8; border-top: 1px solid #e2e8f0; padding-top: 15px; font-family: Arial, sans-serif;">
                            © {{ "now"|date("Y") }} {% block company_name %}Lets Go Sikkim Travels{% endblock %}. All rights reserved.
                        </p>

                    </td>
                </tr>

            </table>

        </td>
    </tr>
</table>

</body>
</html>
