{% extends 'base_dashboard.html.twig' %}

{% block title %}Banner Slide Details{% endblock %}

{% block body %}
    <div class="container py-4">
        <div class="row">
            <div class="col-lg-8 mx-auto">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Banner Slide Details</h5>
                        <a href="{{ path('app_vslider_edit', {'id': vslider.id}) }}" class="btn btn-light-success btn-sm">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                    </div>
                    <div class="card-body">
                        <table class="table table-bordered">
                            <tbody>
                            <tr>
                                <th style="width: 200px;">ID</th>
                                <td>{{ vslider.id }}</td>
                            </tr>
                            <tr>
                                <th>Title</th>
                                <td>{{ vslider.title }}</td>
                            </tr>
                            <tr>
                                <th>Description</th>
                                <td>{{ vslider.description }}</td>
                            </tr>
                            <tr>
                                <th>Media Type</th>
                                <td>
                                    <span class="badge bg-{{ vslider.mediaType == 'video' ? 'primary' : 'info' }}">
                                        {{ vslider.mediaType|upper }}
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th>Media Preview</th>
                                <td>
                                    {% if vslider.mediaPath %}
                                        {% if vslider.mediaType == 'video' %}
                                            <video controls style="max-width: 100%; height: auto;">
                                                <source src="{{ asset('uploads/media/' ~ vslider.mediaPath) }}" type="video/mp4">
                                            </video>
                                        {% else %}
                                            <img src="{{ asset('uploads/media/' ~ vslider.mediaPath) }}" alt="{{ vslider.title }}" style="max-width: 100%; height: auto;">
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted">No media uploaded</span>
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th>Sort Order</th>
                                <td>{{ vslider.sortOrder }}</td>
                            </tr>
                            <tr>
                                <th>Status</th>
                                <td>
                                    <span class="badge bg-{{ vslider.isActive ? 'success' : 'secondary' }}">
                                        {{ vslider.isActive ? 'Active' : 'Inactive' }}
                                    </span>
                                </td>
                            </tr>
                            <tr>
                                <th>Created At</th>
                                <td>{{ vslider.createdAt ? vslider.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                            </tr>
                            <tr>
                                <th>Updated At</th>
                                <td>{{ vslider.updatedAt ? vslider.updatedAt|date('Y-m-d H:i:s') : 'Never' }}</td>
                            </tr>
                            </tbody>
                        </table>

                        <div class="d-flex justify-content-between mt-3">
                            <a href="{{ path('app_vslider_index') }}" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to list
                            </a>
                            <form method="post" action="{{ path('app_vslider_delete', {'id': vslider.id}) }}" onsubmit="return confirm('Are you sure you want to delete this slide?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vslider.id) }}">
                                <button class="btn btn-danger">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
