{% extends 'base_dashboard.html.twig' %}

{% block title %}Edit User: {{ user.email }}{% endblock %}
{% block page_title %}Edit User{% endblock %}

{% block content %}
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5><i class="bi bi-pencil"></i> Edit User: {{ user.email }}</h5>
                    <a href="{{ path('admin_users_show', {'id': user.id}) }}" class="btn btn-sm btn-outline-info">
                        <i class="bi bi-eye"></i> View User
                    </a>
                </div>
                <div class="card-body">
                    {% include 'admin/users/_form.html.twig' with {'button_label': 'Update User'} %}
                </div>
            </div>

            <!-- Delete Form -->
            {% if user.id != app.user.id %}
                <div class="card mt-4 border-danger">
                    <div class="card-header bg-danger text-white">
                        <h6><i class="bi bi-exclamation-triangle"></i> Danger Zone</h6>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Once you delete this user, there is no going back. Please be certain.</p>
                        {% include 'admin/users/_delete_form.html.twig' %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}
