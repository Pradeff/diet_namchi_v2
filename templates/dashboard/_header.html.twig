    <div class="offcanvas-footer border-top p-3">
        <button class="btn btn-primary w-100" id="resetCustomizer">Reset to Default</button>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const logoutLink = document.getElementById('logoutLink');
        if (!logoutLink) return;

        logoutLink.addEventListener('click', function (e) {
            e.preventDefault();
            Swal.fire({
                title: 'Sign out of your account?',
                text: "You will need to log in again to access your dashboard.",
                icon: 'warning',
                allowOutsideClick: false,
                allowEscapeKey: false,
                showCancelButton: true,
                confirmButtonColor: '#209d5e',
                cancelButtonColor: '#777777',
                confirmButtonText: 'Yes, Sign out',
                customClass: {
                    popup: 'rounded-4 border-0',
                    confirmButton: 'btn btn-danger px-4 py-2 ',
                    cancelButton: 'btn btn-outline-secondary px-4 py-2 ms-2'
                },
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = logoutLink.href;
                }
                // If cancelled, do nothing
            });
        });
    });

</script>

