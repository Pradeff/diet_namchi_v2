<!-- Theme Customizer Offcanvas -->
<div class="offcanvas offcanvas-end shadow-lg" tabindex="-1" id="themeCustomizer"
     aria-labelledby="themeCustomizerLabel">
    <div class="offcanvas-header border-bottom">
        <h5 class="offcanvas-title" id="themeCustomizerLabel">Theme Settings</h5>
        <button type="button" class="btn-close text-reset btn-sm" data-bs-dismiss="offcanvas"
                aria-label="Close"></button>
    </div>

    <div class="offcanvas-body">
        <!-- Theme Mode -->
        <div class="customizer-section mb-4">
            <h6 class="section-title">Theme Mode</h6>
            <div class="btn-group w-100" role="group">
                <input type="radio" class="btn-check" name="themeMode" id="customizerLight" autocomplete="off"
                       value="light">
                <label class="btn btn-outline-primary" for="customizerLight">
                    <i class="bi bi-sun me-1"></i> Light
                </label>

                <input type="radio" class="btn-check" name="themeMode" id="customizerDark" autocomplete="off"
                       value="dark">
                <label class="btn btn-outline-primary" for="customizerDark">
                    <i class="bi bi-moon me-1"></i> Dark
                </label>

                <input type="radio" class="btn-check" name="themeMode" id="customizerAuto" autocomplete="off"
                       value="auto">
                <label class="btn btn-outline-primary" for="customizerAuto">
                    <i class="bi bi-laptop me-1"></i> Auto
                </label>
            </div>
        </div>

        <!-- Primary Color -->
        <div class="customizer-section mb-4">
            <h6 class="section-title">Primary Color</h6>
            <div class="d-flex flex-wrap gap-2">
                <button class="color-option rounded-circle border-0" data-color="#066FD1"
                        style="width:32px; height:32px; background-color: #066FD1;"></button>
                <button class="color-option rounded-circle border-0" data-color="#7367f0"
