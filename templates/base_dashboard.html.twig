    <style>

        .gallery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 3fr));
            gap: 20px;
        }
        .gallery-item {
            position: relative;
            border-radius: 4px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        .gallery-item:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        }
        .gallery-item img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            transition: transform 0.3s ease;
        }
        .gallery-item:hover img {
            transform: scale(1.1);
        }
        .cover-badge-large {
            position: absolute;
            top: 10px;
            right: 10px;
            background: linear-gradient(45deg, #28a745, #20c997);
            color: white;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: bold;
            box-shadow: 0 3px 10px rgba(40, 167, 69, 0.3);
        }
        .breadcrumb-custom {
            background: rgba(255,255,255,0.9);
            border-radius: 25px;
            padding: 10px 20px;
            margin-bottom: 2rem;
        }
        .no-images {
            text-align: center;
            padding: 3rem;
            background: #f8f9fa;
            border-radius: 15px;
            color: #6c757d;
        }
        .no-images i {
            font-size: 4rem;
            margin-bottom: 1rem;
            color: #dee2e6;
        }
        .glightbox-image {
            text-decoration: none;
            color: inherit;
        }
        .glightbox-image:hover {
            text-decoration: none;
            color: inherit;
        }
        /* Upload Progress Styles - Force visibility */
        #uploadProgressWrap {
            margin-top: 1rem;
        }

        #uploadProgressWrap .progress {
            height: 25px;
            background-color: #e9ecef;
            border-radius: 0.375rem;
            overflow: hidden;
        }

        #uploadProgressWrap .progress-bar {
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.875rem;
            font-weight: 600;
            color: #fff;
            background-color: #0d6efd;
            transition: width 0.3s ease;
        }

        #uploadProgressWrap .progress-bar.bg-success {
            background-color: #198754 !important;
        }

        #uploadProgressWrap .progress-bar.bg-danger {
            background-color: #dc3545 !important;
        }

        #uploadProgressWrap .progress-bar-animated {
            animation: progress-bar-stripes 1s linear infinite;
        }

        #uploadProgressWrap .progress-bar-striped {
            background-image: linear-gradient(45deg, rgba(255, 255, 255, .15) 25%, transparent 25%, transparent 50%, rgba(255, 255, 255, .15) 50%, rgba(255, 255, 255, .15) 75%, transparent 75%, transparent);
            background-size: 1rem 1rem;
        }

        @keyframes progress-bar-stripes {
            0% { background-position: 1rem 0; }
            100% { background-position: 0 0; }
        }

        /* Spinner styles */
        .spinner-border-sm {
            width: 1rem;
            height: 1rem;
            border-width: 0.2em;
        }

        .spinner-border {
            display: inline-block;
            vertical-align: text-bottom;
            border: 0.25em solid currentColor;
            border-right-color: transparent;
            border-radius: 50%;
            animation: spinner-border 0.75s linear infinite;
        }

        @keyframes spinner-border {
            to { transform: rotate(360deg); }
        }

        /* Upload text styles */
        #uploadProgressText {
            display: block;
            margin-top: 0.5rem;
            font-size: 0.875rem;
            color: #6c757d;
        }
    </style>
