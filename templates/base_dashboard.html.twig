                }
            },
            "dom": '<"row"<"col-sm-12 col-md-6"l><"col-sm-12 col-md-6"f>>rt<"row"<"col-sm-12 col-md-5"i><"col-sm-12 col-md-7"p>>'
        });


    });

    function initializeSummernote() {
        $('.summernote,#vhike_form_description,#vevents_description,#vpage_content,#vitinerary_form_description,#vitinerary_form_highlight,#vtrek_form_description,#vtrek_form_highlights,#vtrek_form_termsandcondition,#vevents_description1,#vblog_description,#vadventure_description,#vdestination_form_description,#vplace_description, #advactivity_description,#vdestination_description,#vitinerary_description,#vitinerary_description1,#vitinerary_inclusion,#vitinerary_exclusion,#vtrekking_description,#vtrekking_inclusion,#vtrekking_exclusion,#vtrekking_placecover,#vhomestay_description,#vhomestay_amenities,#vhomestay_address,#vreviews_message,#vpages_description,#vabout_description,#vteam_description').summernote({
            toolbar: [
                ['style', ['bold', 'italic', 'underline', 'clear']],
                ['font', ['strikethrough', 'superscript', 'subscript']],
                ['fontsize', ['fontsize']],
                ['color', ['color']],
                ['para', ['ul', 'ol', 'paragraph']],
                ['height', ['height']],
                ['insert', ['picture', 'link', 'table']],
                ['view', ['codeview',]]
            ],
            tabsize: 2,
            height: 200,
            disableDragAndDrop: true
        });
    }
</script>


