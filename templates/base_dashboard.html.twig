{#Dropify svg preview#}
<script>
    $('.dropify_file_input').dropify();

    // Manually inject SVG preview
    $('.dropify_file_input').each(function () {
        var input = $(this);
        var defaultFile = input.data('default-file');

        if (defaultFile && defaultFile.endsWith('.svg')) {
            var dropifyWrapper = input.closest('.dropify-wrapper');
            dropifyWrapper.addClass('has-preview');
            dropifyWrapper.find('.dropify-render').html(
                '<img src="' + defaultFile + '" style="max-height: 120px;" alt="SVG Preview">'
            );
        }
    });
</script>



{#Sortable#}
<script>
    $(function () {
        $("#sortable").sortable({
            handle: ".drag-handle",
            update: function () {
                let order = [];
                $("#sortable tr").each(function (index) {
                    order.push({
                        id: $(this).data("id"),
                        position: index + 1
                    });
                });

                $.ajax({
                    url: "{{ path('app_vteam_sort') }}",
                    method: "POST",
                    data: { order: order },
                    success: function () {
                        Swal.fire({
                            icon: 'success',
                            title: 'Order Saved',
                            toast: true,
                            position: 'top-end',
                            showConfirmButton: false,
                            timer: 1500
                        });
                    }
                });
            }
        });
    });
</script>

