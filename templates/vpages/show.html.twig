{% extends 'base_dashboard.html.twig' %}

{% block title %}{{ vpage.title }}{% endblock %}

{% block body %}
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">{{ vpage.title }}</h3>
                        <div>
                            <a href="{{ path('app_vpages_edit', {'id': vpage.id}) }}" class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil"></i> Edit
                            </a>
                            {% include 'vpages/_delete_form.html.twig' %}
                            <a href="{{ path('app_vpages_index') }}" class="btn btn-secondary btn-sm">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h5>Basic Information</h5>
                                <table class="table table-borderless">
                                    <tr>
                                        <th width="120">Title:</th>
                                        <td>{{ vpage.title }}</td>
                                    </tr>
                                    <tr>
                                        <th>Slug:</th>
                                        <td><code>{{ vpage.slug }}</code></td>
                                    </tr>
                                    <tr>
                                        <th>Icon:</th>
                                        <td>
                                            {% if vpage.icon %}
                                                <div style="width: 40px; height: 40px;">
                                                    {{ vpage.icon|raw }}
                                                </div>
                                            {% else %}
                                                <em class="text-muted">No icon</em>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Image:</th>
                                        <td>
                                            {% if vpage.image %}
                                                <img src="{{ asset('uploads/image/' ~ vpage.image) }}"
                                                     alt="{{ vpage.title }}"
                                                     class="img-thumbnail"
                                                     style="max-width: 150px; max-height: 150px;">
                                            {% else %}
                                                <em class="text-muted">No image</em>
                                            {% endif %}
                                        </td>
                                    </tr>
                                    <tr>
                                        <th>Created:</th>
                                        <td>{{ vpage.createdAt ? vpage.createdAt|date('F j, Y \\a\\t g:i A') : 'N/A' }}</td>
                                    </tr>
                                    <tr>
                                        <th>Updated:</th>
                                        <td>{{ vpage.updatedAt ? vpage.updatedAt|date('F j, Y \\a\\t g:i A') : 'N/A' }}</td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <h5>Description</h5>
                                <div class="border rounded p-3 bg-light">
                                    {% if vpage.description %}
                                        {{ vpage.description|raw }}
                                    {% else %}
                                        <em class="text-muted">No description provided</em>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
