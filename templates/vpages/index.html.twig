{% extends 'base_dashboard.html.twig' %}

{% block title %}Pages{% endblock %}

{% block body %}
    <div class="row mb-4">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text_color_default">
                    <i class="bi bi-file-earmark"></i>
                    Pages
                </h5>
                <a href="{{ path('app_vpages_new') }}" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-lg"></i>
                    Add New Page
                </a>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                {% if vpages %}
                    <div class="table-responsive">
                        <table id="d_table" class="table table-hover align-middle">
                            <thead class="table-dark">
                            <tr>
                                <th>Title</th>
                                <th>Slug</th>
                                <th>Icon</th>
                                <th>Image</th>
                                <th>Description</th>
                                <th>Created At</th>
                                <th>Actions</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for vpage in vpages %}
                                <tr id="row-{{ vpage.id }}">
                                    <td>{{ vpage.title }}</td>
                                    <td><code>{{ vpage.slug }}</code></td>
                                    <td class="text-center">
                                        {% if vpage.icon %}
                                            <div style="width: 30px; height: 30px;">
                                                {{ vpage.icon|raw }}
                                            </div>
                                        {% else %}
                                            <em class="text-muted">No icon</em>
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if vpage.image %}
                                            <img src="{{ asset('uploads/image/' ~ vpage.image) }}"
                                                 alt="{{ vpage.title }}"
                                                 class="img-thumbnail"
                                                 style="width: 50px; height: 50px; object-fit: cover;">
                                        {% else %}
                                            <em class="text-muted">No image</em>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if vpage.description %}
                                            {{ vpage.description|raw|length > 52 ? vpage.description|raw|slice(0, 52) ~ '...' : vpage.description|raw }}
                                        {% else %}
                                            <em class="text-muted">No description</em>
                                        {% endif %}
                                    </td>
                                    <td>{{ vpage.createdAt ? vpage.createdAt|date('d m Y') : '' }}</td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="{{ path('app_vpages_show', {'id': vpage.id}) }}" class="btn btn-light-info">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="{{ path('app_vpages_edit', {'id': vpage.id}) }}" class="btn btn-light-secondary">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            {% include 'vpages/_delete_form.html.twig' %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <i class="bi bi-file-earmark-text display-1 text-muted"></i>
                        <p class="lead text-muted">No pages found</p>
                        <p class="text-muted">Create your first page to get started.</p>
                        <a href="{{ path('app_vpages_new') }}" class="btn btn-primary">
                            <i class="bi bi-plus"></i> Add New Page
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
