{# templates/vfaq/index.html.twig #}
{% extends 'base_dashboard.html.twig' %}

{% block title %}FAQs{% endblock %}

{% block body %}
<div class="container-fluid">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h4 class="mb-1 fw-bold"><i class="bi bi-patch-question me-2 text-primary"></i>FAQs</h4>
            <p class="text-muted mb-0 small">Manage frequently asked questions shown on the public site.</p>
        </div>
        <a href="{{ path('app_vfaq_new') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i> New FAQ
        </a>
    </div>

    <!-- Flash messages -->
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>{{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <!-- Table -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            {% if vfaqs is not empty %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width:50px">#</th>
                                <th>Question</th>
                                <th>Answer</th>
                                <th style="width:80px">Added</th>
                                <th class="text-end pe-4" style="width:120px">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for vfaq in vfaqs %}
                                <tr>
                                    <td class="ps-4 text-muted small">{{ loop.index }}</td>
                                    <td>
                                        <span class="fw-semibold">{{ vfaq.question }}</span>
                                    </td>
                                    <td class="text-muted small">
                                        {{ vfaq.answer|length > 100 ? vfaq.answer|slice(0, 100) ~ '…' : vfaq.answer }}
                                    </td>
                                    <td class="text-muted small text-nowrap">
                                        {{ vfaq.createdAt|date('d M Y') }}
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="{{ path('app_vfaq_edit', {'id': vfaq.id}) }}"
                                           class="btn btn-sm btn-outline-secondary me-1"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                title="Delete"
                                                onclick="confirmDelete({{ vfaq.id }}, '{{ vfaq.question|e('html_attr') }}')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-patch-question display-4 d-block mb-3"></i>
                    <p class="mb-0">No FAQs yet. <a href="{{ path('app_vfaq_new') }}">Add the first one</a>.</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>

{# Hidden delete forms — one per FAQ #}
{% for vfaq in vfaqs %}
    <form id="delete-form-{{ vfaq.id }}"
          action="{{ path('app_vfaq_delete', {'id': vfaq.id}) }}"
          method="POST" style="display:none">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ vfaq.id) }}">
    </form>
{% endfor %}

<script>
function confirmDelete(id, question) {
    Swal.fire({
        title: 'Delete FAQ?',
        html: `<p class="text-muted mb-0">Are you sure you want to delete:</p><strong>${question}</strong>`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: '<i class="bi bi-trash"></i> Yes, delete it!',
        cancelButtonText: '<i class="bi bi-x-circle"></i> Cancel',
    }).then(result => {
        if (result.isConfirmed) {
            document.getElementById('delete-form-' + id).submit();
        }
    });
}
</script>
{% endblock %}
