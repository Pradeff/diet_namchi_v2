{# templates/vfaq/_form.html.twig #}
{{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': true,'id': 'form'}}) }}
<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom">
                <strong><i class="bi bi-patch-question me-2"></i>FAQ Content</strong>
            </div>
            <div class="card-body">

                <!-- Question -->
                <div class="mb-4">
                    {{ form_label(form.question, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.question, {
                        'attr': {
                            'class': 'form-control' ~ (form.question.vars.errors|length > 0 ? ' is-invalid' : ''),
                            'placeholder': 'Enter the FAQ question…'
                        }
                    }) }}
                    {% if form.question.vars.errors|length > 0 %}
                        <div class="invalid-feedback d-block">
                            <i class="bi bi-exclamation-circle me-1"></i>
                            {% for error in form.question.vars.errors %}
                                {{ error.message }}{% if not loop.last %}, {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                <!-- Answer -->
                <div class="mb-2">
                    {{ form_label(form.answer, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.answer, {
                        'attr': {
                            'class': 'form-control' ~ (form.answer.vars.errors|length > 0 ? ' is-invalid' : ''),
                            'placeholder': 'Enter the answer…',
                            'rows': 5
                        }
                    }) }}
                    {% if form.answer.vars.errors|length > 0 %}
                        <div class="invalid-feedback d-block">
                            <i class="bi bi-exclamation-circle me-1"></i>
                            {% for error in form.answer.vars.errors %}
                                {{ error.message }}{% if not loop.last %}, {% endif %}
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom">
                <strong><i class="bi bi-gear-wide me-2"></i>Actions</strong>
            </div>
            <div class="card-body">
                {# Save — goes to index #}
                <button class="btn btn-light-info w-100 mb-2" id="submitBtn" type="submit">
                    <span id="submitText">{{ button_label|default('Save') }}</span>
                    <span id="submitSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status">
                    <span class="visually-hidden">Loading...</span>
                </span>
                </button>

                {#<button type="submit" name="_save" class="btn btn-primary w-100 mb-2">
                    <i class="bi bi-save me-1"></i> Save FAQ
                </button>#}

                {# Save & New — only shown on new form, goes back to new form #}
                {% if vfaq.id is null %}
                    <button type="submit" name="_save_and_new" class="btn btn-success w-100 mb-2">
                        <i class="bi bi-plus-circle me-1"></i> Save &amp; New
                    </button>
                {% endif %}

                <a href="{{ path('app_vfaq_index') }}" class="btn btn-light-secondary w-100">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>
        </div>
    </div>
</div>

{{ form_end(form) }}
