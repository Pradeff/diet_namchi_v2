{# templates/vnotice/index.html.twig #}
{% extends 'base_dashboard.html.twig' %}

{% block title %}Notices Management{% endblock %}

{% block body %}
<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5><i class="bi bi-megaphone"></i> Notices Management</h5>
        <a href="{{ path('app_vnotice_new') }}" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle"></i> Add Notice
        </a>
    </div>

    {% for type in ['success', 'danger', 'warning', 'info'] %}
        {% for msg in app.flashes(type) %}
            <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
                <i class="bi bi-{{ type == 'success' ? 'check-circle' : (type == 'danger' ? 'x-circle' : 'info-circle') }}"></i>
                {{ msg }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="d_table">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>Notice Date</th>
                            <th>PDF</th>
                            <th>Created</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for vnotice in vnotices %}
                            <tr>
                                <td class="text-muted small">{{ vnotice.id }}</td>
                                <td>
                                    <strong>{{ vnotice.title }}</strong>
                                    {% if vnotice.description %}
                                        <br><small class="text-muted">{{ vnotice.description|slice(0, 80) }}{% if vnotice.description|length > 80 %}…{% endif %}</small>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="badge bg-secondary">
                                        {{ vnotice.noticeDate ? vnotice.noticeDate|date('d M Y') : '—' }}
                                    </span>
                                </td>
                                <td>
                                    {% if vnotice.pdfFilename %}
                                        <a href="{{ asset('uploads/pdf/' ~ vnotice.pdfFilename) }}"
                                           target="_blank"
                                           class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-file-pdf"></i> View PDF
                                        </a>
                                    {% else %}
                                        <span class="text-muted small">—</span>
                                    {% endif %}
                                </td>
                                <td class="small text-muted">
                                    {{ vnotice.createdAt ? vnotice.createdAt|date('d M Y') : '—' }}
                                </td>
                                <td class="text-center">
                                    <a href="{{ path('app_vnotice_show', {'id': vnotice.id}) }}"
                                       class="btn btn-sm btn-outline-info" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a href="{{ path('app_vnotice_edit', {'id': vnotice.id}) }}"
                                       class="btn btn-sm btn-outline-warning" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    {{ include('vnotice/_delete_form.html.twig') }}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-megaphone display-4 d-block mb-3"></i>
                                    No notices found. <a href="{{ path('app_vnotice_new') }}">Add the first one</a>.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}
