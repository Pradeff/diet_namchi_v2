{# templates/vnotice/show.html.twig #}
{% extends 'base_dashboard.html.twig' %}

{% block title %}Notice — {{ vnotice.title }}{% endblock %}

{% block body %}
<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5><i class="bi bi-megaphone"></i> Notice Detail</h5>
        <div class="d-flex gap-2">
            <a href="{{ path('app_vnotice_edit', {'id': vnotice.id}) }}"
               class="btn btn-outline-warning">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a href="{{ path('app_vnotice_index') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back to list
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <strong><i class="bi bi-info-circle"></i> Notice Information</strong>
                </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <th style="width:160px;" class="text-muted">ID</th>
                            <td>{{ vnotice.id }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Title</th>
                            <td><strong>{{ vnotice.title }}</strong></td>
                        </tr>
                        <tr>
                            <th class="text-muted">Description</th>
                            <td>{{ vnotice.description ?? '<span class="text-muted">—</span>'|raw }}</td>
                        </tr>
                        <tr>
                            <th class="text-muted">Notice Date</th>
                            <td>
                                <span class="badge bg-secondary fs-6">
                                    {{ vnotice.noticeDate ? vnotice.noticeDate|date('d M Y') : '—' }}
                                </span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <strong><i class="bi bi-file-pdf text-danger"></i> PDF Attachment</strong>
                </div>
                <div class="card-body">
                    {% if vnotice.pdfFilename %}
                        <a href="{{ asset('uploads/pdf/' ~ vnotice.pdfFilename) }}"
                           target="_blank"
                           class="btn btn-outline-danger w-100">
                            <i class="bi bi-file-pdf"></i> Open PDF
                        </a>
                        <small class="text-muted d-block mt-2">{{ vnotice.pdfFilename }}</small>
                    {% else %}
                        <p class="text-muted mb-0">
                            <i class="bi bi-x-circle me-1"></i> No PDF attached.
                        </p>
                    {% endif %}
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <strong><i class="bi bi-clock-history"></i> Timestamps</strong>
                </div>
                <div class="card-body small text-muted">
                    <div class="mb-1">
                        <i class="bi bi-calendar-plus me-1"></i>
                        <strong>Created:</strong>
                        {{ vnotice.createdAt ? vnotice.createdAt|date('d M Y, H:i') : '—' }}
                    </div>
                    <div>
                        <i class="bi bi-calendar-check me-1"></i>
                        <strong>Updated:</strong>
                        {{ vnotice.updatedAt ? vnotice.updatedAt|date('d M Y, H:i') : '—' }}
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header">
                    <strong><i class="bi bi-gear-wide"></i> Actions</strong>
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <a href="{{ path('app_vnotice_edit', {'id': vnotice.id}) }}"
                       class="btn btn-outline-warning w-100">
                        <i class="bi bi-pencil"></i> Edit Notice
                    </a>
                    {{ include('vnotice/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>

</div>
{% endblock %}
